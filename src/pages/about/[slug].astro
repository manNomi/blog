---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import {
  portfolioProfile,
  portfolioProjects,
  resumeExperiences,
  type PortfolioLink,
  type PortfolioProject,
  type ResumeExperience
} from '../../data/portfolio';

type ProjectDetailProps = {
  detailType: 'project';
  project: PortfolioProject;
};

type ExperienceDetailProps = {
  detailType: 'experience';
  experience: ResumeExperience;
};

type DetailProps = ProjectDetailProps | ExperienceDetailProps;

export function getStaticPaths() {
  return [
    ...resumeExperiences.map((experience) => ({
      params: { slug: experience.slug },
      props: { detailType: 'experience', experience }
    })),
    ...portfolioProjects.map((project) => ({
      params: { slug: project.slug },
      props: { detailType: 'project', project }
    }))
  ];
}

const props = Astro.props as DetailProps;
const project = props.detailType === 'project' ? props.project : undefined;
const experience = props.detailType === 'experience' ? props.experience : undefined;
const currentProjectIndex = project ? portfolioProjects.findIndex((item) => item.slug === project.slug) : -1;
const nextProject =
  project && currentProjectIndex >= 0 ? portfolioProjects[(currentProjectIndex + 1) % portfolioProjects.length] : undefined;
const siteURL = Astro.site || Astro.url.origin;
const canonicalPath = `/about/${project?.slug ?? experience?.slug}`;
const detailURL = new URL(canonicalPath, siteURL).href;
const hasProjectImage = Boolean(project && !project.image.includes('portfolio-case-placeholder'));
const ogImage =
  project && project.image.endsWith('.svg') ? '/og-image.png' : project?.image ?? '/og-image.png';
const imageAlt = project?.imageAlt ?? `${portfolioProfile.name} 경력 상세`;
const imageWidth = project?.imageWidth ?? 1200;
const imageHeight = project?.imageHeight ?? 630;
const phoneBezelImage = '/images/ui/iphone-bezel.png';
const title = project
  ? `${project.title} | 한만욱 포트폴리오`
  : `${experience?.company} | 한만욱 경력`;
const description = project
  ? `${project.summary} ${project.metrics.map((metric) => `${metric.label} ${metric.value}`).join(', ')}`
  : `${experience?.description ?? ''} ${experience?.highlights
      .map((highlight) => [highlight.title, highlight.metric].filter(Boolean).join(' '))
      .join(', ')}`;
const keywords = project
  ? [project.title, project.eyebrow, ...project.techStack]
  : [experience?.company ?? '', experience?.role ?? '', 'Frontend', 'Experience'].filter(Boolean);
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': project ? 'CreativeWork' : 'ProfilePage',
  '@id': `${detailURL}#${project ? 'case-study' : 'experience'}`,
  url: detailURL,
  name: project?.title ?? experience?.company,
  description,
  inLanguage: 'ko-KR',
  creator: {
    '@type': 'Person',
    name: portfolioProfile.name,
    email: portfolioProfile.email,
    sameAs: [portfolioProfile.github]
  }
};
const experienceMetrics = experience?.highlights.filter((highlight) => highlight.metric).slice(0, 3) ?? [];
const experienceLinks = experience?.highlights.filter((highlight) => highlight.href) ?? [];
const isGithubLink = (link: PortfolioLink) => /github|저장소/i.test(link.label);
const projectPackageLinks = new Set(project?.packages?.map((item) => item.href) ?? []);
const projectGithubLinks = project?.links.filter(isGithubLink) ?? [];
const projectReferenceLinks = project?.links.filter((link) => !isGithubLink(link) && !projectPackageLinks.has(link.href)) ?? [];
const hasProjectPackages = Boolean(project?.packages?.length);
const hasProjectResponsiveDemo = Boolean(project?.responsiveDemo);
const hasProjectRouteDemo = Boolean(
  project && (project.slug === 'incheon-bus' || project.slug === 'dmap-map-grid' || hasProjectResponsiveDemo)
);
const demoStepLabel = hasProjectPackages ? '05' : '04';
const resultsStepLabel = String(4 + Number(hasProjectPackages) + Number(hasProjectRouteDemo)).padStart(2, '0');
const recordsStepLabel = String(5 + Number(hasProjectPackages) + Number(hasProjectRouteDemo)).padStart(2, '0');
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  image={ogImage}
  imageAlt={imageAlt}
  imageWidth={imageWidth}
  imageHeight={imageHeight}
  canonicalURL={canonicalPath}
  jsonLd={jsonLd}
>
  <Header />

  <main class="site-main about-detail-page">
    <div class="wrap">
      <div class="pt-7">
        <a
          href={project ? '/about#projects' : '/about#experience'}
          class="mono inline-flex items-center gap-2 py-2 transition-colors hover:!text-[var(--text)]"
          style="color: var(--text-dim);"
        >
          ← {project ? '프로젝트' : '경력'}
        </a>
      </div>

      {project ? (
        <>
          <header class="rise py-5 pb-9">
            <div class="mb-5 flex items-center gap-3">
              <span class="eyebrow">{project.eyebrow}</span>
              <span class="mono whitespace-nowrap opacity-60">· {project.period}</span>
            </div>
            <h1 class="m-0 text-[clamp(2.1rem,5vw,3.2rem)] font-bold leading-[1.12] tracking-[-0.04em]" style="color: var(--text);">{project.title}</h1>
            <p class="mt-5 max-w-[30ch] text-[1.25rem] font-medium leading-[1.5] tracking-[-0.02em]" style="color: var(--text);">“{project.quote}”</p>
            <p class="mt-5 max-w-[60ch] text-[1.02rem] leading-[1.7]" style="color: var(--text-dim);">{project.summary}</p>
            {projectGithubLinks.length > 0 && (
              <div class="mt-7 flex flex-wrap gap-2.5">
                {projectGithubLinks.map((link) => (
                  <a
                    href={link.href}
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                    class="pill h-8"
                    style="color: var(--text); border-color: var(--border-strong);"
                  >
                    {link.label} →
                  </a>
                ))}
              </div>
            )}
            <div class="mt-6 flex flex-wrap gap-6">
              <div>
                <div class="mono mb-1" style="color: var(--text-faint);">역할</div>
                <div class="whitespace-nowrap text-[0.95rem] font-semibold" style="color: var(--text);">{project.role}</div>
              </div>
              {project.team && (
                <div>
                  <div class="mono mb-1" style="color: var(--text-faint);">팀</div>
                  <div class="whitespace-nowrap text-[0.95rem] font-semibold" style="color: var(--text);">{project.team}</div>
                </div>
              )}
              {project.contribution && (
                <div>
                  <div class="mono mb-1" style="color: var(--text-faint);">기여</div>
                  <div class="whitespace-nowrap text-[0.95rem] font-semibold" style="color: var(--text);">{project.contribution}</div>
                </div>
              )}
            </div>
          </header>

          {hasProjectImage && project.visualMode === 'phone' ? (
            <div class="phone-frame phone-frame--cover mb-2">
              <img src={phoneBezelImage} alt="" class="phone-frame__bezel" loading="eager" decoding="async" aria-hidden="true" />
              <div class="phone-frame__screen">
                <img
                  src={project.image}
                  alt={project.imageAlt}
                  width={project.imageWidth}
                  height={project.imageHeight}
                  class="phone-frame__image"
                  loading="eager"
                  decoding="async"
                />
              </div>
            </div>
          ) : hasProjectImage ? (
            <img
              src={project.image}
              alt={project.imageAlt}
              width={project.imageWidth}
              height={project.imageHeight}
              class="project-cover mb-2 rounded-[18px]"
              loading="eager"
              decoding="async"
            />
          ) : (
            <div class="ph mb-2 rounded-[18px]" data-label={`${project.slug} — cover`} style="aspect-ratio: 16 / 7;"></div>
          )}

          {project.gallery && project.gallery.length > 0 && (
            <section class="py-8">
              <div class="mb-4 flex flex-wrap items-end justify-between gap-3">
                <div>
                  <div class="mono mb-1.5" style="color: var(--text-faint);">README assets</div>
                  <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">프로젝트 화면</h2>
                </div>
                <span class="mono" style="color: var(--text-faint);">{project.gallery.length} images</span>
              </div>

              <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                {project.gallery.map((item) => (
                  <figure class="m-0 overflow-hidden rounded-[16px] border p-3" style="border-color: var(--border); background: var(--surface);">
                    <div class="grid min-h-[260px] place-items-center rounded-[12px]" style="background: var(--bg-soft);">
                      <img
                        src={item.src}
                        alt={item.alt}
                        width={item.width}
                        height={item.height}
                        class="max-h-[420px] w-full object-contain"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                    <figcaption class="mono mt-3 text-[0.72rem]" style="color: var(--text-faint);">{item.caption}</figcaption>
                  </figure>
                ))}
              </div>
            </section>
          )}

          {project.livePreview && (
            <section class="live-preview-section py-9">
              <div class="section-head">
                <div>
                  <div class="eyebrow mb-2">Live preview</div>
                  <h2 class="section-title">실제 서비스 화면</h2>
                </div>
                <a
                  href={project.livePreview.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mono whitespace-nowrap"
                  style="color: var(--text-dim);"
                >
                  {project.livePreview.label} →
                </a>
              </div>
              <div class="live-preview-wrap">
                <div class="phone-frame phone-frame--iframe">
                  <img src={phoneBezelImage} alt="" class="phone-frame__bezel" loading="lazy" decoding="async" aria-hidden="true" />
                  <div class="phone-frame__screen">
                    <iframe
                      src={project.livePreview.url}
                      title={`${project.title} 실제 서비스 미리보기`}
                      class="live-preview-iframe"
                      loading="lazy"
                      referrerpolicy="strict-origin-when-cross-origin"
                      sandbox="allow-scripts allow-same-origin allow-popups allow-forms"
                    ></iframe>
                  </div>
                </div>
                <div class="live-preview-copy">
                  <p>{project.livePreview.description}</p>
                  <div class="flex flex-wrap gap-2.5">
                    <a
                      href={project.livePreview.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="pill h-8"
                      style="color: var(--text); border-color: var(--border-strong);"
                    >
                      새 탭에서 보기 →
                    </a>
                  </div>
                </div>
              </div>
            </section>
          )}

          <section class="py-9 pb-1">
            <div class="metric-3">
              {project.metrics.map((metric) => (
                <div class="border-t py-6 pr-5" style="border-color: var(--border);">
                  <div class="text-[2.1rem] font-bold leading-none tracking-[-0.04em]" style="color: var(--text);">{metric.value}</div>
                  <div class="mt-2.5 text-[0.88rem]" style="color: var(--text-dim);">{metric.label}</div>
                </div>
              ))}
            </div>
          </section>

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">01 · Problem</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">문제</h2>
            </div>
            <p class="m-0 max-w-[62ch] text-[1.05rem] leading-[1.75]" style="color: var(--text);">{project.problem}</p>
          </section>

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">02 · Role</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">역할</h2>
            </div>
            <div>
              <p class="m-0 max-w-[62ch] text-[1.02rem] leading-[1.7]" style="color: var(--text-dim);">
                {[project.role, project.team, project.contribution].filter(Boolean).join(' · ')}
              </p>
              <div class="mt-4 flex flex-wrap gap-2">
                {project.techStack.map((tech) => <span class="pill cursor-default">{tech}</span>)}
              </div>
            </div>
          </section>

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">03 · Approach</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">해결 과정</h2>
            </div>
            <ol class="m-0 flex list-none flex-col gap-[18px] p-0">
              {project.approach.map((item, index) => (
                <li class="grid grid-cols-[auto_1fr] items-start gap-4">
                  <span class="mono grid h-[26px] w-[26px] place-items-center rounded-full border text-[0.7rem]" style="border-color: var(--border); color: var(--text-dim);">{index + 1}</span>
                  <span class="pt-px text-base leading-[1.7]" style="color: var(--text);">{item}</span>
                </li>
              ))}
            </ol>
          </section>

          {hasProjectPackages && (
            <section class="flow-row package-ecosystem-row">
              <div>
                <div class="mono mb-1.5" style="color: var(--text-faint);">04 · Packages</div>
                <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">패키지 구성</h2>
              </div>
              <div class="package-grid">
                {project.packages?.map((item) => (
                  <article class="package-card">
                    <div class="package-card-head">
                      <div class="mono package-card-label">{item.label}</div>
                      <h3>{item.name}</h3>
                    </div>
                    <div class="package-card-body">
                      <p>{item.description}</p>
                      <div class="package-command" aria-label={`${item.name} 설치 명령어`}>
                        <span>{item.installCommand}</span>
                      </div>
                      <div class="mono package-focus">{item.focus}</div>
                      <ul class="package-points">
                        {item.points.map((point) => (
                          <li>{point}</li>
                        ))}
                      </ul>
                    </div>
                    <a
                      href={item.href}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="pill h-8 package-card-action"
                      style="color: var(--text); border-color: var(--border-strong);"
                    >
                      npm →
                    </a>
                  </article>
                ))}
              </div>
            </section>
          )}

          {hasProjectRouteDemo && (
            <section class="flow-row demo-section">
              <div>
                <div class="mono mb-1.5" style="color: var(--text-faint);">{demoStepLabel} · Demo</div>
                <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">동작 데모</h2>
              </div>

              {project.responsiveDemo ? (
                <div class="responsive-demo-panel" data-responsive-demo data-viewport="mobile">
                  <div class="responsive-demo-toolbar">
                    <div>
                      <div class="mono route-demo-kicker">{project.responsiveDemo.label}</div>
                      <p>{project.responsiveDemo.description}</p>
                    </div>
                    <div class="responsive-demo-toggle" role="group" aria-label="풋볼스퀘어 데모 뷰 선택">
                      <button type="button" class="responsive-demo-toggle-button" data-demo-viewport="mobile" aria-pressed="true">
                        모바일
                      </button>
                      <button type="button" class="responsive-demo-toggle-button" data-demo-viewport="desktop" aria-pressed="false">
                        데스크톱
                      </button>
                    </div>
                  </div>

                  <div class="responsive-demo-stage">
                    <div class="responsive-demo-view responsive-demo-view--mobile" data-demo-view="mobile">
                      <div class="phone-frame phone-frame--football-demo">
                        <img src={phoneBezelImage} alt="" class="phone-frame__bezel" loading="lazy" decoding="async" aria-hidden="true" />
                        <div class="phone-frame__screen">
                          <iframe
                            src={project.responsiveDemo.url}
                            title={`${project.title} 모바일 데모`}
                            class="responsive-demo-iframe"
                            loading="eager"
                            sandbox="allow-scripts allow-same-origin allow-forms"
                          ></iframe>
                        </div>
                      </div>
                    </div>

                    <div class="responsive-demo-view responsive-demo-view--desktop" data-demo-view="desktop">
                      <div class="desktop-demo-frame">
                        <div class="desktop-demo-chrome" aria-hidden="true">
                          <span></span>
                          <span></span>
                          <span></span>
                          <strong>{project.responsiveDemo.label}</strong>
                        </div>
                        <iframe
                          src={project.responsiveDemo.url}
                          title={`${project.title} 데스크톱 데모`}
                          class="responsive-demo-iframe"
                          loading="eager"
                          sandbox="allow-scripts allow-same-origin allow-forms"
                        ></iframe>
                      </div>
                    </div>
                  </div>
                </div>
              ) : project.slug === 'incheon-bus' ? (
                <div class="route-demo-panel" data-route-demo="bus">
                  <div class="phone-frame phone-frame--bus-live">
                    <img src={phoneBezelImage} alt="" class="phone-frame__bezel" loading="lazy" decoding="async" aria-hidden="true" />
                    <div class="phone-frame__screen">
                      <iframe
                        src="/demos/bus-live-demo.html"
                        title="BusLive 실제 동작 데모"
                        class="demo-iframe"
                        loading="eager"
                        sandbox="allow-scripts allow-same-origin allow-forms"
                      ></iframe>
                    </div>
                  </div>
                  <aside class="route-demo-copy" aria-live="polite">
                    <div class="mono route-demo-kicker" data-demo-kicker>BusLive · #/map</div>
                    <h3 data-demo-title>실시간 위치 지도</h3>
                    <p data-demo-description>
                      정류장 주변의 버스 위치와 도착 예측을 한 화면에서 확인하는 핵심 진입 화면입니다.
                    </p>
                    <div class="route-demo-tech" data-demo-tech-list>
                      <span class="pill">Naver Maps 구조</span>
                      <span class="pill">ETA 상태 계산</span>
                      <span class="pill">WebSocket Mock</span>
                    </div>
                    <div class="route-demo-note">
                      <div class="mono">What I built</div>
                      <p data-demo-impact>
                        지도 위 레이어, 정류장 선택, 도착 예측 상태를 하나의 모바일 흐름으로 엮어 MVP 시연 가능한 형태로 구성했습니다.
                      </p>
                    </div>
                  </aside>
                </div>
              ) : (
                <div class="route-demo-panel" data-route-demo="dmap">
                  <div class="phone-frame phone-frame--dmap-live">
                    <img src={phoneBezelImage} alt="" class="phone-frame__bezel" loading="lazy" decoding="async" aria-hidden="true" />
                    <div class="phone-frame__screen">
                      <iframe
                        src="/demos/portfolio-dmap-demo.html"
                        title="DMap 실제 동작 데모"
                        class="demo-iframe"
                        loading="eager"
                        sandbox="allow-scripts allow-same-origin allow-forms"
                      ></iframe>
                    </div>
                  </div>
                  <aside class="route-demo-copy" aria-live="polite">
                    <div class="mono route-demo-kicker" data-demo-kicker>DMap · sns</div>
                    <h3 data-demo-title>SNS 피드와 정적 지도 썸네일</h3>
                    <p data-demo-description>
                      사용자의 이동 기록을 피드 형태로 보여주고, 여러 지도 썸네일을 정적 이미지처럼 다루는 화면입니다.
                    </p>
                    <div class="route-demo-tech" data-demo-tech-list>
                      <span class="pill">Static Map</span>
                      <span class="pill">Feed State</span>
                      <span class="pill">Map Thumbnail</span>
                    </div>
                    <div class="route-demo-note">
                      <div class="mono">What I built</div>
                      <p data-demo-impact>
                        다수의 지도 렌더링을 정적 썸네일로 낮추고, 상세 화면에서만 동적 지도를 쓰는 하이브리드 구조의 출발점입니다.
                      </p>
                    </div>
                  </aside>
                </div>
              )}
            </section>
          )}

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">{resultsStepLabel} · Results</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">성과</h2>
            </div>
            <div class="overflow-hidden rounded-[14px] border" style="border-color: var(--border);">
              {project.results.map((result, index) => (
                <div class={`result-row ${index > 0 ? 'border-t' : ''}`} style="border-color: var(--border);">
                  <div class="text-[0.9rem] font-semibold" style="color: var(--text);">{result.label}</div>
                  <div class="flex items-center gap-3 text-[0.9rem]" style="color: var(--text-dim);">
                    {result.before && <><span class="mono whitespace-nowrap line-through opacity-70">{result.before}</span><span class="opacity-50">→</span></>}
                    <span class="whitespace-nowrap font-bold" style="color: var(--text);">{result.after}</span>
                  </div>
                  <div class="mono text-right" style="color: var(--text-faint);">{result.effect}</div>
                </div>
              ))}
            </div>
          </section>

          {projectReferenceLinks.length > 0 && (
            <section class="flow-row">
              <div>
                <div class="mono mb-1.5" style="color: var(--text-faint);">{recordsStepLabel} · Records</div>
                <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">관련 기록</h2>
              </div>
              <div class="flex flex-wrap gap-2.5">
                {projectReferenceLinks.map((link) => (
                  <a
                    href={link.href}
                    target={link.external ? '_blank' : undefined}
                    rel={link.external ? 'noopener noreferrer' : undefined}
                    class="pill h-8"
                    style="color: var(--text); border-color: var(--border-strong);"
                  >
                    {link.label} →
                  </a>
                ))}
              </div>
            </section>
          )}

          <hr class="rule" />

          {nextProject && (
            <a href={`/about/${nextProject.slug}`} class="flex items-center justify-between gap-5 px-1 pt-8">
              <div>
                <div class="mono mb-1.5" style="color: var(--text-faint);">다음 프로젝트</div>
                <h3 class="m-0 text-2xl font-bold tracking-[-0.03em] transition-opacity hover:opacity-60" style="color: var(--text);">{nextProject.title}</h3>
              </div>
              <span class="text-2xl" style="color: var(--text-faint);">→</span>
            </a>
          )}
        </>
      ) : experience ? (
        <>
          <header class="rise py-5 pb-9">
            <div class="mb-5 flex items-center gap-3">
              <span class="eyebrow">Experience</span>
              <span class="mono whitespace-nowrap opacity-60">· {experience.period}</span>
            </div>
            <div class="experience-heading">
              {experience.logo && (
                <span class={`company-logo company-logo--hero company-logo--${experience.logo.shape}`} aria-hidden="true">
                  <img
                    src={experience.logo.src}
                    alt=""
                    width={experience.logo.width}
                    height={experience.logo.height}
                    loading="eager"
                    decoding="async"
                  />
                </span>
              )}
              <h1 class="m-0 text-[clamp(2.1rem,5vw,3.2rem)] font-bold leading-[1.12] tracking-[-0.04em]" style="color: var(--text);">{experience.company}</h1>
            </div>
            <p class="mt-5 max-w-[42ch] text-[1.2rem] font-medium leading-[1.5] tracking-[-0.02em]" style="color: var(--text);">{experience.team}</p>
            <p class="mt-5 max-w-[60ch] text-[1.02rem] leading-[1.7]" style="color: var(--text-dim);">{experience.description}</p>
            <div class="mt-6 flex flex-wrap gap-6">
              <div>
                <div class="mono mb-1" style="color: var(--text-faint);">역할</div>
                <div class="whitespace-nowrap text-[0.95rem] font-semibold" style="color: var(--text);">{experience.role}</div>
              </div>
              <div>
                <div class="mono mb-1" style="color: var(--text-faint);">기간</div>
                <div class="whitespace-nowrap text-[0.95rem] font-semibold" style="color: var(--text);">{experience.period}</div>
              </div>
            </div>
          </header>

          {experienceMetrics.length > 0 && (
            <section class="py-9 pb-1">
              <div class="metric-3">
                {experienceMetrics.map((highlight) => (
                  <div class="border-t py-6 pr-5" style="border-color: var(--border);">
                    <div class="text-[2.1rem] font-bold leading-none tracking-[-0.04em]" style="color: var(--text);">{highlight.metric}</div>
                    <div class="mt-2.5 text-[0.88rem]" style="color: var(--text-dim);">{highlight.title}</div>
                  </div>
                ))}
              </div>
            </section>
          )}

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">01 · Context</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">제품 맥락</h2>
            </div>
            <p class="m-0 max-w-[62ch] text-[1.05rem] leading-[1.75]" style="color: var(--text);">{experience.team}</p>
          </section>

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">02 · Role</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">역할</h2>
            </div>
            <p class="m-0 max-w-[62ch] text-[1.02rem] leading-[1.7]" style="color: var(--text-dim);">{experience.role} · {experience.period}</p>
          </section>

          <section class="flow-row">
            <div>
              <div class="mono mb-1.5" style="color: var(--text-faint);">03 · Contributions</div>
              <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">주요 기여</h2>
            </div>
            <div class="detail-list">
              {experience.highlights.map((highlight) => (
                <article class="experience-detail-item">
                  <div>
                    <h3 class="m-0 text-[1rem] font-bold tracking-[-0.02em]" style="color: var(--text);">{highlight.title}</h3>
                    {highlight.metric && <div class="mono mt-1" style="color: var(--text-faint);">{highlight.metric}</div>}
                  </div>
                  <p class="m-0 text-[0.95rem] leading-[1.65]" style="color: var(--text-dim);">{highlight.description}</p>
                  {highlight.href && (
                    <a href={highlight.href} class="mono detail-link" style="color: var(--text);">관련 글 →</a>
                  )}
                </article>
              ))}
            </div>
          </section>

          {experienceLinks.length > 0 && (
            <section class="flow-row">
              <div>
                <div class="mono mb-1.5" style="color: var(--text-faint);">04 · Records</div>
                <h2 class="m-0 text-[1.25rem] font-bold tracking-[-0.02em]" style="color: var(--text);">관련 기록</h2>
              </div>
              <div class="flex flex-wrap gap-2.5">
                {experienceLinks.map((highlight) => (
                  <a href={highlight.href} class="pill h-8" style="color: var(--text); border-color: var(--border-strong);">
                    {highlight.title} →
                  </a>
                ))}
              </div>
            </section>
          )}
        </>
      ) : null}
    </div>
  </main>

  <Footer />

  <script is:inline>
    const routeDemoCopy = {
      bus: {
        map: {
          kicker: 'BusLive · #/map',
          title: '실시간 위치 지도',
          description: '정류장 주변의 버스 위치와 도착 예측을 한 화면에서 확인하는 핵심 진입 화면입니다.',
          tech: ['Naver Maps 구조', 'ETA 상태 계산', 'WebSocket Mock'],
          impact: '지도 위 레이어, 정류장 선택, 도착 예측 상태를 하나의 모바일 흐름으로 엮어 MVP 시연 가능한 형태로 구성했습니다.'
        },
        chatList: {
          kicker: 'BusLive · #/chatList',
          title: '정류장별 채팅 목록',
          description: '사용자가 이동 중에도 현재 필요한 정류장 채팅방으로 빠르게 들어갈 수 있게 만든 목록 화면입니다.',
          tech: ['Route Overlay', 'Room State', 'Unread Badge'],
          impact: '광고 영역과 채팅 UI가 겹치는 문제를 고려해 레이어 우선순위와 진입 흐름을 분리했습니다.'
        },
        chat: {
          kicker: 'BusLive · #/chat/:stop',
          title: '정류장 실시간 채팅',
          description: '같은 정류장을 보는 사용자가 실시간으로 정보를 공유하는 채팅 화면입니다.',
          tech: ['WebSocket Flow', 'Message Append', 'Auto Scroll'],
          impact: 'Socket 기반 메시지 흐름을 모바일 패널 안에 녹이고, 지도 화면으로 자연스럽게 복귀할 수 있는 구조를 만들었습니다.'
        }
      },
      dmap: {
        sns: {
          kicker: 'DMap · sns',
          title: 'SNS 피드와 정적 지도 썸네일',
          description: '사용자의 이동 기록을 피드 형태로 보여주고, 여러 지도 썸네일을 정적 이미지처럼 다루는 화면입니다.',
          tech: ['Static Map', 'Feed State', 'Map Thumbnail'],
          impact: '다수의 지도 렌더링을 정적 썸네일로 낮추고, 상세 화면에서만 동적 지도를 쓰는 하이브리드 구조의 출발점입니다.'
        },
        search: {
          kicker: 'DMap · search',
          title: '장소 검색과 경로 탐색',
          description: '사용자가 기록할 장소를 찾고, 지도 기반 이동 기록으로 이어가는 검색 화면입니다.',
          tech: ['Search State', 'Place Result', 'Map Preview'],
          impact: '검색 결과, 지도 미리보기, 기록 생성 액션을 한 흐름에 묶어 사용자가 다음 행동을 잃지 않게 설계했습니다.'
        },
        tracking: {
          kicker: 'DMap · tracking',
          title: '동적 지도 트래킹',
          description: '선택한 이동 기록을 실제 지도처럼 탐색하며 경로와 위치 정보를 확인하는 화면입니다.',
          tech: ['Dynamic Map', 'Global Map Instance', 'Route Overlay'],
          impact: '여러 WebGL 지도를 동시에 띄우는 대신 전역 동적 지도 1개만 사용해 크래시와 비용 문제를 줄였습니다.'
        },
        profile: {
          kicker: 'DMap · profile',
          title: '프로필 지도 그리드',
          description: '프로필 안에서 3x3 지도 썸네일을 빠르게 훑고, 필요한 기록만 상세로 들어가는 화면입니다.',
          tech: ['3x3 Grid', 'Static Thumbnail', 'Portal Detail'],
          impact: '제가 담당한 핵심 화면으로, 18개 지도 렌더링으로 생기던 WebGL 한계와 API 과금 문제를 정적 썸네일 전략으로 해결했습니다.'
        },
        setting: {
          kicker: 'DMap · setting',
          title: '공유 설정과 권한 흐름',
          description: '위치 기록의 공개 범위와 사용자 설정을 관리하는 화면입니다.',
          tech: ['Permission UI', 'Visibility State', 'User Setting'],
          impact: '위치 기반 서비스에서 중요한 공개 범위와 설정 변경 흐름을 화면 단위로 분리해 사용자 통제감을 높였습니다.'
        },
        login: {
          kicker: 'DMap · login',
          title: '로그인 진입',
          description: '위치 기록을 개인 계정과 연결하기 위한 인증 진입 화면입니다.',
          tech: ['Auth Entry', 'CTA Flow', 'Session Gate'],
          impact: '비로그인 상태에서도 서비스 맥락을 잃지 않고, 기록 저장이 필요한 순간 인증으로 이어지게 구성했습니다.'
        }
      }
    };

    const renderRouteDemoCopy = (panel, copy) => {
      if (!copy) return;

      const kicker = panel.querySelector('[data-demo-kicker]');
      const title = panel.querySelector('[data-demo-title]');
      const description = panel.querySelector('[data-demo-description]');
      const techList = panel.querySelector('[data-demo-tech-list]');
      const impact = panel.querySelector('[data-demo-impact]');

      if (kicker) kicker.textContent = copy.kicker;
      if (title) title.textContent = copy.title;
      if (description) description.textContent = copy.description;
      if (impact) impact.textContent = copy.impact;
      if (techList) {
        techList.replaceChildren(
          ...copy.tech.map((tech) => {
            const pill = document.createElement('span');
            pill.className = 'pill';
            pill.textContent = tech;
            return pill;
          })
        );
      }
    };

    const getBusRouteKey = (iframe) => {
      try {
        const hash = iframe.contentWindow?.location.hash || '';
        if (hash.startsWith('#/chat/')) return 'chat';
        if (hash === '#/chatList') return 'chatList';
      } catch {
        return 'map';
      }

      return 'map';
    };

    const getDmapRouteKey = (iframe) => {
      try {
        const activePage = iframe.contentDocument?.querySelector('.page-view.is-active');
        return activePage?.getAttribute('data-page') || 'sns';
      } catch {
        return 'sns';
      }
    };

    document.querySelectorAll('[data-route-demo]').forEach((panel) => {
      const demoKind = panel.getAttribute('data-route-demo');
      const iframe = panel.querySelector('iframe');
      let currentKey = '';

      if (!demoKind || !iframe) return;

      const syncCopy = () => {
        const key = demoKind === 'bus' ? getBusRouteKey(iframe) : getDmapRouteKey(iframe);
        if (key === currentKey) return;
        currentKey = key;
        renderRouteDemoCopy(panel, routeDemoCopy[demoKind]?.[key]);
      };

      iframe.addEventListener('load', syncCopy);
      syncCopy();
      window.setInterval(syncCopy, 350);
    });

    document.querySelectorAll('[data-responsive-demo]').forEach((panel) => {
      const buttons = Array.from(panel.querySelectorAll('[data-demo-viewport]'));

      const setViewport = (viewport) => {
        panel.dataset.viewport = viewport;
        buttons.forEach((button) => {
          button.setAttribute('aria-pressed', String(button.dataset.demoViewport === viewport));
        });
      };

      buttons.forEach((button) => {
        button.addEventListener('click', () => setViewport(button.dataset.demoViewport || 'mobile'));
      });

      setViewport(panel.dataset.viewport || 'mobile');
    });
  </script>
</BaseLayout>
