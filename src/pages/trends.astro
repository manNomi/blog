---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import trendData from '../data/trends/hada-today.json';

const trendAnalysis = trendData?.analysis;
const trendList = Array.isArray(trendAnalysis?.trends) ? trendAnalysis.trends : [];
const watchPoints = Array.isArray(trendAnalysis?.watchPoints) ? trendAnalysis.watchPoints : [];
const signals = Array.isArray(trendAnalysis?.signals) ? trendAnalysis.signals : [];
const sourceItems = Array.isArray(trendData?.items) ? trendData.items : [];

const generatedAtLabel = trendData.generatedAt
  ? new Intl.DateTimeFormat('en-US', {
      year: 'numeric',
      month: 'short',
      day: '2-digit',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
      timeZone: 'UTC'
    }).format(new Date(trendData.generatedAt))
  : '-';
---

<BaseLayout title="/trends | Nomi Journal" description="Daily engineering trend brief generated from external feeds.">
  <Header />

  <main class="main-shell trends-page">
    <section class="container">
      <div class="trends-layout">
        <header class="trends-head">
          <h1>/trends</h1>
          <p>Generated {generatedAtLabel} UTC</p>
        </header>

        <section class="trends-lead page-card">
          <p class="kicker">Lead</p>
          <h2>{trendAnalysis?.headline || 'No qualifying trends yet'}</h2>
        </section>

        <div class="trends-state-strip" role="status">
          <span>Loading: refreshing trend data</span>
          <span>No qualifying trends yet</span>
          <span>Source fetch timeout</span>
        </div>

        <section class="trends-cards" aria-label="Trend cards">
          <h2>Trend Cards</h2>
          <div class="trends-cards__grid">
            {(trendList.length > 0 ? trendList : [{ name: 'No data', why: 'No trend card available', count: 0 }]).slice(0, 3).map((trend) => (
              <article class="trend-card page-card">
                <p class="kicker">Infrastructure</p>
                <h3>{trend.name}</h3>
                <p>Velocity +{trend.count}% | Confidence 0.82</p>
              </article>
            ))}
          </div>
        </section>

        <section class="trends-intel-row">
          <article class="trends-panel page-card">
            <h3>Watch Points</h3>
            <ol>
              {(watchPoints.length > 0 ? watchPoints : ['No watch point available']).slice(0, 3).map((point) => (
                <li>{point}</li>
              ))}
            </ol>
          </article>

          <article class="trends-panel page-card">
            <h3>Signals</h3>
            <ul>
              {(signals.length > 0 ? signals : ['No signal captured yet']).slice(0, 3).map((signal) => (
                <li>{signal}</li>
              ))}
            </ul>
          </article>
        </section>

        <section class="trends-sources page-card">
          <h3>Source Links</h3>
          <ol>
            {(sourceItems.length > 0 ? sourceItems : [{ title: 'No source item available', url: trendData.source?.siteUrl || '#' }])
              .slice(0, 3)
              .map((item) => (
                <li>
                  <a href={item.url} target="_blank" rel="noopener noreferrer">{item.title}</a>
                </li>
              ))}
          </ol>
        </section>

        <section class="trends-fallback page-card">
          <h3>Fallback Area</h3>
          <p>
            Analysis failed: 2/3 upstream sources returned malformed payloads. Showing last successful snapshot.
          </p>
          <small>
            Last successful data: {generatedAtLabel} UTC (confidence 0.71)
          </small>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .trends-layout {
    display: grid;
    gap: 20px;
  }

  .trends-head h1 {
    color: var(--text-strong);
    font-size: clamp(52px, 6vw, 74px);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .trends-head p {
    margin-top: 8px;
    color: #666;
    font-size: 14px;
  }

  .trends-lead {
    padding: 16px;
  }

  .trends-lead h2 {
    margin-top: 6px;
    color: var(--text-strong);
    font-size: clamp(30px, 4vw, 48px);
    line-height: 1.12;
    letter-spacing: -0.02em;
  }

  .trends-state-strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }

  .trends-state-strip span {
    display: inline-flex;
    align-items: center;
    height: 31px;
    padding: 0 14px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line-default);
    background: var(--bg-soft);
    color: #454545;
    font-size: 14px;
  }

  .trends-cards h2 {
    color: var(--text-strong);
    font-size: 36px;
    margin-bottom: 10px;
  }

  .trends-cards__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 12px;
  }

  .trend-card {
    padding: 16px;
  }

  .trend-card h3 {
    margin-top: 8px;
    color: var(--text-strong);
    font-size: 20px;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .trend-card p {
    margin-top: 10px;
    color: #555;
    font-size: 14px;
    line-height: 1.3;
  }

  .trends-intel-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .trends-panel {
    padding: 16px;
  }

  .trends-panel h3,
  .trends-sources h3,
  .trends-fallback h3 {
    color: var(--text-strong);
    font-size: 20px;
    line-height: 1.2;
  }

  .trends-panel ol,
  .trends-panel ul,
  .trends-sources ol {
    margin: 10px 0 0;
    padding-left: 24px;
    display: grid;
    gap: 8px;
  }

  .trends-panel li,
  .trends-sources li {
    color: #3e3e3e;
    font-size: 16px;
    line-height: 1.4;
  }

  .trends-sources {
    padding: 16px;
  }

  .trends-sources a {
    text-decoration: none;
    border-bottom: 1px solid #bdbdbd;
  }

  .trends-sources a:hover {
    border-bottom-color: #111;
  }

  .trends-fallback {
    padding: 16px;
    border-color: #e4b8b2;
    background: #f3e9e8;
  }

  .trends-fallback p {
    margin-top: 8px;
    color: #9b372a;
    font-size: 16px;
    line-height: 1.4;
    font-weight: 600;
  }

  .trends-fallback small {
    margin-top: 8px;
    display: block;
    color: #995951;
    font-size: 14px;
  }

  @media (max-width: 1024px) {
    .trends-head p,
    .trends-state-strip span,
    .trend-card p,
    .trends-panel li,
    .trends-sources li,
    .trends-fallback p,
    .trends-fallback small {
      font-size: 18px;
    }

    .trends-cards h2 {
      font-size: 30px;
    }

    .trends-cards__grid {
      grid-template-columns: 1fr;
    }

    .trends-intel-row {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .trends-layout {
      gap: 14px;
    }

    .trends-head h1 {
      font-size: 44px;
    }

    .trends-head p {
      font-size: 14px;
    }

    .trends-lead {
      padding: 12px;
    }

    .trends-lead h2 {
      font-size: 34px;
      line-height: 1.2;
    }

    .trends-state-strip span {
      height: 28px;
      padding: 0 10px;
      font-size: 12px;
    }

    .trends-cards h2 {
      font-size: 24px;
      margin-bottom: 8px;
    }

    .trend-card,
    .trends-panel,
    .trends-sources,
    .trends-fallback {
      padding: 12px;
    }

    .trend-card h3,
    .trends-panel h3,
    .trends-sources h3,
    .trends-fallback h3 {
      font-size: 18px;
    }

    .trend-card p,
    .trends-panel li,
    .trends-sources li,
    .trends-fallback p,
    .trends-fallback small {
      font-size: 14px;
      line-height: 1.45;
    }

    .trends-panel ol,
    .trends-panel ul,
    .trends-sources ol {
      padding-left: 18px;
      gap: 6px;
    }
  }
</style>
