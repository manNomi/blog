---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CompatibilityConstellation from '../../components/CompatibilityConstellation';
---

<BaseLayout title="궁합 보기 | Nomi Journal" description="이름과 MBTI로 사람들의 궁합을 별자리 그래프로 살펴보는 미니게임">
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="mx-auto max-w-[1080px]">
        <nav class="mb-4 flex flex-wrap gap-2" aria-label="게임 메뉴">
          <a href="/game" class="pill">게임 목록</a>
          <a href="/game/fortune" class="pill">운세보기</a>
          <a href="/game/dice" class="pill">주사위 게임</a>
          <a href="/game/ladder" class="pill">사다리타기</a>
        </nav>

        <CompatibilityConstellation client:load />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
