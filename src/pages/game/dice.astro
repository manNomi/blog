---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SajuDicePage from '../../components/SajuDicePage';
---

<BaseLayout title="주사위 게임 | Nomi Journal" description="숫자와 키워드로 가볍게 굴리는 3D 주사위 미니게임">
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="mx-auto max-w-[1080px]">
        <nav class="mb-4 flex flex-wrap gap-2" aria-label="게임 메뉴">
          <a href="/game" class="pill">게임 목록</a>
          <a href="/game/fortune" class="pill">운세보기</a>
          <a href="/game/compatibility" class="pill">궁합 보기</a>
          <a href="/game/ladder" class="pill">사다리타기</a>
        </nav>

        <SajuDicePage client:load />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
