---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';
import { calculateReadingTime } from '../../utils/readingTime';
import { extractFirstImage } from '../../utils/extractFirstImage';
import { isNotePost, sortPostsByPubDateDesc } from '../../utils/postFilters';

type NavPost = { title: string; slug: string };
type RelatedPost = { title: string; slug: string; description?: string; pubDate: Date };

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const sortedPosts = sortPostsByPubDateDesc(posts);

  return sortedPosts.map((post) => {
    const isCurrentNote = isNotePost(post);
    const siblingPosts = sortedPosts.filter((candidate) => isNotePost(candidate) === isCurrentNote);
    const index = siblingPosts.findIndex((candidate) => candidate.slug === post.slug);
    const previous = siblingPosts[index + 1];
    const next = siblingPosts[index - 1];

    const currentTags = new Set(post.data.tags || []);

    const relatedPosts: RelatedPost[] = sortedPosts
      .filter((candidate) => candidate.slug !== post.slug && isNotePost(candidate) === isCurrentNote)
      .map((candidate) => {
        const sharedTags = (candidate.data.tags || []).filter((tag) => currentTags.has(tag)).length;
        return {
          candidate,
          sharedTags
        };
      })
      .sort((a, b) => {
        if (b.sharedTags !== a.sharedTags) return b.sharedTags - a.sharedTags;
        return b.candidate.data.pubDate.valueOf() - a.candidate.data.pubDate.valueOf();
      })
      .slice(0, 3)
      .map(({ candidate }) => ({
        title: candidate.data.title,
        slug: candidate.slug,
        description: candidate.data.description,
        pubDate: candidate.data.pubDate
      }));

    return {
      params: { slug: post.slug },
      props: {
        post,
        previousPost: previous ? ({ title: previous.data.title, slug: previous.slug } satisfies NavPost) : null,
        nextPost: next ? ({ title: next.data.title, slug: next.slug } satisfies NavPost) : null,
        relatedPosts
      }
    };
  });
}

type PageProps = {
  post: CollectionEntry<'blog'>;
  previousPost?: NavPost | null;
  nextPost?: NavPost | null;
  relatedPosts?: RelatedPost[];
};

const { post, previousPost, nextPost, relatedPosts = [] } = Astro.props as PageProps;
const { Content } = await post.render();
const readingTime = calculateReadingTime(post.body);
const heroImage = post.data.heroImage || extractFirstImage(post.body) || undefined;
---

<BlogPost
  {...post.data}
  heroImage={heroImage}
  notes={isNotePost(post)}
  slug={post.slug}
  readingTime={readingTime}
  previousPost={previousPost}
  nextPost={nextPost}
  relatedPosts={relatedPosts}
>
  <Content />
</BlogPost>
