---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }

    return post;
  });

const tagCount = new Set(allPosts.flatMap((post) => post.data.tags || [])).size;
const featuredPost = allPosts.find((post) => post.data.pinned) || allPosts[0];
const recentPosts = allPosts.slice(0, 8);

const dateFormatter = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});

const heroDots = [
  { x: '8%', y: '18%', size: 9, duration: '4.4s', delay: '0s', tone: 'soft' },
  { x: '14%', y: '72%', size: 13, duration: '5.2s', delay: '0.4s', tone: 'strong' },
  { x: '27%', y: '34%', size: 10, duration: '4.8s', delay: '0.8s', tone: 'soft' },
  { x: '34%', y: '62%', size: 8, duration: '4.3s', delay: '0.2s', tone: 'strong' },
  { x: '52%', y: '22%', size: 11, duration: '5.4s', delay: '1s', tone: 'soft' },
  { x: '60%', y: '66%', size: 15, duration: '6.1s', delay: '0.5s', tone: 'strong' },
  { x: '71%', y: '40%', size: 9, duration: '4.6s', delay: '1.1s', tone: 'soft' },
  { x: '84%', y: '19%', size: 12, duration: '5.8s', delay: '0.3s', tone: 'strong' },
  { x: '91%', y: '61%', size: 9, duration: '4.5s', delay: '0.9s', tone: 'soft' }
];
---

<BaseLayout title="Nomi | 한만욱의 블로그" description="자바스크립트를 극한으로 써보기 위해 노력하는 과정을 기록중이에요">
  <Header />

  <main class="homepage pt-[calc(var(--header-height)+1.2rem)] pb-[2.2rem] md:pt-[calc(var(--header-height)+1.9rem)] md:pb-12">
    <section class="container mb-7">
      <div class="hero paper-panel">
        <div class="hero-copy">
          <p class="hero-label">nomi</p>
          <h1>한만욱의 블로그</h1>
          <p>자바스크립트를 극한으로 써보기 위해 노력하는 과정을 기록중이에요</p>
          <div class="hero-actions">
            <a href="/posts">글 보러가기</a>
            <a href="/saju">사주 리포트</a>
          </div>
          <p class="hero-meta">
            <span>{allPosts.length} posts</span>
            <span>{tagCount} tags</span>
          </p>
        </div>
        <div class="hero-visual" aria-hidden="true">
          {heroDots.map((dot) => (
            <span
              class:list={['hero-dot', { strong: dot.tone === 'strong' }]}
              style={`--x:${dot.x}; --y:${dot.y}; --size:${dot.size}px; --duration:${dot.duration}; --delay:${dot.delay};`}
            />
          ))}
        </div>
      </div>
    </section>

    {featuredPost && (
      <section class="container mt-5 reveal" data-reveal>
        <div class="paper-panel section-head">
          <h2>금주의 헤드라인</h2>
        </div>
        <a href={`/blog/${featuredPost.slug}`} class="paper-panel featured">
          <div class="featured-copy">
            <p class="featured-tag">TOP STORY</p>
            <h3>{featuredPost.data.title}</h3>
            {featuredPost.data.description && <p class="featured-desc">{featuredPost.data.description}</p>}
            <p class="featured-meta">
              {dateFormatter.format(featuredPost.data.pubDate)}
              {featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
                <>
                  <span> · </span>
                  <span>{featuredPost.data.tags.slice(0, 2).join(', ')}</span>
                </>
              )}
            </p>
          </div>
          <div class="featured-image">
            <img src={featuredPost.data.heroImage || '/images/placeholder.svg'} alt={featuredPost.data.title} loading="lazy" />
          </div>
        </a>
      </section>
    )}

    <section class="container mt-5 reveal" data-reveal>
      <div class="paper-panel section-head section-head-split">
        <h2>최신 기사</h2>
        <a href="/posts">전체 보기</a>
      </div>

      <ul class="latest-list paper-panel">
        {recentPosts.map((post) => (
          <li class="latest-row">
            <a href={`/blog/${post.slug}`} class="latest-link">
              <time>{dateFormatter.format(post.data.pubDate)}</time>
              <div>
                <h3>{post.data.title}</h3>
                {post.data.description && <p>{post.data.description}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const revealNodes = Array.from(document.querySelectorAll('[data-reveal]'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduceMotion) {
    revealNodes.forEach((node) => node.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const node = entry.target;
          if (entry.isIntersecting) {
            node.classList.add('is-visible');
            node.classList.remove('is-past');
          } else if (entry.boundingClientRect.top < 0) {
            node.classList.add('is-past');
            node.classList.remove('is-visible');
          } else {
            node.classList.remove('is-visible', 'is-past');
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -12% 0px' }
    );

    revealNodes.forEach((node) => observer.observe(node));
  }
</script>

<style>
  .hero {
    display: grid;
    gap: 1.1rem;
    grid-template-columns: 1.2fr 1fr;
    padding: 1rem;
    min-height: 270px;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    text-align: left;
    gap: 0.3rem;
  }

  .hero-label {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    color: var(--text-tertiary);
  }

  .hero-copy h1 {
    font-family: var(--font-serif);
    font-size: clamp(1.85rem, 4.8vw, 2.8rem);
    line-height: 1.2;
    color: var(--text-primary);
  }

  .hero-copy p {
    font-size: 0.93rem;
    color: var(--text-secondary);
    max-width: 36ch;
  }

  .hero-actions {
    margin-top: 0.35rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-primary);
    padding: 0.33rem 0.58rem;
    font-size: 0.78rem;
    color: var(--text-secondary);
    background: rgba(255, 255, 255, 0.16);
    transition: border-color 0.16s ease, color 0.16s ease;
  }

  .hero-actions a:hover {
    color: var(--text-primary);
    border-color: var(--border-secondary);
  }

  .hero-meta {
    margin-top: 0.25rem;
    font-size: 0.74rem;
    color: var(--text-tertiary);
    display: flex;
    gap: 0.6rem;
  }

  .hero-visual {
    position: relative;
    min-height: 210px;
    border: 1px solid var(--divider);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.18) 0%, rgba(255, 255, 255, 0.05) 100%);
    overflow: hidden;
  }

  .hero-dot {
    position: absolute;
    left: var(--x);
    top: var(--y);
    width: var(--size);
    height: var(--size);
    border-radius: 999px;
    background: var(--dot-soft);
    opacity: 0.66;
    animation: dot-float var(--duration) ease-in-out var(--delay) infinite;
  }

  .hero-dot.strong {
    background: var(--dot-strong);
    opacity: 0.76;
  }

  .section-head {
    display: flex;
    align-items: center;
    padding: 0.48rem 0.75rem;
    margin-bottom: 0.62rem;
  }

  .section-head h2 {
    font-size: 1.02rem;
    line-height: 1.3;
  }

  .section-head-split {
    justify-content: space-between;
  }

  .section-head-split a {
    font-size: 0.76rem;
    color: var(--text-secondary);
  }

  .section-head-split a:hover {
    color: var(--text-primary);
  }

  .featured {
    display: grid;
    grid-template-columns: 1fr 245px;
    gap: 0.75rem;
    padding: 0.75rem;
    transition: border-color 0.16s ease;
  }

  .featured:hover {
    border-color: var(--border-secondary);
  }

  .featured-tag {
    font-size: 0.72rem;
    letter-spacing: 0.07em;
    color: #5a5f77;
    margin-bottom: 0.2rem;
  }

  .featured h3 {
    font-size: 1.2rem;
    line-height: 1.34;
    margin-bottom: 0.3rem;
  }

  .featured-desc {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.58;
    margin-bottom: 0.42rem;
  }

  .featured-meta {
    font-size: 0.76rem;
    color: var(--text-tertiary);
  }

  .featured-image {
    border: 1px solid var(--divider);
    background: #c4c0b5;
    min-height: 155px;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .latest-list {
    list-style: none;
  }

  .latest-row + .latest-row {
    border-top: 1px solid var(--divider);
  }

  .latest-link {
    display: grid;
    gap: 0.35rem;
    grid-template-columns: 122px 1fr;
    align-items: start;
    padding: 0.78rem 0.75rem;
  }

  .latest-link time {
    font-size: 0.74rem;
    color: var(--text-tertiary);
    padding-top: 0.25rem;
  }

  .latest-link h3 {
    font-size: 1rem;
    line-height: 1.45;
  }

  .latest-link p {
    margin-top: 0.22rem;
    font-size: 0.86rem;
    line-height: 1.58;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 860px) {
    .hero {
      grid-template-columns: 1fr;
    }

    .featured {
      grid-template-columns: 1fr;
    }

    .featured-image {
      min-height: 180px;
    }

    .latest-link {
      grid-template-columns: 1fr;
      gap: 0.18rem;
    }
  }
</style>
