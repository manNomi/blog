---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }

    return post;
  });

const pinnedPosts = allPosts.filter((post) => post.data.pinned);
const featuredPosts = pinnedPosts.slice(0, 4);
const siteURL = Astro.site || Astro.url.origin;
const homeURL = new URL('/', siteURL).href;
const ogImageURL = new URL('/og-image.png', siteURL).href;
const seoTitle = '한만욱의 이모저모 | Nomi Journal';
const seoDescription =
  '프론트엔드 개발자 한만욱이 웹 성능, 번들링, 웹뷰, 협업, 제품 개발 과정에서 배운 내용을 기록하는 기술 블로그입니다.';
const seoKeywords = ['프론트엔드', '웹 성능', 'React', 'Astro', '웹뷰', '개발 블로그', '한만욱'];
const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${homeURL}#website`,
      url: homeURL,
      name: 'Nomi Journal',
      inLanguage: 'ko-KR',
      description: seoDescription,
      publisher: {
        '@id': `${homeURL}#person`
      }
    },
    {
      '@type': 'Person',
      '@id': `${homeURL}#person`,
      name: '한만욱',
      url: homeURL,
      sameAs: ['https://github.com/manNomi']
    },
    {
      '@type': 'Blog',
      '@id': `${homeURL}#blog`,
      url: homeURL,
      name: '한만욱의 이모저모',
      description: seoDescription,
      image: ogImageURL,
      inLanguage: 'ko-KR',
      author: {
        '@id': `${homeURL}#person`
      }
    }
  ]
};

const valueCards = [
  {
    title: 'Rapid Setup',
    description: 'Get projects running quickly with a calm, dependable baseline.'
  },
  {
    title: 'Editorial Flow',
    description: 'Structure content with restrained rhythm and clear visual hierarchy.'
  },
  {
    title: 'Measured Contrast',
    description: 'Off-white surfaces keep the interface quiet while preserving depth.'
  },
  {
    title: 'Quiet Components',
    description: 'Minimal cards support scanning without introducing visual noise.'
  },
  {
    title: 'Balanced Spacing',
    description: 'Consistent gaps and padding create a composed editorial cadence.'
  },
  {
    title: 'Soft Elevation',
    description: 'A subtle shadow adds depth while maintaining a calm visual tone.'
  }
];

const toCategory = (tags: string[] | undefined) => {
  if (!tags || tags.length === 0) return 'Editorial';
  return tags[0].toUpperCase();
};
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  image="/og-image.png"
  imageAlt="한만욱의 이모저모 Nomi Journal"
  canonicalURL="/"
  jsonLd={homeJsonLd}
>
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="grid animate-fade-up gap-10 md:gap-14 lg:gap-[70px]">
        <section class="page-card grid gap-10 px-4 py-6 md:gap-12 md:px-8 md:py-9">
          <div class="grid justify-items-center gap-6 text-center">
            <h1 class="max-w-[860px] text-balance text-[42px] font-semibold leading-[1.02] tracking-[-0.03em] text-zinc-900 sm:text-[56px] md:text-[72px] lg:text-[86px]">
              한만욱의 이모저모
            </h1>
            <p class="max-w-[760px] text-balance text-[15px] leading-[1.55] text-zinc-600 md:text-lg">
              프론트엔드 개발과 일상에 대해서 이야기를 적고 있습니다.
            </p>
            <a href="/posts" class="btn-pill-dark">View Selected Work</a>
          </div>

          <section class="relative overflow-hidden rounded-card border border-line bg-soft px-4 py-4 text-left md:px-5 md:py-5" aria-label="처음 방문자를 위한 사주 안내">
            <span class="pointer-events-none absolute right-5 top-5 h-2 w-2 animate-float-dot rounded-full bg-[#c3b8a8]" aria-hidden="true"></span>
            <span class="pointer-events-none absolute right-9 top-8 h-1.5 w-1.5 animate-soft-pulse rounded-full bg-zinc-400" aria-hidden="true"></span>

            <p class="kicker">First Visit</p>
            <h2 class="mt-1.5 text-balance text-[22px] font-semibold leading-[1.28] tracking-[-0.02em] text-zinc-900 md:text-[26px]">
              처음 오셨나요? 사주 연애운도 함께 볼 수 있어요.
            </h2>
            <p class="mt-2 text-[14px] leading-[1.58] text-zinc-600 md:text-[15px]">
              간단한 입력 후 비동기로 분석되며, 결과는 전자우편(이메일)로 보내드립니다.
            </p>

            <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-center">
              <a href="/saju" class="btn-pill-dark w-full sm:w-auto">사주 보러가기</a>
              <a href="/privacy" class="btn-pill-soft w-full sm:w-auto">처리방침 보기</a>
            </div>
          </section>

          <div class="grid gap-5">
            <h2 class="text-[28px] font-semibold leading-tight tracking-[-0.02em] text-zinc-900 md:text-[30px]">Pinned</h2>

            {featuredPosts.length > 0 ? (
              <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4 lg:gap-5">
                {featuredPosts.map((post, index) => (
                  <a
                    href={`/blog/${post.slug}`}
                    class="group grid gap-3 rounded-card border border-line bg-elevated p-4 shadow-soft transition duration-200 hover:-translate-y-0.5 hover:border-zinc-400"
                    style={`animation-delay:${index * 60}ms`}
                  >
                    <img
                      src={post.data.heroImage || '/images/editorial-fallback.svg'}
                      alt={post.data.title}
                      loading="lazy"
                      class="h-[150px] w-full rounded-md border border-zinc-200 object-cover"
                    />
                    <p class="text-[11px] uppercase leading-none tracking-[0.05em] text-zinc-500">{toCategory(post.data.tags)}</p>
                    <h3 class="line-clamp-2 text-[20px] font-semibold leading-[1.2] text-zinc-900">{post.data.title}</h3>
                    <p class="line-clamp-2 text-sm leading-[1.5] text-zinc-600">{post.data.description || 'Open article'}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div class="grid min-h-[132px] place-items-center rounded-card border border-line bg-elevated px-5 py-6 text-center text-[15px] text-zinc-500 shadow-soft">
                고정된 글을 준비 중입니다.
              </div>
            )}
          </div>
        </section>

        <section class="grid justify-items-center gap-5 text-center md:gap-7">
          <div class="h-px w-24 bg-zinc-300"></div>
          <p class="max-w-[840px] text-balance text-[28px] font-semibold leading-[1.32] tracking-[-0.02em] text-zinc-900 sm:text-[34px] md:text-[44px] lg:text-[52px]">
            Consider the postage stamp: its usefulness consists in the ability to stick to one thing till it gets there.
            <br />
            <span class="mt-3 inline-block text-[0.78em] font-medium italic tracking-[-0.01em]">- Josh Billings -</span>
          </p>
          <div class="h-px w-24 bg-zinc-300"></div>
        </section>

        <section class="grid grid-cols-1 gap-4 px-0 md:grid-cols-2 md:gap-5 lg:grid-cols-3 lg:gap-6 lg:px-6" aria-label="Editorial principles">
          {valueCards.map((card, index) => (
            <article
              class="rounded-card border border-line bg-[#fcfbf8] p-5 shadow-card transition duration-200 hover:-translate-y-0.5"
              style={`animation-delay:${index * 55}ms`}
            >
              <span class="inline-block h-2 w-2 animate-float-dot rounded-full bg-[#c3b8a8]" aria-hidden="true"></span>
              <h3 class="mt-3 text-[18px] font-medium leading-tight text-[#2b2a28]">{card.title}</h3>
              <p class="mt-2.5 text-[14px] leading-[1.55] text-[#6d675f]">{card.description}</p>
            </article>
          ))}
        </section>

        <section class="grid justify-items-center gap-6 px-0 py-8 text-center md:gap-8 md:py-14">
          <span class="kicker">Highlight</span>
          <h2 class="max-w-[860px] text-balance text-[38px] font-semibold leading-[1.08] tracking-[-0.02em] text-zinc-900 sm:text-[44px] md:text-[56px] lg:text-[64px]">
            Building Interfaces
            <br />
            With Notion API
          </h2>
          <p class="max-w-[740px] text-balance text-[15px] leading-[1.6] text-zinc-700 md:text-base">Quiet Sys, Quiet deploy.</p>

          <div class="flex w-full flex-col items-center gap-3 sm:w-auto sm:flex-row">
            <a href="/posts" class="btn-pill-dark w-full sm:w-auto">Read Selected Works</a>
            <a href="/tags" class="btn-pill-soft w-full sm:w-auto">View Archive</a>
          </div>

          <div class="h-px w-full bg-zinc-200"></div>
          <p class="text-[12px] text-zinc-500">Astro · Tailwind CSS · Editorial Layout · Content Systems</p>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
