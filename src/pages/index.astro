---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }

    return post;
  });

const pinnedPosts = allPosts.filter((post) => post.data.pinned);
const featuredPosts = pinnedPosts.slice(0, 4);
const recentPosts = allPosts.filter((post) => !post.data.pinned);
const RECENT_POSTS_INITIAL_COUNT = 6;
const RECENT_POSTS_PAGE_SIZE = 4;
const siteURL = Astro.site || Astro.url.origin;
const homeURL = new URL('/', siteURL).href;
const ogImageURL = new URL('/og-image.png', siteURL).href;
const seoTitle = '한만욱의 이모저모';
const seoDescription = '프론트엔드 개발과 일상에 대해서 이야기를 적고 있습니다.';
const seoKeywords = ['프론트엔드', '웹 성능', 'React', 'Astro', '웹뷰', '개발 블로그', '한만욱'];
const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${homeURL}#website`,
      url: homeURL,
      name: 'Nomi Journal',
      inLanguage: 'ko-KR',
      description: seoDescription,
      publisher: {
        '@id': `${homeURL}#person`
      }
    },
    {
      '@type': 'Person',
      '@id': `${homeURL}#person`,
      name: '한만욱',
      url: homeURL,
      sameAs: ['https://github.com/manNomi']
    },
    {
      '@type': 'Blog',
      '@id': `${homeURL}#blog`,
      url: homeURL,
      name: '한만욱의 이모저모',
      description: seoDescription,
      image: ogImageURL,
      inLanguage: 'ko-KR',
      author: {
        '@id': `${homeURL}#person`
      }
    }
  ]
};

const toCategory = (tags: string[] | undefined) => {
  if (!tags || tags.length === 0) return 'Editorial';
  return tags[0].toUpperCase();
};

const recentDateFormatter = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric'
});

const formatRecentDate = (date: Date) => recentDateFormatter.format(date);
const toRecentCategory = (tags: string[] | undefined) => tags?.[0] || '에세이';
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  keywords={seoKeywords}
  image="/og/kakao-share.png"
  imageAlt="한만욱의 이모저모 Nomi Journal"
  canonicalURL="/"
  jsonLd={homeJsonLd}
>
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="grid animate-fade-up gap-10 md:gap-14 lg:gap-[70px]">
        <section class="page-card grid gap-10 overflow-hidden px-4 py-6 md:gap-12 md:px-8 md:py-9">
          <div class="grid justify-items-center gap-6 text-center">
            <h1 class="max-w-[860px] text-balance text-[42px] font-semibold leading-[1.02] tracking-[-0.03em] text-zinc-900 sm:text-[56px] md:text-[72px] lg:text-[86px]">
              한만욱의 이모저모
            </h1>
            <p class="max-w-[760px] text-balance text-[15px] leading-[1.55] text-zinc-600 md:text-lg">
              프론트엔드 개발과 일상에 대해서 이야기를 적고 있습니다.
            </p>
            <a
              href="/posts"
              class="group flex w-full max-w-[860px] items-center justify-between gap-4 rounded-card border border-zinc-900 bg-zinc-900 px-4 py-3 text-left text-white shadow-lift transition duration-200 hover:-translate-y-0.5 hover:bg-zinc-800 md:px-5 md:py-4"
              aria-label="블로그 포스팅 전체 보기"
            >
              <span class="min-w-0">
                <span class="block text-[11px] font-medium uppercase leading-none tracking-[0.14em] text-zinc-400">Blog Posts</span>
                <span class="mt-1.5 block text-[17px] font-semibold leading-[1.25] tracking-[-0.01em] md:text-[20px]">블로그 포스팅 전체 보기</span>
              </span>
              <span class="theme-inverse inline-flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-white text-[18px] font-semibold text-zinc-900 transition duration-200 group-hover:translate-x-0.5" aria-hidden="true">
                →
              </span>
            </a>
          </div>

          <section class="relative overflow-hidden rounded-card border border-line bg-soft px-4 py-4 text-left md:px-5 md:py-5" aria-label="처음 방문자를 위한 사주 안내">
            <span class="pointer-events-none absolute right-5 top-5 h-2 w-2 animate-float-dot rounded-full bg-[#c3b8a8]" aria-hidden="true"></span>
            <span class="pointer-events-none absolute right-9 top-8 h-1.5 w-1.5 animate-soft-pulse rounded-full bg-zinc-400" aria-hidden="true"></span>

            <p class="kicker">First Visit</p>
            <h2 class="mt-1.5 text-balance text-[22px] font-semibold leading-[1.28] tracking-[-0.02em] text-zinc-900 md:text-[26px]">
              사주로 연애와 시험운을 볼수 있어요 !
            </h2>
            <p class="mt-2 text-[14px] leading-[1.58] text-zinc-600 md:text-[15px]">
              간단한 입력후 전자우편 (이메일)로 보내드립니다!!
            </p>

            <div class="mt-3 flex flex-col gap-2 sm:flex-row sm:items-center">
              <a href="/saju" class="btn-pill-dark w-full sm:w-auto">사주 보러가기</a>
              <a href="/privacy" class="btn-pill-soft w-full sm:w-auto">처리방침 보기</a>
            </div>
          </section>

          <div class="grid gap-5">
            <h2 class="text-[28px] font-semibold leading-tight tracking-[-0.02em] text-zinc-900 md:text-[30px]">Pinned</h2>

            {featuredPosts.length > 0 ? (
              <div class="grid grid-cols-1 gap-4 md:grid-cols-2 lg:grid-cols-4 lg:gap-5">
                {featuredPosts.map((post, index) => (
                  <a
                    href={`/blog/${post.slug}`}
                    class="group grid gap-3 rounded-card border border-line bg-elevated p-4 shadow-lift transition duration-200 hover:-translate-y-0.5 hover:border-zinc-400"
                    style={`animation-delay:${index * 60}ms`}
                  >
                    <img
                      src={post.data.heroImage || '/images/editorial-fallback.svg'}
                      alt={post.data.title}
                      loading="lazy"
                      class="h-[150px] w-full rounded-md border border-zinc-200 object-cover"
                    />
                    <p class="text-[11px] uppercase leading-none tracking-[0.05em] text-zinc-500">{toCategory(post.data.tags)}</p>
                    <h3 class="line-clamp-2 text-[20px] font-semibold leading-[1.2] text-zinc-900">{post.data.title}</h3>
                    <p class="line-clamp-2 text-sm leading-[1.5] text-zinc-600">{post.data.description || 'Open article'}</p>
                  </a>
                ))}
              </div>
            ) : (
              <div class="grid min-h-[132px] place-items-center rounded-card border border-line bg-elevated px-5 py-6 text-center text-[15px] text-zinc-500 shadow-lift">
                고정된 글을 준비 중입니다.
              </div>
            )}
          </div>

          <section
            class="-mx-4 -mb-6 border-t border-line bg-elevated px-4 py-8 text-zinc-900 md:-mx-8 md:-mb-9 md:px-8 md:py-10 dark:border-white/10 dark:bg-zinc-950 dark:text-zinc-100"
            aria-labelledby="recent-posts-title"
            data-recent-posts-root
            data-initial-count={RECENT_POSTS_INITIAL_COUNT}
            data-page-size={RECENT_POSTS_PAGE_SIZE}
          >
            <div class="mb-7 flex items-center justify-between gap-4 md:mb-9">
              <h2 id="recent-posts-title" class="text-[28px] font-semibold leading-none tracking-[-0.02em] md:text-[34px]">Recent Posts</h2>
              <a href="/posts" class="shrink-0 text-[15px] font-medium text-zinc-500 transition hover:text-zinc-900 md:text-[17px] dark:text-zinc-400 dark:hover:text-white">View all →</a>
            </div>

            {recentPosts.length > 0 ? (
              <div class="grid" data-recent-posts-list>
                {recentPosts.map((post, index) => (
                  <a
                    href={`/blog/${post.slug}`}
                    class={`group grid gap-5 border-b border-line py-7 first:pt-0 last:pb-0 md:grid-cols-[minmax(0,1fr)_220px] md:items-center md:gap-8 dark:border-white/15 ${index >= RECENT_POSTS_INITIAL_COUNT ? 'hidden' : ''}`}
                    data-recent-post-item
                  >
                    <div class="min-w-0">
                      <p class="text-[14px] font-medium text-zinc-500 md:text-[15px] dark:text-zinc-400">{toRecentCategory(post.data.tags)}</p>
                      <h3 class="mt-4 text-balance text-[25px] font-semibold leading-[1.22] tracking-[-0.02em] text-zinc-900 transition group-hover:text-zinc-600 md:text-[32px] dark:text-zinc-100 dark:group-hover:text-white">
                        {post.data.title}
                      </h3>
                      <p class="mt-3 max-w-[760px] text-[15px] leading-[1.58] text-zinc-600 md:text-[17px] dark:text-zinc-400">
                        {post.data.description || '글을 읽어보세요.'}
                      </p>
                      <time datetime={post.data.pubDate.toISOString()} class="mt-8 block text-[15px] font-medium text-zinc-500 md:text-[17px]">
                        {formatRecentDate(post.data.pubDate)}
                      </time>
                    </div>
                    <img
                      src={post.data.heroImage || '/images/editorial-fallback.svg'}
                      alt={post.data.title}
                      loading="lazy"
                      class="h-[150px] w-full rounded-md border border-line object-cover opacity-90 transition group-hover:opacity-100 md:h-[118px] md:w-[220px] dark:border-white/10"
                    />
                  </a>
                ))}
                {recentPosts.length > RECENT_POSTS_INITIAL_COUNT && (
                  <div class="mt-7 grid place-items-center border border-line bg-soft px-4 py-4 text-center text-[14px] text-zinc-500 dark:border-white/10 dark:bg-white/[0.03]" data-recent-posts-sentinel>
                    스크롤하면 글을 더 불러옵니다.
                  </div>
                )}
              </div>
            ) : (
              <div class="grid min-h-[132px] place-items-center border-y border-line px-5 py-8 text-center text-[15px] text-zinc-500 dark:border-white/15 dark:text-zinc-400">
                최근 글을 준비 중입니다.
              </div>
            )}
          </section>
        </section>

      </div>
    </section>
  </main>

  <Footer />

  <script>
    const recentPostsRoot = document.querySelector('[data-recent-posts-root]');
    const recentPostItems = Array.from(recentPostsRoot?.querySelectorAll('[data-recent-post-item]') ?? []);
    const recentPostSentinel = recentPostsRoot?.querySelector('[data-recent-posts-sentinel]');
    const initialRecentPostCount = Number(recentPostsRoot?.getAttribute('data-initial-count') ?? 6);
    const recentPostsPageSize = Number(recentPostsRoot?.getAttribute('data-page-size') ?? 4);

    if (recentPostItems.length === 0 || !recentPostSentinel) {
      recentPostSentinel?.setAttribute('hidden', '');
    } else {
      let visibleRecentPostCount = initialRecentPostCount;
      let recentPostObserver: IntersectionObserver | undefined;

      const revealRecentPosts = () => {
        const nextVisibleCount = Math.min(visibleRecentPostCount + recentPostsPageSize, recentPostItems.length);

        for (let index = visibleRecentPostCount; index < nextVisibleCount; index += 1) {
          recentPostItems[index]?.classList.remove('hidden');
        }

        visibleRecentPostCount = nextVisibleCount;

        if (visibleRecentPostCount >= recentPostItems.length) {
          recentPostSentinel.setAttribute('hidden', '');
          recentPostObserver?.disconnect();
        }
      };

      if ('IntersectionObserver' in window) {
        recentPostObserver = new IntersectionObserver(
          (entries) => {
            if (entries.some((entry) => entry.isIntersecting)) {
              revealRecentPosts();
            }
          },
          { rootMargin: '360px 0px' }
        );

        recentPostObserver.observe(recentPostSentinel);
      } else {
        recentPostItems.forEach((item) => item.classList.remove('hidden'));
        recentPostSentinel.setAttribute('hidden', '');
      }
    }
  </script>
</BaseLayout>
