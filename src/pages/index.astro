---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { portfolioProfile, portfolioProjects } from '../data/portfolio';
import { extractFirstImage } from '../utils/extractFirstImage';
import { getArticlePosts } from '../utils/postFilters';

const posts = getArticlePosts(await getCollection('blog'));
const featuredPost = posts.find((post) => post.data.pinned) || posts[0];
const restPosts = posts.filter((post) => post.slug !== featuredPost?.slug);
const defaultPostSlugs = new Set(restPosts.slice(0, 8).map((post) => post.slug));
const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort((a, b) => a.localeCompare(b, 'ko-KR'));
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = posts.filter((post) => (post.data.tags || []).includes(tag)).length;
  return acc;
}, {} as Record<string, number>);

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(date);

const fallbackPostImage = '/images/placeholder.svg';
const getPostImage = (post: (typeof posts)[number]) => post.data.heroImage || extractFirstImage(post.body) || fallbackPostImage;
---

<BaseLayout title="한만욱 · Frontend Developer" description={portfolioProfile.intro}>
  <Header />

  <main class="site-main">
    <div class="wrap">
      <section class="rise pt-[clamp(44px,7vw,84px)] pb-[clamp(28px,4vw,48px)]">
        <div class="mb-[34px] flex flex-wrap items-end justify-between gap-5">
          <h1 class="m-0 max-w-[22ch] text-[clamp(1.6rem,3.4vw,2.3rem)] font-bold leading-[1.25] tracking-[-0.035em]" style="color: var(--text);">
            {portfolioProfile.headline}
          </h1>

          <div class="focus-row max-w-[280px] justify-end">
            {portfolioProfile.focus.map((item) => <span class="focus-chip">{item}</span>)}
          </div>
        </div>

        {featuredPost && (
          <a href={`/blog/${featuredPost.slug}`} class="feat-card">
            <img
              src={getPostImage(featuredPost)}
              alt={`${featuredPost.data.title} 대표 이미지`}
              class="featured-image"
              loading="eager"
              decoding="async"
            />
            <div class="flex flex-col justify-center gap-4 p-[clamp(26px,3vw,42px)]">
              <div class="flex flex-wrap items-center gap-2">
                <span class="pill h-6 text-[0.64rem]" style="color: var(--text); border-color: var(--border-strong);">FEATURED POST</span>
                <span class="mono">{formatDate(featuredPost.data.pubDate)}</span>
              </div>
              <h2 class="m-0 text-[clamp(1.5rem,2.6vw,2.1rem)] font-bold leading-[1.28] tracking-[-0.03em]" style="color: var(--text);">
                {featuredPost.data.title}
              </h2>
              {featuredPost.data.description && <p class="m-0 text-base leading-[1.65]" style="color: var(--text-dim);">{featuredPost.data.description}</p>}
              <div class="mt-1 flex flex-wrap gap-2">
                {(featuredPost.data.tags || []).slice(0, 3).map((tag) => <span class="mono text-[0.68rem]">#{tag}</span>)}
              </div>
            </div>
          </a>
        )}
      </section>

      <hr class="rule" />

      <section class="pt-10">
        <div class="section-head">
          <div>
            <div class="eyebrow mb-2">All writing · {posts.length}</div>
            <h2 class="section-title">글</h2>
          </div>
          <a href="/tags" class="mono whitespace-nowrap" style="color: var(--text-dim);">태그 전체 →</a>
        </div>

        <div class="my-5 flex flex-wrap gap-2" data-home-tag-filter>
          <button type="button" class="pill" data-home-tag="all" data-active="true" aria-pressed="true">전체 <span class="opacity-60">{posts.length}</span></button>
          {allTags.slice(0, 10).map((tag) => (
            <button type="button" class="pill" data-home-tag={tag} aria-pressed="false">{tag} <span class="opacity-60">{tagCounts[tag]}</span></button>
          ))}
        </div>

        <div class="grid-2 grid gap-x-8 gap-y-[clamp(28px,3.5vw,52px)] md:grid-cols-2">
          {posts.map((post) => {
            const defaultVisible = defaultPostSlugs.has(post.slug);
            return (
            <a
              href={`/blog/${post.slug}`}
              class={`post-card ${defaultVisible ? '' : 'hidden'}`}
              data-home-post
              data-default-visible={defaultVisible ? 'true' : 'false'}
              data-tags={(post.data.tags || []).join('|')}
            >
              <img
                src={getPostImage(post)}
                alt={`${post.data.title} 썸네일`}
                class="post-card-image rounded-2xl"
                loading="lazy"
                decoding="async"
              />
              <div class="flex flex-col gap-2.5">
                <div class="flex flex-wrap items-center gap-2">
                  {post.data.pinned && <span class="pill h-[22px] text-[0.62rem]" style="color: var(--text); border-color: var(--border-strong);">FEATURED</span>}
                  <span class="mono">{formatDate(post.data.pubDate)}</span>
                </div>
                <h3 class="post-title m-0 text-[1.2rem] font-bold leading-[1.32] tracking-[-0.025em]">{post.data.title}</h3>
                {post.data.description && <p class="m-0 max-w-[44ch] text-[0.92rem] leading-[1.6]" style="color: var(--text-dim);">{post.data.description}</p>}
                <div class="mt-0.5 flex flex-wrap gap-1.5">
                  {(post.data.tags || []).slice(0, 3).map((tag) => <span class="mono text-[0.66rem]">#{tag}</span>)}
                </div>
              </div>
            </a>
            );
          })}
        </div>
        <p class="mono mt-8 hidden text-[0.78rem]" style="color: var(--text-faint);" data-home-filter-empty>
          선택한 태그의 글이 없습니다.
        </p>
      </section>

      <section class="pt-[84px]">
        <div class="section-head">
          <div>
            <div class="eyebrow mb-2">Case studies · {portfolioProjects.length}</div>
            <h2 class="section-title">프로젝트</h2>
          </div>
          <a href="/projects" class="mono whitespace-nowrap" style="color: var(--text-dim);">전체 보기 →</a>
        </div>

        <div class="mt-5">
          {portfolioProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
          <hr class="rule" />
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const homeTagButtons = Array.from(document.querySelectorAll<HTMLElement>('[data-home-tag]'));
  const homePostCards = Array.from(document.querySelectorAll<HTMLElement>('[data-home-post]'));
  const homeFilterEmpty = document.querySelector<HTMLElement>('[data-home-filter-empty]');

  const applyHomeTagFilter = (selectedTag: string) => {
    let visibleCount = 0;

    homeTagButtons.forEach((button) => {
      if (button.getAttribute('data-home-tag') === selectedTag) {
        button.setAttribute('data-active', 'true');
        button.setAttribute('aria-pressed', 'true');
      } else {
        button.removeAttribute('data-active');
        button.setAttribute('aria-pressed', 'false');
      }
    });

    homePostCards.forEach((card) => {
      const tags = (card.getAttribute('data-tags') || '').split('|').filter(Boolean);
      const defaultVisible = card.getAttribute('data-default-visible') === 'true';
      const shouldShow = selectedTag === 'all' ? defaultVisible : tags.includes(selectedTag);

      card.classList.toggle('hidden', !shouldShow);
      if (shouldShow) visibleCount += 1;
    });

    homeFilterEmpty?.classList.toggle('hidden', visibleCount > 0);
  };

  homeTagButtons.forEach((button) => {
    button.addEventListener('click', () => {
      applyHomeTagFilter(button.getAttribute('data-home-tag') || 'all');
    });
  });
</script>
