---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }

    return post;
  });

const tagCount = new Set(allPosts.flatMap((post) => post.data.tags || [])).size;
const featuredPost = allPosts.find((post) => post.data.pinned) || allPosts[0];
const recentPosts = allPosts.slice(0, 8);

const dateFormatter = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});

const paperDate = dateFormatter.format(new Date());
const frontNotes = recentPosts.slice(0, 6);
const opinionNotes = allPosts.slice(6, 12);
const mastPhoto = '/images/newspaper-press-room.png';

const headline = featuredPost?.data.title || '노미신문 기술 별호';
const dek =
  featuredPost?.data.description ||
  '누리집을 지새우며 마주본 그대 문제가 아니 풀릴지언정 기사와 함께하면 어떨지어니';
---

<BaseLayout title="노미 | 한만욱의 누리집" description="자바스크립트를 극진히 쓰고자 늘 힘쓰고 있사옵니다.">
  <Header />

  <main class="homepage pt-[calc(var(--header-height)+1.2rem)] pb-[2.2rem] md:pt-[calc(var(--header-height)+1.9rem)] md:pb-12">
    <section class="container mb-6 reveal" data-reveal>
      <article class="frontpage paper-panel">
        <div class="folio">
          <span>88</span>
          <p>노미신문 · {paperDate} · 기술 기록 별호</p>
          <span>93</span>
        </div>
        <div class="paper-rule" />

        <div class="lead-band">
          <div class="lead-copy">
            <h1 class="headline">
              <span>{headline}</span>
              <span class="headline-breaking">(속보)</span>
            </h1>
            <p class="subhead">{dek}</p>
          </div>

          <figure class="main-photo">
            <img src={mastPhoto} alt="유니폼 프레스 작업 현장" loading="lazy" />
            <figcaption>△ 선수 유니폼 찍어내는 마당을 갈무리한 기록이옵니다.</figcaption>
          </figure>
        </div>

        <div class="under-fold">
          <div class="story-col">
            <h2>오늘 엮은 글월</h2>
            <p>
              으뜸 지면은 그림 썸네일을 걷어내고, 머리글과 문장으로만 짜 놓았사옵니다. 눈길을 흩뜨리는 그림 칸을 덜어 내어, 옛
              신문마냥 글줄의 위계가 먼저 읽히도록 다듬었사옵니다.
            </p>
            <ul>
              {frontNotes.map((post) => (
                <li class="story-item">
                  <a href={`/blog/${post.slug}`}>
                    <strong>{post.data.title}</strong>
                    {post.data.description && <span>{post.data.description}</span>}
                  </a>
                </li>
              ))}
            </ul>
            <p class="meta-text">
              도합 {allPosts.length}편 기사 · 갈래말 {tagCount}벌 ·
              <a href="/posts"> 모든 기사 보기</a>
            </p>
          </div>

          <aside class="photo-col">
            <h3>사설 · 기별</h3>
            <ul>
              {opinionNotes.map((post) => (
                <li>
                  <a href={`/blog/${post.slug}`}>{post.data.title}</a>
                  <time>{dateFormatter.format(post.data.pubDate)}</time>
                </li>
              ))}
            </ul>
            <p>
              자바스크립트를 극진히 쓰고자 늘 힘쓰고 있사옵니다. 프론트엔드 일터에서 맞닥뜨린 난제를 풀어 간 자취를 부지런히 적어
              두고 있사옵니다.
            </p>
          </aside>
        </div>
      </article>
    </section>

    <section class="container mt-5 reveal" data-reveal>
      <div class="paper-panel section-head section-head-split">
        <h2>새 기사</h2>
        <a href="/posts">모두 보기</a>
      </div>

      <ul class="latest-list paper-panel">
        {recentPosts.map((post) => (
          <li class="latest-row">
            <a href={`/blog/${post.slug}`} class="latest-link">
              <time>{dateFormatter.format(post.data.pubDate)}</time>
              <div>
                <h3>{post.data.title}</h3>
                {post.data.description && <p>{post.data.description}</p>}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  const revealNodes = Array.from(document.querySelectorAll('[data-reveal]'));
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (reduceMotion) {
    revealNodes.forEach((node) => node.classList.add('is-visible'));
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const node = entry.target;
          if (entry.isIntersecting) {
            node.classList.add('is-visible');
            node.classList.remove('is-past');
          } else if (entry.boundingClientRect.top < 0) {
            node.classList.add('is-past');
            node.classList.remove('is-visible');
          } else {
            node.classList.remove('is-visible', 'is-past');
          }
        });
      },
      { threshold: 0.2, rootMargin: '0px 0px -12% 0px' }
    );

    revealNodes.forEach((node) => observer.observe(node));
  }
</script>

<style>
  .frontpage {
    position: relative;
    padding: 0.85rem;
    overflow: hidden;
  }

  .frontpage::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0.11;
    background-image: radial-gradient(circle at 1px 1px, rgba(20, 18, 15, 0.35) 0.75px, transparent 0.8px);
    background-size: 3px 3px;
  }

  .folio {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: 0.76rem;
    color: var(--text-tertiary);
    margin-bottom: 0.5rem;
  }

  .folio p {
    text-align: center;
    letter-spacing: 0.02em;
  }

  .headline {
    font-family: var(--font-serif);
    font-size: clamp(2.35rem, 7.4vw, 4.9rem);
    line-height: 1.06;
    letter-spacing: -0.03em;
    margin-top: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: 0.45rem;
  }

  .headline-breaking {
    font-family: var(--font-sans);
    font-size: clamp(0.82rem, 1.7vw, 1rem);
    line-height: 1;
    color: #6b2e1a;
    letter-spacing: 0.04em;
    padding-bottom: 0.28rem;
    white-space: nowrap;
  }

  .lead-band {
    margin-top: 0.56rem;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    gap: 0.62rem;
    align-items: stretch;
  }

  .lead-copy {
    border: 1px solid var(--divider);
    background: rgba(204, 200, 190, 0.45);
    padding: 0.5rem 0.56rem;
  }

  .subhead {
    margin-top: 0.44rem;
    font-size: 1.22rem;
    line-height: 1.36;
    font-weight: 700;
    border-top: 1px solid var(--divider);
    border-bottom: 1px solid var(--divider);
    padding: 0.45rem 0;
  }

  .main-photo {
    border: 1px solid var(--divider);
    background: #bdb8ae;
    margin-top: 0;
    height: 100%;
  }

  .main-photo img {
    width: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.1) saturate(0.35);
    mix-blend-mode: multiply;
  }

  .main-photo figcaption {
    font-size: 0.83rem;
    color: var(--text-secondary);
    border-top: 1px solid var(--divider);
    padding: 0.35rem 0.5rem;
    font-weight: 700;
  }

  .under-fold {
    margin-top: 0.65rem;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 0.62rem;
  }

  .story-col,
  .photo-col {
    border: 1px solid var(--divider);
    padding: 0.5rem;
    background: rgba(204, 200, 190, 0.65);
  }

  .story-col h2,
  .photo-col h3 {
    font-size: 1.2rem;
    margin-bottom: 0.3rem;
  }

  .story-col p,
  .photo-col p {
    font-size: 0.86rem;
    line-height: 1.56;
    color: var(--text-secondary);
  }

  .story-col ul {
    list-style: none;
    border-top: 1px solid var(--divider);
    margin-top: 0.46rem;
    padding-top: 0.35rem;
  }

  .story-col li + li,
  .photo-col li + li {
    margin-top: 0.26rem;
  }

  .story-item {
    border-bottom: 1px dotted rgba(95, 90, 80, 0.5);
    padding-bottom: 0.25rem;
  }

  .story-col a {
    font-size: 0.82rem;
    color: var(--text-primary);
    text-decoration: none;
    display: inline-flex;
    flex-direction: column;
    gap: 0.1rem;
    border-bottom: 1px solid transparent;
  }

  .story-col a:hover {
    border-bottom-color: var(--border-secondary);
  }

  .story-col a span {
    font-size: 0.74rem;
    color: var(--text-secondary);
    line-height: 1.42;
  }

  .meta-text {
    margin-top: 0.5rem;
    font-size: 0.76rem;
    color: var(--text-tertiary);
  }

  .photo-col ul {
    list-style: none;
    border-top: 1px solid var(--divider);
    margin-top: 0.35rem;
    padding-top: 0.35rem;
    margin-bottom: 0.42rem;
  }

  .photo-col li a {
    font-size: 0.8rem;
    color: var(--text-primary);
    text-decoration: none;
  }

  .photo-col li a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .photo-col li time {
    display: block;
    margin-top: 0.07rem;
    font-size: 0.72rem;
    color: var(--text-tertiary);
  }

  .section-head {
    display: flex;
    align-items: center;
    padding: 0.48rem 0.75rem;
    margin-bottom: 0.62rem;
  }

  .section-head h2 {
    font-size: 1.02rem;
    line-height: 1.3;
  }

  .section-head-split {
    justify-content: space-between;
  }

  .section-head-split a {
    font-size: 0.76rem;
    color: var(--text-secondary);
  }

  .section-head-split a:hover {
    color: var(--text-primary);
  }

  .latest-list {
    list-style: none;
  }

  .latest-row + .latest-row {
    border-top: 1px solid var(--divider);
  }

  .latest-link {
    display: grid;
    gap: 0.35rem;
    grid-template-columns: 122px 1fr;
    align-items: start;
    padding: 0.78rem 0.75rem;
  }

  .latest-link time {
    font-size: 0.74rem;
    color: var(--text-tertiary);
    padding-top: 0.25rem;
  }

  .latest-link h3 {
    font-size: 1rem;
    line-height: 1.45;
  }

  .latest-link p {
    margin-top: 0.22rem;
    font-size: 0.86rem;
    line-height: 1.58;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 920px) {
    .headline {
      font-size: clamp(1.9rem, 9vw, 3.2rem);
      line-height: 1.1;
    }

    .headline-breaking {
      font-size: 0.86rem;
      padding-bottom: 0.16rem;
    }

    .subhead {
      font-size: 1rem;
    }

    .lead-band {
      grid-template-columns: 1fr;
    }

    .under-fold {
      grid-template-columns: 1fr;
    }

    .latest-link {
      grid-template-columns: 1fr;
      gap: 0.18rem;
    }
  }
</style>
