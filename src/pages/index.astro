---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }

    return post;
  });

const tagCount = new Set(allPosts.flatMap((post) => post.data.tags || [])).size;
const featuredPost = allPosts.find((post) => post.data.pinned) || allPosts[0];
const recentPosts = allPosts.slice(0, 8);

const dateFormatter = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---

<BaseLayout title="Nomi | 한만욱의 블로그" description="프론트엔드 실무 경험과 문제 해결 과정을 기록합니다">
  <Header />

  <main class="main">
    <section class="intro container">
      <p class="eyebrow">nomi</p>
      <h1 class="intro-title">한만욱의 블로그</h1>
      <p class="intro-description">
        프론트엔드 실무에서 부딪힌 문제와 해결 과정을 기록합니다.
      </p>
      <div class="intro-links">
        <a href="/posts">전체 글 보기</a>
        <a href="/tags">태그 보기</a>
      </div>
      <div class="intro-stats">
        <span><strong>{allPosts.length}</strong> posts</span>
        <span><strong>{tagCount}</strong> tags</span>
      </div>
    </section>

    {featuredPost && (
      <section class="section container">
        <div class="section-header">
          <h2 class="section-title">Pinned</h2>
        </div>
        <a href={`/blog/${featuredPost.slug}`} class="featured-card">
          <div class="featured-content">
            <p class="featured-label">추천 글</p>
            <h3 class="featured-title">{featuredPost.data.title}</h3>
            {featuredPost.data.description && (
              <p class="featured-description">{featuredPost.data.description}</p>
            )}
            <p class="featured-meta">
              {dateFormatter.format(featuredPost.data.pubDate)}
              {featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
                <>
                  <span> · </span>
                  <span>{featuredPost.data.tags.slice(0, 2).join(', ')}</span>
                </>
              )}
            </p>
          </div>
          <div class="featured-image">
            <img
              src={featuredPost.data.heroImage || '/images/placeholder.svg'}
              alt={featuredPost.data.title}
              loading="lazy"
              class:list={[{ placeholder: !featuredPost.data.heroImage }]}
            />
          </div>
        </a>
      </section>
    )}

    <section class="section container">
      <div class="section-header">
        <h2 class="section-title">Latest Posts</h2>
        <a class="section-link" href="/posts">더 보기</a>
      </div>

      <ul class="post-list">
        {recentPosts.map((post) => (
          <li class="post-item">
            <a href={`/blog/${post.slug}`} class="post-link">
              <time class="post-date">{dateFormatter.format(post.data.pubDate)}</time>
              <div class="post-content">
                <h3 class="post-title">{post.data.title}</h3>
                {post.data.description && (
                  <p class="post-description">{post.data.description}</p>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .main {
    padding-top: calc(var(--header-height) + 2rem);
    padding-bottom: 3rem;
    background: linear-gradient(180deg, #fff 0%, #fbfbfa 100%);
  }

  .intro {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .eyebrow {
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 0.35rem;
  }

  .intro-title {
    font-size: clamp(2rem, 5vw, 2.9rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 0.55rem;
  }

  .intro-description {
    color: var(--text-secondary);
    font-size: 1rem;
    margin-bottom: 1rem;
  }

  .intro-links {
    display: flex;
    gap: 0.8rem;
    margin-bottom: 0.9rem;
  }

  .intro-links a {
    font-size: 0.85rem;
    color: var(--text-secondary);
    border-bottom: 1px solid transparent;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .intro-links a:hover {
    color: var(--text-primary);
    border-bottom-color: var(--border-secondary);
  }

  .intro-stats {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
  }

  .intro-stats strong {
    color: var(--text-primary);
    font-weight: 600;
  }

  .section {
    margin-top: 1.6rem;
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    color: var(--text-primary);
  }

  .section-link {
    font-size: 0.8rem;
    color: var(--text-secondary);
  }

  .section-link:hover {
    color: var(--text-primary);
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: 1rem;
    align-items: stretch;
    border: 1px solid var(--border-primary);
    border-radius: 10px;
    padding: 0.95rem;
    background: var(--bg-primary);
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .featured-card:hover {
    border-color: var(--border-secondary);
    box-shadow: var(--shadow-sm);
  }

  .featured-label {
    font-size: 0.72rem;
    color: var(--text-tertiary);
    margin-bottom: 0.35rem;
  }

  .featured-title {
    font-size: 1.15rem;
    margin-bottom: 0.35rem;
    line-height: 1.35;
    color: var(--text-primary);
  }

  .featured-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    margin-bottom: 0.55rem;
    line-height: 1.55;
  }

  .featured-meta {
    font-size: 0.76rem;
    color: var(--text-tertiary);
  }

  .featured-image {
    border: 1px solid var(--border-primary);
    border-radius: 8px;
    overflow: hidden;
    background: var(--bg-hover);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .featured-image img.placeholder {
    object-fit: contain;
    opacity: 0.5;
  }

  .post-list {
    list-style: none;
    border-top: 1px solid var(--border-primary);
  }

  .post-item {
    border-bottom: 1px solid var(--border-primary);
  }

  .post-link {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 1rem;
    align-items: start;
    padding: 0.95rem 0;
  }

  .post-date {
    font-size: 0.76rem;
    color: var(--text-tertiary);
    line-height: 1.5;
    padding-top: 0.2rem;
  }

  .post-title {
    font-size: 1rem;
    line-height: 1.45;
    margin-bottom: 0.28rem;
    color: var(--text-primary);
  }

  .post-description {
    font-size: 0.86rem;
    color: var(--text-secondary);
    line-height: 1.55;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 768px) {
    .main {
      padding-top: calc(var(--header-height) + 1.4rem);
      padding-bottom: 2.2rem;
    }

    .intro-links,
    .intro-stats {
      flex-wrap: wrap;
      gap: 0.6rem 0.9rem;
    }

    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-image {
      min-height: 170px;
    }

    .post-link {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
