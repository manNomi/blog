---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }

    return post;
  });

const tagCount = new Set(allPosts.flatMap((post) => post.data.tags || [])).size;
const featuredPost = allPosts.find((post) => post.data.pinned) || allPosts[0];
const recentPosts = allPosts.slice(0, 8);

const dateFormatter = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
});
---

<BaseLayout title="Nomi | 한만욱의 블로그" description="자바스크립트를 극한으로 써보기 위해 노력하는 과정을 기록중이에요">
  <Header />

  <main class="bg-[linear-gradient(180deg,#fff_0%,#fbfbfa_100%)] pt-[calc(var(--header-height)+1.4rem)] pb-[2.2rem] md:pt-[calc(var(--header-height)+2rem)] md:pb-12">
    <section class="container mb-8">
      <div class="max-w-[760px] text-left">
        <p class="mb-[0.35rem] text-[0.78rem] uppercase tracking-[0.12em] text-[var(--text-tertiary)]">nomi</p>
        <h1 class="mb-[0.55rem] leading-[1.2] tracking-[-0.02em] [font-size:clamp(2rem,5vw,2.9rem)]">한만욱의 블로그</h1>
        <p class="mb-4 text-base text-[var(--text-secondary)]">
          자바스크립트를 극한으로 써보기 위해 노력하는 과정을 기록중이에요
        </p>
        <div class="mb-[0.9rem] flex flex-wrap gap-x-[0.8rem] gap-y-[0.4rem]">
          <a
            href="/posts"
            class="border-b border-transparent text-[0.85rem] text-[var(--text-secondary)] transition-[color,border-color] duration-150 hover:border-[var(--border-secondary)] hover:text-[var(--text-primary)]"
          >
            전체 글 보기
          </a>
          <a
            href="/tags"
            class="border-b border-transparent text-[0.85rem] text-[var(--text-secondary)] transition-[color,border-color] duration-150 hover:border-[var(--border-secondary)] hover:text-[var(--text-primary)]"
          >
            태그 보기
          </a>
        </div>
        <div class="flex flex-wrap items-center gap-x-[0.9rem] gap-y-[0.35rem] text-[0.82rem] text-[var(--text-tertiary)]">
          <span><strong class="font-semibold text-[var(--text-primary)]">{allPosts.length}</strong> posts</span>
          <span><strong class="font-semibold text-[var(--text-primary)]">{tagCount}</strong> tags</span>
        </div>
      </div>
    </section>

    {featuredPost && (
      <section class="container mt-[1.6rem]">
        <div class="mb-3 flex items-baseline justify-between">
          <h2 class="text-base font-semibold tracking-[0.01em] text-[var(--text-primary)]">Pinned</h2>
        </div>
        <a
          href={`/blog/${featuredPost.slug}`}
          class="grid items-stretch gap-4 rounded-[10px] border border-[var(--border-primary)] bg-[var(--bg-primary)] p-[0.95rem] transition-[border-color,box-shadow] duration-150 hover:border-[var(--border-secondary)] hover:shadow-[var(--shadow-sm)] md:grid-cols-[1fr_220px]"
        >
          <div>
            <p class="mb-[0.35rem] text-[0.72rem] text-[var(--text-tertiary)]">추천 글</p>
            <h3 class="mb-[0.35rem] text-[1.15rem] leading-[1.35] text-[var(--text-primary)]">{featuredPost.data.title}</h3>
            {featuredPost.data.description && (
              <p class="mb-[0.55rem] text-[0.9rem] leading-[1.55] text-[var(--text-secondary)]">{featuredPost.data.description}</p>
            )}
            <p class="text-[0.76rem] text-[var(--text-tertiary)]">
              {dateFormatter.format(featuredPost.data.pubDate)}
              {featuredPost.data.tags && featuredPost.data.tags.length > 0 && (
                <>
                  <span> · </span>
                  <span>{featuredPost.data.tags.slice(0, 2).join(', ')}</span>
                </>
              )}
            </p>
          </div>
          <div class="flex min-h-[170px] items-center justify-center overflow-hidden rounded-lg border border-[var(--border-primary)] bg-[var(--bg-hover)] md:min-h-0">
            <img
              src={featuredPost.data.heroImage || '/images/placeholder.svg'}
              alt={featuredPost.data.title}
              loading="lazy"
              class:list={[
                'h-full w-full',
                {
                  'object-cover': !!featuredPost.data.heroImage,
                  'object-contain opacity-50': !featuredPost.data.heroImage
                }
              ]}
            />
          </div>
        </a>
      </section>
    )}

    <section class="container mt-[1.6rem]">
      <div class="mb-3 flex items-baseline justify-between">
        <h2 class="text-base font-semibold tracking-[0.01em] text-[var(--text-primary)]">Latest Posts</h2>
        <a class="text-[0.8rem] text-[var(--text-secondary)] hover:text-[var(--text-primary)]" href="/posts">더 보기</a>
      </div>

      <ul class="list-none border-t border-[var(--border-primary)]">
        {recentPosts.map((post) => (
          <li class="border-b border-[var(--border-primary)]">
            <a href={`/blog/${post.slug}`} class="grid gap-[0.25rem] py-[0.95rem] md:grid-cols-[120px_1fr] md:items-start md:gap-4">
              <time class="pt-[0.2rem] text-[0.76rem] leading-[1.5] text-[var(--text-tertiary)]">{dateFormatter.format(post.data.pubDate)}</time>
              <div>
                <h3 class="mb-[0.28rem] text-base leading-[1.45] text-[var(--text-primary)]">{post.data.title}</h3>
                {post.data.description && (
                  <p class="overflow-hidden text-[0.86rem] leading-[1.55] text-[var(--text-secondary)] [display:-webkit-box] [-webkit-box-orient:vertical] [-webkit-line-clamp:2]">{post.data.description}</p>
                )}
              </div>
            </a>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <Footer />
</BaseLayout>
