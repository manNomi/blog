---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="All Posts | Nomi Journal" description="Browse all published stories and concise engineering notes.">
  <Header />

  <main class="main-shell posts-page">
    <section class="container">
      <header class="posts-head">
        <p class="kicker">Archive</p>
        <h1>All Posts</h1>
        <p>{allPosts.length} published stories.</p>
      </header>

      <section class="posts-list" aria-label="All posts list">
        {allPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            pinned={post.data.pinned}
            variant="compact"
          />
        ))}
      </section>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  .posts-head {
    border-bottom: 1px solid var(--line-default);
    padding-bottom: 16px;
  }

  .posts-head h1 {
    margin-top: 8px;
    color: var(--text-strong);
    font-size: clamp(58px, 6vw, 78px);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  .posts-head p:last-child {
    margin-top: 10px;
    color: #575757;
    font-size: 30px;
    line-height: 1.3;
  }

  .posts-list {
    margin-top: 18px;
    display: grid;
    gap: 10px;
  }

  @media (max-width: 768px) {
    .posts-head {
      padding-bottom: 12px;
    }

    .posts-head h1 {
      margin-top: 6px;
      font-size: 46px;
    }

    .posts-head p:last-child {
      margin-top: 8px;
      font-size: 16px;
      line-height: 1.45;
    }

    .posts-list {
      margin-top: 12px;
      gap: 8px;
    }
  }
</style>
