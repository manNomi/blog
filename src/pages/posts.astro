---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="All Posts | Nomi Journal" description="Browse all published stories and concise engineering notes.">
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <header class="animate-fade-up border-b border-line pb-4 md:pb-5">
        <p class="kicker">Archive</p>
        <h1 class="mt-2 text-[46px] font-semibold leading-none tracking-[-0.03em] text-zinc-900 sm:text-[58px] md:text-[78px]">All Posts</h1>
        <p class="mt-2 text-[16px] leading-[1.45] text-zinc-600 md:mt-3 md:text-[30px]">{allPosts.length} published stories.</p>
      </header>

      <section class="mt-3 grid animate-fade-up gap-2.5 md:mt-[18px] md:gap-2.5" aria-label="All posts list">
        {allPosts.map((post) => (
          <PostCard
            title={post.data.title}
            description={post.data.description}
            slug={post.slug}
            pubDate={post.data.pubDate}
            tags={post.data.tags}
            pinned={post.data.pinned}
            variant="compact"
          />
        ))}
      </section>
    </section>
  </main>

  <Footer />
</BaseLayout>
