---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { getArticlePosts, isNotePost } from '../utils/postFilters';

const posts = getArticlePosts(await getCollection('blog'));
const allTags = [...new Set(posts.flatMap((post) => post.data.tags || []))].sort((a, b) => a.localeCompare(b, 'ko-KR'));
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = posts.filter((post) => (post.data.tags || []).includes(tag)).length;
  return acc;
}, {} as Record<string, number>);
---

<BaseLayout title="글 | 한만욱" description="성능, 아키텍처 디버깅, DX 자동화, 오픈소스 문제를 추적하고 해결한 기록입니다.">
  <Header />

  <main class="site-main">
    <div class="wrap">
      <header class="page-head rise">
        <div class="eyebrow mb-[18px]">All writing · {posts.length}</div>
        <h1>글</h1>
        <p>성능, 아키텍처 디버깅, DX 자동화, 오픈소스 — 문제를 추적하고 해결한 기록입니다.</p>
      </header>

      <div class="my-2 mb-6 flex flex-wrap items-center justify-between gap-4">
        <div class="flex flex-wrap gap-2">
          <a href="/posts" class="pill" data-active="true">전체 <span class="opacity-60">{posts.length}</span></a>
          {allTags.map((tag) => (
            <a href={`/tags?tag=${encodeURIComponent(tag)}`} class="pill">{tag} <span class="opacity-60">{tagCounts[tag]}</span></a>
          ))}
        </div>
      </div>

      <hr class="rule" />

      <div class="flex flex-col">
        {posts.map((post, index) => (
          <>
            {index > 0 && <hr class="rule" />}
            <PostCard
              title={post.data.title}
              description={post.data.description}
              slug={post.slug}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              pinned={post.data.pinned}
              notes={isNotePost(post)}
              variant="compact"
            />
          </>
        ))}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
