---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { portfolioProjects } from '../../data/portfolio';
---

<BaseLayout title="프로젝트 | 한만욱" description="어떤 문제를 해결했고 어떤 임팩트를 만들었는지를 중심으로 정리한 케이스 스터디입니다.">
  <Header />

  <main class="site-main">
    <div class="wrap">
      <header class="page-head rise">
        <div class="eyebrow mb-[18px]">Case studies</div>
        <h1>프로젝트</h1>
        <p>무엇을 만들었는가보다, 어떤 문제를 해결했고 어떤 임팩트를 만들었는지를 중심으로 정리했습니다.</p>
      </header>

      <hr class="rule" />

      <div class="mt-2">
        {portfolioProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
        <hr class="rule" />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
