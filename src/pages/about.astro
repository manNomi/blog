---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { portfolioProfile, portfolioProjects, resumeExperiences, resumeOpenSourceGroups } from '../data/portfolio';

const openSourceContributions = resumeOpenSourceGroups.flatMap((group) => {
  const repositoryLink = group.links?.find((link) => link.label.includes('저장소'));

  return group.bullets.map((item) => ({
    groupTitle: group.title,
    repositoryLink,
    item,
    prHref: item.href ?? repositoryLink?.href ?? '#',
    prLabel: item.metric?.match(/#\d+/)?.[0] ?? 'PR'
  }));
});
---

<BaseLayout title="소개 | 한만욱" description={portfolioProfile.intro}>
  <Header />

  <main class="site-main about-page">
    <div class="wrap">
      <header class="page-head rise">
        <div class="eyebrow mb-[18px]">About</div>
        <h1>{portfolioProfile.name}</h1>
        <p>{portfolioProfile.headline}</p>
      </header>

      <p class="m-0 max-w-[62ch] text-[1.05rem] leading-[1.75]" style="color: var(--text-dim);">{portfolioProfile.intro}</p>
      <div class="focus-row mt-6">
        {portfolioProfile.focus.map((item) => <span class="focus-chip">{item}</span>)}
      </div>

      <section id="experience" class="mt-16 scroll-mt-24">
        <div class="section-head">
          <div>
            <div class="eyebrow mb-2">Experience</div>
            <h2 class="section-title">경력</h2>
          </div>
          <span class="mono">{resumeExperiences.length} roles</span>
        </div>

        {resumeExperiences.map((experience, index) => (
          <a href={`/about/${experience.slug}`} class="detail-card detail-card-link" id={`experience-${index + 1}`}>
            <span class="detail-summary">
              <span class="mono pt-1" style="color: var(--text-faint);">{experience.period}</span>
              <span class="min-w-0">
                <span class="experience-company-line">
                  {experience.logo && (
                    <span class={`company-logo company-logo--list company-logo--${experience.logo.shape}`} aria-hidden="true">
                      <img
                        src={experience.logo.src}
                        alt=""
                        width={experience.logo.width}
                        height={experience.logo.height}
                        loading="lazy"
                        decoding="async"
                      />
                    </span>
                  )}
                  <span class="m-0 block text-[1.15rem] font-bold tracking-[-0.02em]" style="color: var(--text);">{experience.company}</span>
                </span>
                <span class="my-1 block text-[0.9rem]" style="color: var(--text-dim);">{experience.role}</span>
                <span class="m-0 block max-w-[64ch] text-[0.95rem] leading-[1.6]" style="color: var(--text-dim);">{experience.description}</span>
              </span>
              <span class="pj-arrow text-2xl" aria-hidden="true">↗</span>
            </span>
          </a>
        ))}
      </section>

      <section id="projects" class="mt-16 scroll-mt-24">
        <div class="section-head">
          <div>
            <div class="eyebrow mb-2">Case studies</div>
            <h2 class="section-title">프로젝트</h2>
          </div>
          <span class="mono">{portfolioProjects.length} projects</span>
        </div>

        <div class="mt-5">
          {portfolioProjects.map((project, index) => <ProjectCard project={project} index={index} />)}
          <hr class="rule" />
        </div>
      </section>

      <section id="open-source" class="mt-16 scroll-mt-24">
        <div class="section-head">
          <div>
            <div class="eyebrow mb-2">Open Source</div>
            <h2 class="section-title">오픈소스</h2>
          </div>
          <span class="mono">{openSourceContributions.length} PRs</span>
        </div>

        <div class="mt-5">
          {openSourceContributions.map((contribution, index) => (
            <a
              href={contribution.prHref}
              target="_blank"
              rel="noopener noreferrer"
              class="detail-card detail-card-link open-source-card"
            >
              <span class="detail-summary open-source-summary">
                <span class="mono pt-1" style="color: var(--text-faint);">PR {String(index + 1).padStart(2, '0')}</span>
                <span class="open-source-copy">
                  <span class="open-source-title-line">
                    <span class="m-0 block text-[1.15rem] font-bold tracking-[-0.02em]" style="color: var(--text);">{contribution.item.title}</span>
                    {contribution.item.metric && <span class="mono opacity-60">{contribution.item.metric}</span>}
                  </span>
                  <span class="my-1 block text-[0.9rem]" style="color: var(--text-dim);">{contribution.groupTitle}</span>
                  <span class="open-source-contribution">
                    <span>{contribution.item.description}</span>
                  </span>
                </span>
                <span class="open-source-actions" aria-label={`${contribution.item.title} GitHub 링크`}>
                  {contribution.repositoryLink && (
                    <button
                      type="button"
                      class="pill open-source-link-button"
                      data-open-source-link
                      data-href={contribution.repositoryLink.href}
                      data-external={contribution.repositoryLink.external ? 'true' : 'false'}
                      aria-label={`${contribution.groupTitle} ${contribution.repositoryLink.label} 열기`}
                    >
                      {contribution.repositoryLink.label} ↗
                    </button>
                  )}
                  {contribution.item.href && (
                    <button
                      type="button"
                      class="pill open-source-link-button"
                      data-open-source-link
                      data-href={contribution.item.href}
                      data-external={contribution.item.href.startsWith('http') ? 'true' : 'false'}
                      aria-label={`${contribution.item.title} ${contribution.prLabel} 열기`}
                    >
                      {contribution.prLabel} ↗
                    </button>
                  )}
                  <span class="pj-arrow text-2xl" aria-hidden="true">↗</span>
                </span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="mt-16">
        <div class="eyebrow mb-[18px]">Contact</div>
        <div class="flex flex-wrap gap-3">
          <a href={`mailto:${portfolioProfile.email}`} class="pill h-9" style="color: var(--text); border-color: var(--border-strong);">{portfolioProfile.email}</a>
          <a href={portfolioProfile.github} target="_blank" rel="noopener noreferrer" class="pill h-9" style="color: var(--text); border-color: var(--border-strong);">GitHub ↗</a>
        </div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-open-source-link]').forEach((button) => {
    button.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();

      const href = button.dataset.href;
      if (!href) return;

      if (button.dataset.external === 'true') {
        const opened = window.open(href, '_blank', 'noopener,noreferrer');
        if (opened) opened.opener = null;
        return;
      }

      window.location.assign(href);
    });
  });
</script>
