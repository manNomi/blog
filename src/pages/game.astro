---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const games = [
  {
    href: '/game/fortune',
    eyebrow: 'Fortune',
    title: '운세보기',
    description: '시험운과 연애운 중 하나를 골라 필요한 정보만 단계적으로 입력합니다.',
    meta: '이메일 리포트 · Progressive Flow'
  },
  {
    href: '/game/compatibility',
    eyebrow: 'Match',
    title: '궁합 보기',
    description: '이름과 MBTI를 별자리 그래프로 배치해 사람들 사이의 궁합 흐름을 확인합니다.',
    meta: 'MBTI Graph · Interactive'
  },
  {
    href: '/game/dice',
    eyebrow: 'Dice',
    title: '주사위 게임',
    description: '숫자와 키워드를 넣고 3D 주사위를 굴려 가벼운 오늘의 흐름을 봅니다.',
    meta: 'Three.js · Physics'
  },
  {
    href: '/game/ladder',
    eyebrow: 'Ladder',
    title: '3D 사다리타기',
    description: '참가자와 결과를 입력하고, 명화풍 배경 위의 3D 사다리 경로를 따라갑니다.',
    meta: 'Three.js · Z-axis View'
  }
];
---

<BaseLayout title="게임 | Nomi Journal" description="운세, 궁합, 주사위, 사다리타기를 한 곳에서 고르는 미니게임 허브">
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="mx-auto grid max-w-[1080px] gap-5 text-[var(--text)]">
        <section class="saju-card overflow-hidden px-5 py-7 md:px-8 md:py-9">
          <div class="flex flex-col gap-5 md:flex-row md:items-end md:justify-between">
            <div>
              <p class="eyebrow">Game Lab</p>
              <h1 class="mt-3 text-[34px] font-semibold leading-[1.08] tracking-[-0.04em] md:text-[54px]">작게 즐기는 실험실</h1>
              <p class="mt-4 max-w-[680px] text-[15px] leading-[1.72] text-[var(--text-dim)] md:text-[17px]">
                기존 운세 화면을 게임 허브로 바꿨습니다. 가벼운 운세, 궁합 그래프, 주사위, 3D 사다리타기를 한 화면에서 고르고 바로 실행할 수 있습니다.
              </p>
            </div>
            <span class="pill w-fit cursor-default">4 games</span>
          </div>
        </section>

        <section aria-label="미니게임 목록" class="grid gap-3 md:grid-cols-2">
          {games.map((game, index) => (
            <a
              href={game.href}
              class="saju-choice group min-h-[220px] p-5 transition-transform duration-200 hover:-translate-y-0.5 md:p-6"
              style={`animation-delay: ${index * 70}ms;`}
            >
              <span class="eyebrow">{game.eyebrow}</span>
              <span class="mt-4 block text-[26px] font-semibold leading-[1.15] tracking-[-0.03em] text-[var(--text)] md:text-[32px]">{game.title}</span>
              <span class="mt-3 block max-w-[42ch] text-[14px] leading-[1.65] text-[var(--text-dim)] md:text-[15px]">{game.description}</span>
              <span class="mt-7 flex items-center justify-between gap-4">
                <span class="mono">{game.meta}</span>
                <span class="grid h-9 w-9 place-items-center rounded-full border border-[var(--border)] text-[var(--text-dim)] transition group-hover:border-[var(--border-strong)] group-hover:text-[var(--text)]" aria-hidden="true">↗</span>
              </span>
            </a>
          ))}
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
