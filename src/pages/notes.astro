---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getNotePosts } from '../utils/postFilters';

const notes = getNotePosts(await getCollection('blog'));

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  })
    .format(date)
    .replaceAll(' ', '');
---

<BaseLayout title="Notes | 한만욱" description="짧은 기록과 논문 메모를 분리해 모아둔 페이지입니다.">
  <Header />

  <main class="site-main">
    <div class="wrap">
      <header class="page-head rise">
        <div class="eyebrow mb-[18px]">Notes · {notes.length}</div>
        <h1>Notes</h1>
        <p>짧은 기록, 논문 메모, 가벼운 로그를 일반 글 목록과 분리해 모았습니다.</p>
      </header>

      <hr class="rule" />

      <section class="note-card-grid" aria-label="노트 목록">
        {notes.length > 0 ? (
          notes.map((post) => (
            <a href={`/blog/${post.slug}`} class="note-card">
              <span class="note-card__meta">
                <span class="mono">{formatDate(post.data.pubDate)}</span>
                {post.data.pinned && <span class="mono">Featured</span>}
              </span>

              <span class="note-card__body">
                <span class="note-card__title">{post.data.title}</span>
                {post.data.description && <span class="note-card__description">{post.data.description}</span>}
              </span>

              <span class="note-card__footer">
                <span class="note-card__tags">
                  {(post.data.tags || []).slice(0, 3).map((tag) => <span class="mono">#{tag}</span>)}
                </span>
                <span class="mono">읽기</span>
              </span>
            </a>
          ))
        ) : (
          <div class="mono py-12" style="color: var(--text-faint);">notes 체크박스가 켜진 글이 아직 없습니다.</div>
        )}
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>
