---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SajuLovePage from '../components/SajuLovePage';
---

<BaseLayout title="사주 연정 풀이 | 한만욱" description="사주를 적어 올리면 연정·혼인·위태로움을 헤아려 드리는 통합 마당">
  <Header />

  <main class="pb-[2.4rem] pt-[calc(var(--header-height)+1.5rem)] md:pb-12 md:pt-[calc(var(--header-height)+2rem)]">
    <section class="container">
      <div class="mx-auto max-w-[860px]">
        <SajuLovePage client:load />
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
