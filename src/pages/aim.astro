---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AIM 화이팅 | Nomi Journal" description="김용준, 문승재 AIM 레이스 응원 페이지" robots="noindex, follow">
  <main class="aim-page">
    <section id="animation_holder" aria-label="AIM race day support animation">
      <div class="cheer-banner">
        <div class="cheer-kicker">RACE DAY SUPPORT</div>
        <h1>김용준 · 문승재</h1>
        <h2><span>AIM</span> 화이팅!</h2>
        <p>끝까지 멋지게 달려라 🚗💨</p>
      </div>

      <section id="bugatti_v">
        <section id="carhold_1">
          <section id="veyron_ruler_holer_box">
            <div id="ruler_1_wrap"></div>
            <section id="ruler_horizontal_2"></section>
          </section>

          <section id="veyron_hold_box">
            <img id="veyron_bumper" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_bumper.png" alt="" />
            <img id="veyron_frame" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_frame.png" alt="" />
            <img id="veyron_siding" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_siding.png" alt="" />
            <img id="veyron_fender" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_s_fender.png" alt="" />
            <img id="veyron_tire" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_tire.png" alt="" />
            <img id="veyron_tire_2" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_tire.png" alt="" />
            <img id="veyron_window" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_windows.png" alt="" />
            <img id="veyron_front_break" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_brake.png" alt="" />
            <img id="veyron_rear_break" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/veyron_brake.png" alt="" />

            <div id="aim_letters" aria-label="AIM">
              <span class="aim-a">A</span>
              <span class="aim-i">I</span>
              <span class="aim-m">M</span>
            </div>
          </section>

          <section id="stage_2">
            <img id="bugatti_veyron" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/bugatti_v.png" alt="Bugatti Veyron assembled race car" />
            <img id="bugatti_v_tire" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/bugatti_v_tire.png" alt="" />
            <img id="bugatti_v_tire_2" src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/bugatti_v_tire.png" alt="" />
            <div id="aim_final">AIM</div>
          </section>
        </section>
      </section>
    </section>
  </main>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/gsap/1.20.3/TweenMax.min.js"></script>

  <script is:inline>
    window.addEventListener('load', function () {
      var $ = window.jQuery;
      if (!$ || !window.TweenMax || !window.TimelineLite) return;

      var miniBoxesHolder = $('#ruler_1_wrap');
      for (var n = 0; n < 12; n += 1) {
        miniBoxesHolder.append('<div class="ruler_box_1"></div>');
      }

      var rulers = $('.ruler_box_1');

      new TimelineLite()
        .appendMultiple([
          TweenMax.staggerFromTo(
            rulers,
            0.3,
            {
              css: {
                height: 0,
                top: 0,
                backgroundColor: '#000',
                borderColor: 'red',
                rotation: 720,
                autoAlpha: 0
              }
            },
            {
              css: {
                height: 330,
                backgroundColor: 'transparent',
                transformOrigin: 'bottom',
                borderColor: '#777',
                rotation: 0,
                autoAlpha: 0.3
              },
              ease: Back.easeOut,
              immediateRender: true
            },
            0.1
          )
        ])
        .appendMultiple(
          [
            TweenMax.fromTo(
              $('#veyron_rear_break'),
              1.2,
              { css: { opacity: 0, right: -1000 }, immediateRender: true },
              { css: { right: 166, opacity: 1 }, ease: SlowMo.ease }
            ),
            TweenMax.fromTo(
              $('#veyron_front_break'),
              2.1,
              { css: { opacity: 0, right: -1900 }, immediateRender: true },
              { css: { right: 678, opacity: 1, delay: 1 }, ease: SlowMo.ease }
            ),
            TweenMax.fromTo(
              $('#veyron_bumper'),
              1,
              { css: { opacity: 0, right: -1100, top: -9 }, immediateRender: true },
              { css: { right: -97, top: -9, opacity: 0.7 }, ease: SlowMo.ease }
            ),
            TweenMax.fromTo(
              $('#veyron_frame'),
              2.5,
              { css: { opacity: 0, right: -1100, top: -5 }, immediateRender: true },
              {
                css: { right: -76, top: -5, opacity: 0.7 },
                ease: SlowMo.ease,
                delay: 1
              }
            ),
            TweenMax.fromTo(
              $('#veyron_siding'),
              1.2,
              {
                css: { opacity: 0, right: -1200, top: -135 },
                immediateRender: true
              },
              { css: { right: -335, top: -135, opacity: 0.7 }, ease: SlowMo.ease }
            ),
            TweenMax.fromTo(
              $('#veyron_fender'),
              1.9,
              {
                css: { opacity: 0, right: -1200, top: -158 },
                immediateRender: true
              },
              { css: { right: 274, top: -158, opacity: 0.7 }, ease: Back.easeIn }
            ),
            TweenMax.fromTo(
              $('#veyron_window'),
              2.4,
              {
                css: { opacity: 0, right: -100, top: -341 },
                immediateRender: true
              },
              { css: { right: 6, top: -341, opacity: 0.7 }, ease: Back.easeOut }
            ),
            TweenMax.staggerFromTo(
              $('#ruler_horizontal_2'),
              2,
              {
                css: {
                  height: 0,
                  left: 900,
                  backgroundColor: '#fff',
                  rotation: 400,
                  autoAlpha: 0
                }
              },
              {
                css: {
                  height: 1,
                  width: 891,
                  bottom: 85,
                  left: 5,
                  transformOrigin: 'top',
                  backgroundColor: '#777',
                  rotation: 1080,
                  opacity: 0.2,
                  autoAlpha: 0.4
                },
                ease: Back.easeOut,
                immediateRender: true
              },
              0.1
            ),
            TweenMax.staggerFromTo(
              $('#veyron_tire'),
              2.5,
              { css: { opacity: 0, right: -2991, top: -301 } },
              {
                css: { right: -191, top: -301, opacity: 0.7 },
                ease: SlowMo.ease,
                immediateRender: true
              }
            ),
            TweenMax.staggerFromTo(
              $('#veyron_tire_2'),
              3,
              { css: { opacity: 0, right: -2558, top: -301 } },
              {
                css: { right: -558, top: -301, opacity: 0.7 },
                ease: Back.easeOut,
                immediateRender: true
              },
              0.9
            ),
            TweenMax.fromTo(
              $('#aim_letters'),
              0.2,
              { css: { autoAlpha: 0 }, immediateRender: true },
              { css: { autoAlpha: 1 }, delay: 1.2 }
            ),
            TweenMax.fromTo(
              $('#aim_letters .aim-a'),
              1.35,
              {
                css: {
                  autoAlpha: 0,
                  x: -620,
                  y: -90,
                  rotation: -35,
                  scale: 0.25
                },
                immediateRender: true
              },
              {
                css: {
                  autoAlpha: 1,
                  x: 0,
                  y: 0,
                  rotation: 0,
                  scale: 1
                },
                ease: Back.easeOut,
                delay: 1.25
              }
            ),
            TweenMax.fromTo(
              $('#aim_letters .aim-i'),
              1.25,
              {
                css: {
                  autoAlpha: 0,
                  x: 0,
                  y: -420,
                  rotation: 360,
                  scale: 0.2
                },
                immediateRender: true
              },
              {
                css: {
                  autoAlpha: 1,
                  x: 0,
                  y: 0,
                  rotation: 0,
                  scale: 1
                },
                ease: Back.easeOut,
                delay: 1.45
              }
            ),
            TweenMax.fromTo(
              $('#aim_letters .aim-m'),
              1.45,
              {
                css: {
                  autoAlpha: 0,
                  x: 620,
                  y: 110,
                  rotation: 35,
                  scale: 0.25
                },
                immediateRender: true
              },
              {
                css: {
                  autoAlpha: 1,
                  x: 0,
                  y: 0,
                  rotation: 0,
                  scale: 1
                },
                ease: Back.easeOut,
                delay: 1.65
              }
            ),
            TweenMax.staggerFromTo(
              $('#veyron_head_1'),
              1,
              { css: { left: 44, top: -1579, autoAlpha: 0 } },
              {
                css: { left: 44, top: -976, autoAlpha: 0.9 },
                ease: SlowMo.ease,
                immediateRender: true
              },
              2
            )
          ],
          -2
        )
        .appendMultiple([
          TweenMax.staggerFromTo(
            $('#bugatti_veyron'),
            4,
            { css: { opacity: 0 }, immediateRender: true },
            { css: { opacity: 0.9 } },
            5
          ),
          TweenMax.fromTo(
            $('#aim_final'),
            1.2,
            {
              css: {
                autoAlpha: 0,
                scale: 0.35,
                rotation: -8
              },
              immediateRender: true
            },
            {
              css: {
                autoAlpha: 1,
                scale: 1,
                rotation: 0
              },
              ease: Back.easeOut,
              delay: 2.4
            }
          ),
          TweenMax.staggerFromTo(
            $('#bugatti_v_tire'),
            0.1,
            { css: { opacity: 0 }, immediateRender: true },
            { css: { opacity: 1 } }
          ),
          TweenMax.staggerFromTo(
            $('#bugatti_v_tire_2'),
            0.1,
            { css: { opacity: 0 }, immediateRender: true },
            { css: { opacity: 1 } }
          ),

          TweenMax.staggerTo($('#bugatti_veyron'), 0.1, {
            css: { opacity: 0.4 },
            immediateRender: true
          })
        ])

        .appendMultiple([
          TweenMax.staggerTo($('#veyron_hold_box'), 5, {
            css: { zIndex: '77777', opacity: 1 }
          }),
          TweenMax.staggerTo($('#veyron_hold_box'), 1, { css: { opacity: 0 } }),

          TweenMax.staggerFromTo(
            $('#bugatti_v_tire'),
            5,
            { css: { rotation: '0deg' } },
            { css: { rotation: '70deg' }, immediateRender: true }
          ),

          TweenMax.staggerFromTo(
            $('#bugatti_v_tire_2'),
            5,
            { css: { rotation: '0deg' }, immediateRender: true },
            { css: { rotation: '70deg' } }
          ),
          TweenMax.staggerTo($('#veyron_hold_box'), 5, { css: { left: 7 } }),
          TweenMax.staggerTo($('#stage_2'), 5, { css: { left: 102 } }),

          TweenMax.staggerFromTo(
            rulers,
            3,
            { css: { autoAlpha: 0.3, rotation: '0deg' } },
            {
              css: { autoAlpha: 0, rotation: '4000deg' },
              ease: Back.easeOut,
              immediateRender: true
            },
            0.2
          )
        ]);
    });
  </script>
</BaseLayout>

<style>
  .aim-page {
    min-height: 100vh;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(7, 7, 24, 0.28), rgba(7, 7, 24, 0.92)),
      url('https://s3-us-west-2.amazonaws.com/s.cdpn.io/49174/hexabump.png'),
      rgb(17, 17, 45);
    padding: 1px 0 0;
  }

  #animation_holder {
    width: 100%;
    position: relative;
    overflow: hidden;
    min-height: 100vh;
  }

  #bugatti_veyron {
    position: relative;
    float: left;
    width: 100%;
  }

  #bugatti_v {
    --aim-scale: 1;
    display: block;
    width: 100%;
    position: relative;
    max-width: 980px;
    height: 420px;
    margin: 0 auto;
  }

  #veyron_rear_break,
  #veyron_front_break {
    position: absolute;
    bottom: 35px;
  }

  #stage_2 {
    position: absolute;
    left: 45px;
    width: 816px;
    top: 52px;
  }

  img#bugatti_v_tire {
    top: -133px;
    left: 101px;
  }

  img#bugatti_v_tire_2 {
    left: 476px;
    top: -133px;
  }

  #veyron_bumper,
  #veyron_frame,
  #veyron_siding,
  #veyron_fender,
  #veyron_tire,
  #veyron_tire_2,
  #veyron_window,
  #bugatti_v_tire,
  #bugatti_v_tire_2 {
    position: relative;
  }

  #carhold_1 {
    border: 1px solid transparent;
    height: 352px;
    left: 50%;
    margin: 50px 0 0;
    position: relative;
    width: 980px;
    float: left;
    transform: translateX(-50%) scale(var(--aim-scale));
    transform-origin: top center;
  }

  #divider {
    width: 500px;
    height: 500px;
    display: block;
    margin: auto;
  }

  #veyron_ruler_holer_box {
    width: 900px;
    height: 340px;
    margin: 0 auto;
    z-index: 1;
    position: absolute;
    top: 0;
    left: 0;
  }

  #ruler_1_wrap {
    height: 370px;
    position: relative;
    width: 1000px;
    z-index: 9999;
  }

  #ruler_horizontal_1,
  #ruler_horizontal_2 {
    position: relative;
  }

  #veyron_hold_box {
    width: 978px;
    height: 229px;
    position: absolute;
    top: 60px;
    left: -50px;
  }

  #veyron_hold_box img {
    opacity: 0;
  }

  .ruler_box_1 {
    position: relative;
    float: left;
    width: 65px;
    height: 347px;
    margin: 4px;
    border-left: 1px dashed #488fcd;
    border-right: 1px dashed #488fcd;
  }

  .ruler_mark {
    border-left: 2px dotted #ccc;
    border-right: 2px dotted #ccc;
    height: 22px;
    margin: 11px auto;
    width: 33px;
  }

  .ruler_mark_2 {
    border-left: 2px dotted rgba(204, 204, 204, 0.32);
    height: 50px;
    margin: 8px auto 0;
    width: 1px;
  }

  .cheer-banner {
    position: relative;
    z-index: 999999;
    width: min(92vw, 980px);
    margin: 28px auto 0;
    text-align: center;
    font-family: 'Arial Black', Impact, sans-serif;
    color: #fff;
    pointer-events: none;
    animation: cheerIntro 1.1s ease-out both;
  }

  .cheer-banner::before {
    content: '';
    position: absolute;
    inset: -18px 10%;
    z-index: -1;
    background:
      radial-gradient(circle at 50% 50%, rgba(255, 220, 70, 0.25), transparent 58%),
      radial-gradient(circle at 20% 20%, rgba(65, 210, 255, 0.25), transparent 45%);
    filter: blur(10px);
  }

  .cheer-kicker {
    display: inline-block;
    padding: 7px 16px;
    margin-bottom: 8px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    border-radius: 999px;
    font-size: 13px;
    letter-spacing: 3px;
    color: #8de7ff;
    text-shadow: 0 0 12px rgba(141, 231, 255, 0.9);
  }

  .cheer-banner h1 {
    margin: 0;
    font-size: clamp(32px, 6vw, 72px);
    letter-spacing: -2px;
    text-shadow:
      0 0 12px rgba(255, 255, 255, 0.75),
      0 0 28px rgba(255, 220, 70, 0.65),
      4px 5px 0 rgba(0, 0, 0, 0.5);
  }

  .cheer-banner h2 {
    margin: 2px 0 0;
    font-size: clamp(30px, 5vw, 62px);
    letter-spacing: -1px;
    color: #fff;
    text-shadow:
      0 0 14px rgba(255, 255, 255, 0.9),
      0 0 26px rgba(255, 60, 60, 0.75);
  }

  .cheer-banner h2 span {
    color: #ffd84a;
    text-shadow:
      0 0 10px rgba(255, 216, 74, 1),
      0 0 30px rgba(255, 216, 74, 0.75);
  }

  .cheer-banner p {
    margin: 8px 0 0;
    font-family: Arial, sans-serif;
    font-size: clamp(15px, 2vw, 22px);
    font-weight: bold;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.88);
  }

  #aim_letters {
    position: absolute;
    left: 420px;
    top: 88px;
    z-index: 99999;
    opacity: 0;
    white-space: nowrap;
    font-family: 'Arial Black', Impact, sans-serif;
    font-size: 62px;
    line-height: 1;
    letter-spacing: 5px;
    transform: skewX(-10deg);
    color: #ffffff;
    text-shadow:
      0 0 8px rgba(255, 255, 255, 1),
      0 0 18px rgba(68, 221, 255, 0.9),
      0 0 30px rgba(255, 216, 74, 0.8),
      3px 4px 0 rgba(0, 0, 0, 0.65);
  }

  #aim_letters span {
    display: inline-block;
  }

  #aim_final {
    position: absolute;
    left: 43%;
    top: 39%;
    z-index: 30;
    opacity: 0;
    transform: translate(-50%, -50%) skewX(-10deg);
    font-family: 'Arial Black', Impact, sans-serif;
    font-size: 58px;
    line-height: 1;
    letter-spacing: 6px;
    color: #ffd84a;
    text-shadow:
      0 0 8px rgba(255, 255, 255, 1),
      0 0 18px rgba(255, 216, 74, 1),
      0 0 34px rgba(255, 64, 64, 0.9),
      3px 4px 0 rgba(0, 0, 0, 0.7);
    pointer-events: none;
  }

  @keyframes cheerIntro {
    from {
      opacity: 0;
      transform: translateY(-25px) scale(0.96);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (max-width: 900px) {
    #bugatti_v {
      --aim-scale: 0.72;
      height: 340px;
    }

    #carhold_1 {
      margin-top: 40px;
    }
  }

  @media (max-width: 560px) {
    .aim-page {
      min-height: 100svh;
    }

    #animation_holder {
      min-height: 100svh;
    }

    .cheer-banner {
      margin-top: 22px;
    }

    .cheer-banner h1 {
      letter-spacing: -1px;
    }

    #bugatti_v {
      --aim-scale: 0.42;
      height: 245px;
    }

    #carhold_1 {
      margin-top: 32px;
    }
  }
</style>
