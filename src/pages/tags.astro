---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import Footer from '../components/Footer.astro';
import { extractFirstImage } from '../utils/extractFirstImage';

const allPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .map((post) => {
    if (!post.data.heroImage && post.body) {
      const extractedImage = extractFirstImage(post.body);
      return {
        ...post,
        data: {
          ...post.data,
          heroImage: extractedImage || undefined
        }
      };
    }
    return post;
  });

const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort();

const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = allPosts.filter((post) => post.data.tags?.includes(tag)).length;
  return acc;
}, {} as Record<string, number>);

if (allTags.length === 0) {
  return Astro.redirect('/posts');
}

const tagButtonBaseClass =
  'tag-tab inline-flex items-center gap-2 rounded-[var(--radius-sm)] border px-[0.62rem] py-[0.3rem] text-[0.8rem] transition-[border-color,background-color,color] duration-150';
const tagButtonInactiveClass =
  'border-[var(--border-primary)] bg-[var(--bg-primary)] text-[var(--text-secondary)] hover:border-[var(--border-secondary)] hover:bg-[var(--bg-hover)]';
const tagButtonActiveClass =
  'border-[rgba(11,110,153,0.28)] bg-[#edf5f8] text-[var(--accent-primary)]';

const tagCountBaseClass =
  'tag-count inline-flex h-[18px] min-w-[18px] items-center justify-center rounded-[var(--radius-sm)] px-1 text-[0.67rem] font-medium';
const tagCountInactiveClass = 'bg-[var(--bg-tag)]';
const tagCountActiveClass = 'bg-[rgba(11,110,153,0.12)] text-[var(--accent-primary)]';
---

<BaseLayout title="태그별 글 보기 - manNomi" description="태그별로 분류된 기술 블로그 글을 확인하세요">
  <Header />

  <main class="min-h-screen pb-[var(--space-3xl)] pt-[calc(var(--header-height)+1.7rem)]">
    <div class="container">
      <div class="mb-[1.2rem] text-left">
        <h1 class="mb-[0.32rem] text-[1.65rem] font-semibold tracking-[-0.015em] text-[var(--text-primary)] md:text-[2rem]">
          태그별 글 보기
        </h1>
        <p class="text-[0.9rem] text-[var(--text-secondary)]">관심있는 태그를 선택하여 글을 찾아보세요</p>
      </div>

      <div class="mb-[1.2rem] rounded-[var(--radius-md)] border border-[var(--border-primary)] bg-[var(--bg-secondary)] p-[0.72rem] md:p-[0.85rem]">
        <div class="flex flex-wrap justify-start gap-[0.45rem]">
          <button
            class={`${tagButtonBaseClass} ${tagButtonActiveClass}`}
            data-tag="all"
            data-base={tagButtonBaseClass}
            data-inactive={tagButtonInactiveClass}
            data-active-classes={tagButtonActiveClass}
            data-count-base={tagCountBaseClass}
            data-count-inactive={tagCountInactiveClass}
            data-count-active={tagCountActiveClass}
          >
            <span class="tag-name text-[0.78rem] font-medium">전체</span>
            <span class={`${tagCountBaseClass} ${tagCountActiveClass}`}>{allPosts.length}</span>
          </button>
          {allTags.map((tag) => (
            <button
              class={`${tagButtonBaseClass} ${tagButtonInactiveClass}`}
              data-tag={tag}
              data-base={tagButtonBaseClass}
              data-inactive={tagButtonInactiveClass}
              data-active-classes={tagButtonActiveClass}
              data-count-base={tagCountBaseClass}
              data-count-inactive={tagCountInactiveClass}
              data-count-active={tagCountActiveClass}
            >
              <span class="tag-name text-[0.78rem] font-medium">{tag}</span>
              <span class={`${tagCountBaseClass} ${tagCountInactiveClass}`}>{tagCounts[tag]}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="posts-section mt-4">
        <div class="mb-[0.9rem] border-b border-[var(--border-primary)] pb-[0.7rem]">
          <h2 class="flex items-baseline gap-2 text-[1.24rem] font-semibold text-[var(--text-primary)]">
            <span class="current-tag">전체</span>
            <span class="post-count text-[0.85rem] font-normal text-[var(--text-tertiary)]">({allPosts.length}개의 글)</span>
          </h2>
        </div>

        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-3">
          {allPosts.map((post) => (
            <div class="post-item" data-tags={JSON.stringify(post.data.tags || [])}>
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                pubDate={post.data.pubDate}
                heroImage={post.data.heroImage}
                tags={post.data.tags}
              />
            </div>
          ))}
        </div>

        {allPosts.length === 0 && (
          <div class="py-[var(--space-3xl)] text-center text-[0.95rem] text-[var(--text-tertiary)]">
            <p>아직 작성된 글이 없습니다.</p>
          </div>
        )}
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  const tagTabs = document.querySelectorAll('.tag-tab');
  const postItems = document.querySelectorAll('.post-item');
  const currentTagElement = document.querySelector('.current-tag');
  const postCountElement = document.querySelector('.post-count');

  const updateButtonState = (button: Element, isActive: boolean) => {
    const inactiveClasses = (button.getAttribute('data-inactive') || '').split(' ').filter(Boolean);
    const activeClasses = (button.getAttribute('data-active-classes') || '').split(' ').filter(Boolean);
    const countInactiveClasses = (button.getAttribute('data-count-inactive') || '').split(' ').filter(Boolean);
    const countActiveClasses = (button.getAttribute('data-count-active') || '').split(' ').filter(Boolean);
    const countNode = button.querySelector('.tag-count');

    button.classList.remove(...inactiveClasses, ...activeClasses);

    if (isActive) {
      button.classList.add(...activeClasses);
    } else {
      button.classList.add(...inactiveClasses);
    }

    if (countNode) {
      countNode.classList.remove(...countInactiveClasses, ...countActiveClasses);
      if (isActive) {
        countNode.classList.add(...countActiveClasses);
      } else {
        countNode.classList.add(...countInactiveClasses);
      }
    }
  };

  tagTabs.forEach((button) => {
    button.addEventListener('click', () => {
      const selectedTag = button.getAttribute('data-tag');
      const tagName = button.querySelector('.tag-name')?.textContent || '전체';

      tagTabs.forEach((btn) => updateButtonState(btn, btn === button));

      let visibleCount = 0;
      postItems.forEach((item) => {
        const postTags = JSON.parse(item.getAttribute('data-tags') || '[]');

        if (selectedTag === 'all' || postTags.includes(selectedTag)) {
          item.classList.remove('hidden');
          visibleCount++;
        } else {
          item.classList.add('hidden');
        }
      });

      if (currentTagElement) {
        currentTagElement.textContent = tagName;
      }
      if (postCountElement) {
        postCountElement.textContent = `(${visibleCount}개의 글)`;
      }

      document.querySelector('.posts-section')?.scrollIntoView({
        behavior: 'smooth',
        block: 'start'
      });
    });
  });
</script>
