---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';
import { sortPostsByPubDateDesc } from '../utils/postFilters';

const allPosts = sortPostsByPubDateDesc(await getCollection('blog'));
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort((a, b) => {
  const diff = allPosts.filter((post) => (post.data.tags || []).includes(b)).length - allPosts.filter((post) => (post.data.tags || []).includes(a)).length;
  return diff || a.localeCompare(b, 'ko-KR');
});
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = allPosts.filter((post) => (post.data.tags || []).includes(tag)).length;
  return acc;
}, {} as Record<string, number>);
---

<BaseLayout title="태그 | 한만욱" description="주제별로 글과 노트를 탐색하세요.">
  <Header />

  <main class="site-main">
    <div class="wrap">
      <header class="page-head rise">
        <div class="eyebrow mb-[18px]">Browse by topic</div>
        <h1>태그</h1>
        <p>주제별로 글과 노트를 탐색하세요.</p>
      </header>

      <hr class="rule" />

      <section class="grid grid-cols-[repeat(auto-fill,minmax(220px,1fr))] gap-0" aria-label="Tag cards">
        {allTags.map((tag) => (
          <a
            href={`/tags?tag=${encodeURIComponent(tag)}`}
            class="tag-card flex items-baseline justify-between border-b py-[26px] pr-[18px] transition-[padding-left]"
            data-tag-card={tag}
            style="border-color: var(--border); color: var(--text);"
          >
            <span class="text-[1.25rem] font-bold tracking-[-0.02em]">{tag}</span>
            <span class="mono">{String(tagCounts[tag]).padStart(2, '0')}</span>
          </a>
        ))}
      </section>

      <section class="mt-16 hidden" data-selected-section aria-live="polite">
        <div class="section-head">
          <div>
            <div class="eyebrow mb-2">Selected topic</div>
            <h2 class="section-title" data-tag-title>전체</h2>
          </div>
          <a href="/tags" class="mono whitespace-nowrap" style="color: var(--text-dim);">전체 태그 →</a>
        </div>

        <hr class="rule" />

        <div class="flex flex-col" data-tag-list>
          {allPosts.map((post, index) => (
            <div class="tag-content__item" data-tags={JSON.stringify(post.data.tags || [])}>
              {index > 0 && <hr class="rule" />}
              <PostCard
                title={post.data.title}
                description={post.data.description}
                slug={post.slug}
                pubDate={post.data.pubDate}
                tags={post.data.tags}
                pinned={post.data.pinned}
                notes={post.data.notes}
                variant="compact"
              />
            </div>
          ))}
        </div>

        <div class="mono hidden py-12" data-tag-empty style="color: var(--text-faint);">일치하는 글이 없습니다.</div>
      </section>
    </div>
  </main>

  <Footer />
</BaseLayout>

<script>
  // @ts-nocheck
  const selectedTag = new URLSearchParams(window.location.search).get('tag');
  const selectedSection = document.querySelector('[data-selected-section]');
  const titleNode = document.querySelector('[data-tag-title]');
  const emptyNode = document.querySelector('[data-tag-empty]');
  const items = Array.from(document.querySelectorAll('.tag-content__item'));

  const parseTags = (node) => {
    try {
      return JSON.parse(node.getAttribute('data-tags') || '[]');
    } catch {
      return [];
    }
  };

  if (selectedTag && selectedSection) {
    selectedSection.classList.remove('hidden');
    let visibleCount = 0;

    items.forEach((item) => {
      const visible = parseTags(item).includes(selectedTag);
      item.classList.toggle('hidden', !visible);
      if (visible) visibleCount += 1;
    });

    if (titleNode) titleNode.textContent = `${selectedTag} (${visibleCount})`;
    if (emptyNode) emptyNode.classList.toggle('hidden', visibleCount > 0);

    document.querySelector(`[data-tag-card="${CSS.escape(selectedTag)}"]`)?.setAttribute('data-active', 'true');
  }
</script>
