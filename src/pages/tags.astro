---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort((a, b) => a.localeCompare(b, 'en-US'));
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = allPosts.filter((post) => (post.data.tags || []).includes(tag)).length;
  return acc;
}, {} as Record<string, number>);
const tagSummaries = allTags
  .map((tag) => ({
    tag,
    count: tagCounts[tag],
    latestPost: allPosts.find((post) => (post.data.tags || []).includes(tag))?.data.title || ''
  }))
  .sort((a, b) => b.count - a.count || a.tag.localeCompare(b.tag, 'en-US'));
const tagCardClass =
  'tag-filter-card group flex min-h-[106px] w-full min-w-0 flex-col justify-between rounded-card border border-line bg-surface p-4 text-left shadow-soft transition hover:-translate-y-0.5 hover:border-zinc-400 hover:bg-zinc-50 md:min-h-[122px] md:p-5';
---

<BaseLayout title="Tags | Nomi Journal" description="Tag collections for focused reading.">
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="grid gap-6 md:gap-8 lg:gap-9">
        <header class="animate-fade-up border-b border-line pb-4 md:pb-[18px]">
          <h1 class="text-[52px] font-semibold leading-none tracking-[-0.03em] text-zinc-900 md:text-[82px]">Tags</h1>
        </header>

        <section class="grid gap-7 md:gap-8">
          <section class="animate-fade-up" aria-label="Tag cards">
            <div class="grid gap-2.5 sm:grid-cols-2 lg:grid-cols-4 xl:grid-cols-5" aria-label="Tag filters">
              <button type="button" class={tagCardClass} data-tag="all" aria-pressed="true">
                <span class="flex items-start justify-between gap-3">
                  <span class="min-w-0 truncate text-[24px] font-semibold leading-none tracking-[-0.02em] text-zinc-900 md:text-[28px]" data-tag-label>All</span>
                  <span class="shrink-0 rounded-full border border-line bg-soft px-2.5 py-1 text-[12px] font-medium leading-none text-zinc-500" data-tag-count>{allPosts.length}</span>
                </span>
                <span class="line-clamp-2 text-[13px] leading-[1.45] text-zinc-500 md:text-sm" data-tag-excerpt>전체 글</span>
              </button>

              {tagSummaries.map(({ tag, count, latestPost }) => (
                <button
                  type="button"
                  class={tagCardClass}
                  data-tag={tag}
                  aria-pressed="false"
                >
                  <span class="flex items-start justify-between gap-3">
                    <span class="min-w-0 truncate text-[24px] font-semibold leading-none tracking-[-0.02em] text-zinc-900 md:text-[28px]" data-tag-label>#{tag}</span>
                    <span class="shrink-0 rounded-full border border-line bg-soft px-2.5 py-1 text-[12px] font-medium leading-none text-zinc-500" data-tag-count>{count}</span>
                  </span>
                  <span class="line-clamp-2 text-[13px] leading-[1.45] text-zinc-500 md:text-sm" data-tag-excerpt>{latestPost}</span>
                </button>
              ))}
            </div>
          </section>

          <section class="min-w-0 animate-fade-up" aria-live="polite">
            <p class="kicker">Selected Tag</p>
            <h2 class="mt-1 text-[36px] font-semibold leading-[1.08] tracking-[-0.02em] text-zinc-900 md:text-[74px]" data-tag-title>
              All Posts ({allPosts.length})
            </h2>
            <p class="mt-2 max-w-[760px] text-[16px] leading-[1.45] text-zinc-600 md:text-[26px]" data-tag-summary>
              전체 글 {allPosts.length}개
            </p>

            <div class="mt-3 grid gap-2.5 md:mt-4" data-tag-list>
              {allPosts.map((post) => (
                <div class="tag-content__item" data-tags={JSON.stringify(post.data.tags || [])}>
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    slug={post.slug}
                    pubDate={post.data.pubDate}
                    tags={post.data.tags}
                    pinned={post.data.pinned}
                    variant="compact"
                  />
                </div>
              ))}
            </div>

            <div class="mt-4 hidden rounded-card border border-line bg-soft p-3 text-sm text-zinc-600" data-tag-empty>
              선택한 태그에는 글이 없습니다.
            </div>
          </section>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style is:global>
  .tag-filter-card.is-active {
    border-color: rgb(24 24 27);
    background-color: rgb(24 24 27);
    color: rgb(255 255 255);
  }

  .tag-filter-card.is-active [data-tag-label] {
    color: rgb(255 255 255);
  }

  .tag-filter-card.is-active [data-tag-count] {
    border-color: rgb(63 63 70);
    background-color: rgb(39 39 42);
    color: rgb(244 244 245);
  }

  .tag-filter-card.is-active [data-tag-excerpt] {
    color: rgb(212 212 216);
  }

  .dark .tag-filter-card.is-active {
    border-color: rgb(216 218 222);
    background-color: rgb(216 218 222);
    color: rgb(24 25 28);
  }

  .dark .tag-filter-card.is-active [data-tag-label] {
    color: rgb(24 25 28);
  }

  .dark .tag-filter-card.is-active [data-tag-count] {
    border-color: rgb(196 198 204);
    background-color: rgb(236 237 240);
    color: rgb(63 63 70);
  }

  .dark .tag-filter-card.is-active [data-tag-excerpt] {
    color: rgb(63 63 70);
  }
</style>

<script>
  // @ts-nocheck
  const tagCards = Array.from(document.querySelectorAll('.tag-filter-card'));
  const postItems = Array.from(document.querySelectorAll('.tag-content__item'));
  const titleNode = document.querySelector('[data-tag-title]');
  const summaryNode = document.querySelector('[data-tag-summary]');
  const emptyNode = document.querySelector('[data-tag-empty]');

  const parseTags = (node) => {
    try {
      return JSON.parse(node.getAttribute('data-tags') || '[]');
    } catch {
      return [];
    }
  };

  const resolveTag = (tag) => {
    if (!tag) return 'all';
    return tagCards.some((card) => card.getAttribute('data-tag') === tag) ? tag : 'all';
  };

  const syncUrl = (tag) => {
    const url = new URL(window.location.href);
    if (tag === 'all') {
      url.searchParams.delete('tag');
    } else {
      url.searchParams.set('tag', tag);
    }
    window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
  };

  const setCardActive = (activeTag) => {
    tagCards.forEach((card) => {
      const isActive = card.getAttribute('data-tag') === activeTag;
      card.classList.toggle('is-active', isActive);
      card.classList.toggle('shadow-card', isActive);

      card.setAttribute('aria-pressed', isActive ? 'true' : 'false');
    });
  };

  const applyTag = (requestedTag, { sync = true } = {}) => {
    const tag = resolveTag(requestedTag);
    let visibleCount = 0;

    setCardActive(tag);

    postItems.forEach((item) => {
      const tags = parseTags(item);
      const visible = tag === 'all' ? true : tags.includes(tag);
      item.classList.toggle('hidden', !visible);
      if (visible) visibleCount += 1;
    });

    if (titleNode) {
      titleNode.textContent = tag === 'all' ? `All Posts (${visibleCount})` : `${tag} (${visibleCount})`;
    }

    if (summaryNode) {
      summaryNode.textContent = tag === 'all' ? `전체 글 ${visibleCount}개` : `${tag} 글 ${visibleCount}개`;
    }

    if (emptyNode) {
      emptyNode.classList.toggle('hidden', visibleCount > 0);
    }

    if (sync) syncUrl(tag);
  };

  tagCards.forEach((card) => {
    card.addEventListener('click', () => {
      applyTag(card.getAttribute('data-tag'));
    });
  });

  const initialTag = new URLSearchParams(window.location.search).get('tag');
  applyTag(initialTag, { sync: false });
</script>
