---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PostCard from '../components/PostCard.astro';

const allPosts = (await getCollection('blog')).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const allTags = [...new Set(allPosts.flatMap((post) => post.data.tags || []))].sort((a, b) => a.localeCompare(b, 'en-US'));
const tagCounts = allTags.reduce((acc, tag) => {
  acc[tag] = allPosts.filter((post) => (post.data.tags || []).includes(tag)).length;
  return acc;
}, {} as Record<string, number>);
---

<BaseLayout title="Tags | Nomi Journal" description="Tag collections for focused reading.">
  <Header />

  <main class="main-shell">
    <section class="container-shell">
      <div class="grid gap-6 md:gap-8 lg:gap-9">
        <header class="animate-fade-up border-b border-line pb-4 md:pb-[18px]">
          <h1 class="text-[52px] font-semibold leading-none tracking-[-0.03em] text-zinc-900 md:text-[82px]">Tags</h1>
        </header>

        <section class="grid items-start gap-5 lg:grid-cols-[280px_minmax(0,1fr)] lg:gap-11">
          <aside class="page-card animate-fade-up p-3.5 md:p-3" aria-label="Tag list">
            <h2 class="text-[17px] font-semibold leading-tight text-zinc-900">Tag List</h2>
            <div class="mt-3 grid grid-cols-1 gap-2 md:grid-cols-2 lg:grid-cols-1" role="listbox" aria-label="Tag filters">
              {allTags.map((tag) => (
                <button
                  type="button"
                  class="tag-rail__button flex min-h-[34px] w-full items-center justify-between rounded-md border border-line bg-soft px-2.5 py-2 text-left text-[16px] text-zinc-700 transition hover:bg-zinc-900 hover:text-white md:min-h-[38px] md:px-3 md:py-2.5 md:text-[18px]"
                  data-tag={tag}
                >
                  <span>{tag}</span>
                  <span class="text-[14px] text-zinc-500 md:text-[16px]">{tagCounts[tag]}</span>
                </button>
              ))}
            </div>
          </aside>

          <section class="min-w-0 animate-fade-up" aria-live="polite">
            <p class="kicker">Selected Tag</p>
            <h2 class="mt-1 text-[36px] font-semibold leading-[1.08] tracking-[-0.02em] text-zinc-900 md:text-[74px]" data-tag-title>
              All Posts ({allPosts.length})
            </h2>
            <p class="mt-2 max-w-[760px] text-[16px] leading-[1.45] text-zinc-600 md:text-[26px]" data-tag-summary>
              선택한 꼬리표 기준으로 글목록을 묶어 보여드립니다.
            </p>

            <div class="mt-3 grid gap-2.5 md:mt-4" data-tag-list>
              {allPosts.map((post) => (
                <div class="tag-content__item" data-tags={JSON.stringify(post.data.tags || [])}>
                  <PostCard
                    title={post.data.title}
                    description={post.data.description}
                    slug={post.slug}
                    pubDate={post.data.pubDate}
                    pinned={post.data.pinned}
                    variant="compact"
                  />
                </div>
              ))}
            </div>

            <div class="mt-4 hidden rounded-card border border-line bg-soft p-3 text-sm text-zinc-600" data-tag-empty>
              선택한 꼬리표에는 글이 없습니다.
            </div>
          </section>
        </section>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<script>
  // @ts-nocheck
  const tagButtons = Array.from(document.querySelectorAll('.tag-rail__button'));
  const postItems = Array.from(document.querySelectorAll('.tag-content__item'));
  const titleNode = document.querySelector('[data-tag-title]');
  const summaryNode = document.querySelector('[data-tag-summary]');
  const emptyNode = document.querySelector('[data-tag-empty]');

  const parseTags = (node) => {
    try {
      return JSON.parse(node.getAttribute('data-tags') || '[]');
    } catch {
      return [];
    }
  };

  const resolveTag = (tag) => {
    if (!tag) return 'all';
    return tagButtons.some((button) => button.getAttribute('data-tag') === tag) ? tag : 'all';
  };

  const syncUrl = (tag) => {
    const url = new URL(window.location.href);
    if (tag === 'all') {
      url.searchParams.delete('tag');
    } else {
      url.searchParams.set('tag', tag);
    }
    window.history.replaceState({}, '', `${url.pathname}${url.search}${url.hash}`);
  };

  const setButtonActive = (activeTag) => {
    tagButtons.forEach((button) => {
      const isActive = button.getAttribute('data-tag') === activeTag;
      button.classList.toggle('is-active', isActive);
      button.classList.toggle('bg-zinc-900', isActive);
      button.classList.toggle('text-white', isActive);
      button.classList.toggle('border-zinc-900', isActive);

      const count = button.querySelector('span:last-child');
      count?.classList.toggle('text-zinc-300', isActive);
      count?.classList.toggle('text-zinc-500', !isActive);

      button.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
  };

  const applyTag = (requestedTag, { sync = true } = {}) => {
    const tag = resolveTag(requestedTag);
    let visibleCount = 0;

    setButtonActive(tag);

    postItems.forEach((item) => {
      const tags = parseTags(item);
      const visible = tag === 'all' ? true : tags.includes(tag);
      item.classList.toggle('hidden', !visible);
      if (visible) visibleCount += 1;
    });

    if (titleNode) {
      titleNode.textContent = tag === 'all' ? `All Posts (${visibleCount})` : `${tag} (${visibleCount})`;
    }

    if (summaryNode) {
      summaryNode.textContent =
        tag === 'all'
          ? '선택한 꼬리표 기준으로 글목록을 묶어 보여드립니다.'
          : `${tag} 꼬리표로 묶인 글을 보여드립니다.`;
    }

    if (emptyNode) {
      emptyNode.classList.toggle('hidden', visibleCount > 0);
    }

    if (sync) syncUrl(tag);
  };

  tagButtons.forEach((button) => {
    button.addEventListener('click', () => {
      applyTag(button.getAttribute('data-tag'));
    });
  });

  const initialTag = new URLSearchParams(window.location.search).get('tag');
  applyTag(initialTag, { sync: false });
</script>
