---
const pathname = Astro.url.pathname;
const navItems = [
  { href: '/', label: '글', match: (path: string) => path === '/' || path.startsWith('/blog') || path.startsWith('/posts') },
  { href: '/about', label: '소개', match: (path: string) => path.startsWith('/about') },
  { href: '/tags', label: '태그', match: (path: string) => path.startsWith('/tags') },
  { href: '/game', label: '게임', match: (path: string) => path.startsWith('/game') || path.startsWith('/saju') },
  { href: '/notes', label: '노트', match: (path: string) => path.startsWith('/notes') }
];
---

<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="site-header__brand" href="/" aria-label="한만욱 홈">
      <span class="text-[1.02rem]">한만욱</span>
      <span class="mono hd-sub text-[0.66rem]">frontend</span>
    </a>

    <nav class="site-header__nav" aria-label="Primary">
      {navItems.map((item) => (
        <a class="site-header__link" href={item.href} data-active={item.match(pathname) ? 'true' : undefined}>
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="https://github.com/manNomi"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
        class="icon-button hd-github"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 1.5A10.5 10.5 0 0 0 8.7 22c.5.1.7-.2.7-.5v-2c-2.9.6-3.5-1.2-3.5-1.2-.5-1.2-1.2-1.5-1.2-1.5-1-.6 0-.6 0-.6 1 .1 1.6 1.1 1.6 1.1.9 1.6 2.4 1.1 3 .9.1-.7.4-1.1.6-1.4-2.3-.3-4.7-1.1-4.7-5 0-1.1.4-2 1-2.7-.1-.3-.5-1.3.1-2.7 0 0 .9-.3 2.8 1a9.6 9.6 0 0 1 5 0c1.9-1.3 2.8-1 2.8-1 .6 1.4.2 2.4.1 2.7.7.7 1 1.6 1 2.7 0 3.9-2.4 4.7-4.6 5 .3.3.7 1 .7 2v3c0 .3.2.6.7.5A10.5 10.5 0 0 0 12 1.5z" />
        </svg>
      </a>

      <button type="button" class="icon-button" aria-label="테마 전환" title="테마 전환" data-theme-toggle>
        <svg data-theme-icon="light" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg data-theme-icon="dark" class="hidden" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // @ts-nocheck
  const THEME_STORAGE_KEY = 'nomi-theme';
  const themeToggle = document.querySelector('[data-theme-toggle]');
  const lightIcon = document.querySelector('[data-theme-icon="light"]');
  const darkIcon = document.querySelector('[data-theme-icon="dark"]');

  const readTheme = () => document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';

  const syncIcons = (theme) => {
    lightIcon?.classList.toggle('hidden', theme !== 'dark');
    darkIcon?.classList.toggle('hidden', theme !== 'light');
    themeToggle?.setAttribute('title', theme === 'dark' ? '라이트 모드' : '다크 모드');
  };

  const applyTheme = (theme) => {
    const nextTheme = theme === 'light' ? 'light' : 'dark';
    document.documentElement.dataset.theme = nextTheme;
    document.documentElement.classList.toggle('dark', nextTheme === 'dark');
    document.documentElement.style.colorScheme = nextTheme;
    try {
      localStorage.setItem(THEME_STORAGE_KEY, nextTheme);
    } catch {}
    syncIcons(nextTheme);
    window.dispatchEvent(new CustomEvent('themechange', { detail: { theme: nextTheme } }));
  };

  syncIcons(readTheme());
  themeToggle?.addEventListener('click', () => {
    applyTheme(readTheme() === 'dark' ? 'light' : 'dark');
  });
</script>
