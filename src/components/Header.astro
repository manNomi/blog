---
const navItems = [
  { href: '/posts', label: 'All Posts' },
  { href: '/tags', label: 'Tags' },
  { href: '/saju', label: 'Saju' }
];
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-logo" href="/" aria-label="Nomi Journal Home">
      <span class="site-logo__title">Nomi Journal</span>
      <span class="site-logo__sub">Editorial Developer Notes</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </nav>

    <button type="button" class="site-nav-toggle" aria-expanded="false" aria-controls="mobile-nav" id="mobileNavToggle">
      <span class="sr-only">Open navigation</span>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="4" y1="7" x2="20" y2="7"></line>
        <line x1="4" y1="12" x2="20" y2="12"></line>
        <line x1="4" y1="17" x2="20" y2="17"></line>
      </svg>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <div class="container">
      <ul>
        <li><a href="/">Home</a></li>
        {navItems.map((item) => (
          <li><a href={item.href}>{item.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg-page) 92%, white 8%);
    border-bottom: 1px solid var(--line-default);
    backdrop-filter: blur(10px);
  }

  .site-header__inner {
    height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .site-logo {
    display: inline-flex;
    flex-direction: column;
    min-width: 0;
  }

  .site-logo__title {
    font-size: 17px;
    line-height: 1.05;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-strong);
  }

  .site-logo__sub {
    margin-top: 2px;
    font-size: 11px;
    color: var(--text-faint);
    white-space: nowrap;
  }

  .site-nav ul {
    list-style: none;
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 0;
  }

  .site-nav a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    padding: 0 12px;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    color: #4d4d4d;
    font-size: 13px;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .site-nav a:hover {
    color: var(--text-strong);
    border-color: var(--line-default);
    background: var(--bg-soft);
  }

  .site-nav-toggle {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    border: 1px solid var(--line-default);
    background: var(--bg-soft);
    color: var(--text-body);
    display: none;
    align-items: center;
    justify-content: center;
  }

  .mobile-nav {
    border-top: 1px solid var(--line-default);
    background: var(--bg-page);
    padding: 10px 0 14px;
  }

  .mobile-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 6px;
  }

  .mobile-nav a {
    display: block;
    padding: 10px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line-default);
    background: var(--bg-surface);
    font-size: 14px;
    color: var(--text-body);
  }

  @media (max-width: 768px) {
    .site-logo__sub {
      display: none;
    }

    .site-logo__title {
      font-size: 16px;
    }

    .site-nav {
      display: none;
    }

    .site-nav-toggle {
      display: inline-flex;
    }
  }
</style>

<script>
  // @ts-nocheck
  const toggle = document.getElementById('mobileNavToggle');
  const mobileNav = document.getElementById('mobile-nav');

  const setOpen = (open) => {
    if (!toggle || !mobileNav) return;
    toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    mobileNav.hidden = !open;
  };

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    setOpen(!isOpen);
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 768) {
      setOpen(false);
    }
  });
</script>
