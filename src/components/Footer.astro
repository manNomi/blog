---
const links = [
  { name: 'Contact', url: 'mailto:hanmw110@gmail.com' },
  { name: 'GitHub', url: 'https://github.com/manNomi' },
  { name: 'Posts', url: '/posts' }
];
---

<footer class="site-footer">
  <div class="container">
    <div class="site-footer__bar">
      <div class="site-footer__links">
        {links.map((link, index) => (
          <>
            {index > 0 && <span aria-hidden="true">·</span>}
            <a href={link.url} target={link.url.startsWith('http') ? '_blank' : undefined} rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}>{link.name}</a>
          </>
        ))}
      </div>
      <p>© 2026</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: 64px;
  }

  .site-footer__bar {
    border-radius: var(--radius-md);
    border: 1px solid #1f1f1f;
    background: #111;
    color: #d8d8d8;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    padding: 14px 16px;
    font-size: 13px;
    line-height: 1;
  }

  .site-footer__links {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .site-footer__links a {
    color: #efefef;
    opacity: 0.95;
  }

  .site-footer__links a:hover {
    opacity: 1;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .site-footer p {
    margin: 0;
    color: #c4c4c4;
  }

  @media (max-width: 768px) {
    .site-footer__bar {
      padding: 12px 14px;
      flex-direction: column;
      align-items: flex-start;
      font-size: 12px;
    }
  }
</style>
