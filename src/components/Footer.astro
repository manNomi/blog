---
const links = [
  { name: 'GitHub ↗', url: 'https://github.com/manNomi' },
  { name: 'About', url: '/about' },
  { name: 'Tags', url: '/tags' }
];
---

<footer class="mt-24 border-t" style="border-color: var(--border);">
  <div class="wrap flex flex-wrap items-end justify-between gap-7 py-11 pb-14">
    <div>
      <div class="mb-1.5 text-[1.05rem] font-bold tracking-[-0.02em]" style="color: var(--text);">한만욱</div>
      <a class="mono" href="mailto:hanmw110@naver.com">hanmw110@naver.com</a>
    </div>

    <div class="mono flex gap-5">
      {links.map((link) => (
        <a
          href={link.url}
          target={link.url.startsWith('http') ? '_blank' : undefined}
          rel={link.url.startsWith('http') ? 'noopener noreferrer' : undefined}
          class="whitespace-nowrap transition-colors hover:!text-[var(--text)]"
          style="color: var(--text-dim);"
        >
          {link.name}
        </a>
      ))}
    </div>
  </div>
</footer>
