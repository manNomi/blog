---
interface Props {
  title: string;
  description?: string;
  slug: string;
  pubDate: Date;
  tags?: string[];
  pinned?: boolean;
}

const { title, description, slug, pubDate, tags, pinned = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(pubDate);
---

<article class="post-row">
  <a href={`/blog/${slug}`} class="row-link">
    <div class="row-title-wrap">
      <h3 class="row-title">{title}</h3>
      {pinned && <span class="row-badge">으뜸</span>}
    </div>

    {description && <p class="row-description">{description}</p>}

    <div class="row-meta">
      <time datetime={pubDate.toISOString()}>{formattedDate}</time>
      {tags && tags.length > 0 && (
        <div class="row-tags" aria-label="갈래말">
          {tags.slice(0, 4).map((tag) => (
            <span class="row-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>

<style>
  .post-row {
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    background: var(--bg-card);
    transition: border-color 0.15s ease, transform 0.15s ease;
  }

  .post-row:hover {
    border-color: var(--border-secondary);
    transform: translateY(-1px);
  }

  .row-link {
    display: block;
    padding: 0.82rem 0.9rem 0.78rem;
    color: inherit;
    text-decoration: none;
  }

  .row-title-wrap {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.38rem;
  }

  .row-title {
    font-size: 1.05rem;
    line-height: 1.45;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .row-badge {
    display: inline-flex;
    align-items: center;
    height: 18px;
    padding: 0 0.36rem;
    border: 1px solid rgba(11, 110, 153, 0.28);
    border-radius: 999px;
    background: #edf5f8;
    color: var(--accent-primary);
    font-size: 0.66rem;
    font-weight: 700;
    line-height: 1;
  }

  .row-description {
    margin-top: 0.34rem;
    font-size: 0.86rem;
    line-height: 1.6;
    color: var(--text-secondary);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .row-meta {
    margin-top: 0.56rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem 0.56rem;
    font-size: 0.76rem;
    color: var(--text-tertiary);
  }

  .row-meta time {
    white-space: nowrap;
  }

  .row-tags {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.3rem;
  }

  .row-tag {
    display: inline-flex;
    align-items: center;
    height: 19px;
    padding: 0 0.4rem;
    border: 1px solid rgba(123, 118, 109, 0.44);
    border-radius: 999px;
    background: var(--bg-tag);
    color: var(--text-secondary);
    font-size: 0.7rem;
    line-height: 1;
  }

  @media (max-width: 768px) {
    .row-link {
      padding: 0.74rem 0.75rem;
    }

    .row-title {
      font-size: 1rem;
    }
  }
</style>
