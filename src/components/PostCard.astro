---
interface Props {
  title: string;
  description?: string;
  slug: string;
  pubDate: Date;
  tags?: string[];
  pinned?: boolean;
  variant?: 'list' | 'compact';
}

const { title, description, slug, pubDate, tags = [], pinned = false, variant = 'list' } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric'
}).format(pubDate);
---

<article class={`post-card post-card--${variant}`}>
  <a href={`/blog/${slug}`} class="post-card__link">
    <div class="post-card__meta">
      <span>{formattedDate}</span>
      {pinned && <span class="post-card__pill">Featured</span>}
      {tags.length > 0 && <span>{tags.slice(0, 2).join(' · ')}</span>}
    </div>

    <h3 class="post-card__title">{title}</h3>

    {description && <p class="post-card__description">{description}</p>}
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--line-default);
    border-radius: var(--radius-md);
    background: var(--bg-surface);
    transition: border-color 0.2s ease, transform 0.2s ease, background-color 0.2s ease;
  }

  .post-card:hover {
    border-color: var(--line-strong);
    background: #fdfdfd;
    transform: translateY(-1px);
  }

  .post-card__link {
    display: block;
    padding: 18px;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
    font-size: 12px;
    color: var(--text-faint);
    line-height: 1.2;
  }

  .post-card__pill {
    display: inline-flex;
    align-items: center;
    height: 20px;
    padding: 0 8px;
    border-radius: var(--radius-pill);
    border: 1px solid var(--line-default);
    background: var(--bg-soft);
    font-size: 11px;
    color: #3f3f3f;
  }

  .post-card__title {
    margin-top: 10px;
    color: var(--text-strong);
    font-size: 26px;
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
  }

  .post-card__description {
    margin-top: 10px;
    font-size: 17px;
    line-height: 1.55;
    color: #3f3f3f;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .post-card--compact .post-card__link {
    padding: 16px;
  }

  .post-card--compact .post-card__title {
    margin-top: 8px;
    font-size: 24px;
    line-height: 1.2;
  }

  .post-card--compact .post-card__description {
    font-size: 15px;
    line-height: 1.5;
  }

  @media (max-width: 1024px) {
    .post-card__title,
    .post-card--compact .post-card__title {
      font-size: 22px;
    }
  }

  @media (max-width: 768px) {
    .post-card__link,
    .post-card--compact .post-card__link {
      padding: 14px;
    }

    .post-card__title,
    .post-card--compact .post-card__title {
      font-size: 20px;
      line-height: 1.22;
    }

    .post-card__description,
    .post-card--compact .post-card__description {
      font-size: 14px;
    }
  }
</style>
