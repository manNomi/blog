---
interface Props {
  title: string;
  description?: string;
  slug: string;
  pubDate: Date;
  tags?: string[];
  pinned?: boolean;
  variant?: 'list' | 'compact';
}

const { title, description, slug, pubDate, tags = [], pinned = false, variant = 'list' } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
}).format(pubDate);

const cardPadding = variant === 'compact' ? 'p-4 md:p-5' : 'p-5 md:p-6';
const titleSize = variant === 'compact' ? 'mt-2 text-[22px] leading-[1.22] md:text-2xl' : 'mt-2.5 text-2xl leading-[1.2] md:text-[26px]';
const descSize = variant === 'compact' ? 'mt-2 text-[15px] leading-[1.52]' : 'mt-2.5 text-[17px] leading-[1.55]';
---

<article class="rounded-card border border-line bg-surface transition hover:-translate-y-0.5 hover:border-zinc-400 hover:bg-zinc-50">
  <a href={`/blog/${slug}`} class={`block ${cardPadding}`}>
    <div class="flex flex-wrap items-center gap-2 text-xs leading-[1.2] text-zinc-500">
      <span>{formattedDate}</span>
      {pinned && <span class="inline-flex h-5 items-center rounded-full border border-line bg-soft px-2 text-[11px] text-zinc-700">고정</span>}
      {tags.length > 0 && <span>{tags.slice(0, 2).join(' · ')}</span>}
    </div>

    <h3 class={`font-semibold tracking-[-0.02em] text-zinc-900 ${titleSize}`}>{title}</h3>

    {description && <p class={`line-clamp-2 text-zinc-700 ${descSize}`}>{description}</p>}
  </a>
</article>
