---
interface Props {
  title: string;
  description?: string;
  slug: string;
  pubDate: Date;
  tags?: string[];
  pinned?: boolean;
  notes?: boolean;
  variant?: 'list' | 'compact';
}

const { title, description, slug, pubDate, tags = [], pinned = false, notes = false } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
})
  .format(pubDate)
  .replaceAll(' ', '');
---

<a href={`/blog/${slug}`} class="post-row">
  <span class="mono pt-1">{formattedDate}</span>

  <span>
    <span class="post-title text-[1.12rem] font-semibold leading-[1.4] tracking-[-0.02em]">{title}</span>
    {description && <span class="mt-1.5 block max-w-[62ch] text-[0.92rem] leading-[1.6]" style="color: var(--text-dim);">{description}</span>}
    <span class="mt-2.5 flex flex-wrap gap-1.5">
      {pinned && <span class="mono text-[0.66rem]" style="color: var(--text-faint);">#Featured</span>}
      {notes && <span class="mono text-[0.66rem]" style="color: var(--text-faint);">#Note</span>}
      {tags.slice(0, 4).map((tag) => (
        <span class="mono text-[0.66rem]" style="color: var(--text-faint);">#{tag}</span>
      ))}
    </span>
  </span>

  <span class="mono pt-1 opacity-80">read</span>
</a>
