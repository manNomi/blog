---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ViewCounter from '../components/ViewCounter';
import ShareButtons from '../components/ShareButtons.astro';
import Comments from '../components/Comments';
import PostCard from '../components/PostCard.astro';

type NavPost = { title: string; slug: string } | null;
type RelatedPost = { title: string; slug: string; description?: string; pubDate?: Date };
type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  heroImage?: string;
  readingTime: number;
  previousPost?: NavPost;
  nextPost?: NavPost;
  relatedPosts?: RelatedPost[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags = [],
  slug,
  heroImage,
  readingTime,
  previousPost = null,
  nextPost = null,
  relatedPosts = [],
  notes = false
} = Astro.props as Props;

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat('ko-KR', {
    year: 'numeric',
    month: '2-digit',
    day: '2-digit'
  }).format(date);

const collectionPath = notes ? '/notes' : '/';
const collectionLabel = notes ? '노트 목록' : '글 목록';
---

<BaseLayout
  title={`${title} - 한만욱`}
  description={description || '아티클 상세 페이지'}
  image={heroImage}
  imageAlt={`${title} 대표 이미지`}
  canonicalURL={`/blog/${slug}`}
  ogType="article"
>
  <Header />

  <main class="site-main">
    <div class="wrap max-w-[720px]">
      <div class="pt-7">
        <a href={collectionPath} class="mono inline-flex items-center gap-2 py-2 transition-colors hover:!text-[var(--text)]" style="color: var(--text-dim);">← {collectionLabel}</a>
      </div>

      <article class="rise pt-5">
        <div class="mb-5 flex flex-wrap items-center gap-2.5">
          <span class="mono">{formatDate(pubDate)}</span>
          {updatedDate && <span class="mono opacity-60">· 수정 {formatDate(updatedDate)}</span>}
          <span class="mono opacity-60">· {readingTime}min read</span>
          <ViewCounter client:load slug={slug} />
        </div>

        <h1 class="m-0 text-[clamp(1.9rem,4.4vw,2.7rem)] font-bold leading-[1.22] tracking-[-0.035em]" style="color: var(--text);">{title}</h1>

        <div class="mt-[18px] flex flex-wrap gap-1.5">
          {notes && <a href="/notes" class="mono text-[0.7rem]" style="color: var(--text-faint);">#Note</a>}
          {tags.map((tag) => <a href={`/tags?tag=${encodeURIComponent(tag)}`} class="mono text-[0.7rem]" style="color: var(--text-faint);">#{tag}</a>)}
        </div>

        {heroImage && (
          <img
            src={heroImage}
            alt={`${title} 대표 이미지`}
            class="post-cover my-8 rounded-2xl"
            loading="eager"
            decoding="async"
          />
        )}
        {!heroImage && (
          <div class="ph my-8 rounded-2xl" data-label={notes ? 'note cover' : 'post cover'} style="aspect-ratio: 16 / 8;"></div>
        )}

        {description && <p class="text-[1.18rem] leading-[1.8] tracking-[-0.01em]" style="color: var(--text);">{description}</p>}

        <div class="article-body mt-7">
          <slot />
        </div>

        <div class="mono my-7 rounded-xl border border-dashed px-[18px] py-4 leading-[1.7]" style="border-color: var(--border-strong); color: var(--text-faint);">
          Notion sync로 동기화된 Markdown 콘텐츠입니다.
        </div>

        <div class="mt-7 flex flex-wrap items-center justify-between gap-3 border-t pt-5" style="border-color: var(--border);">
          <span class="mono">공유</span>
          <ShareButtons title={title} url={`/blog/${slug}`} />
        </div>
      </article>

      {(previousPost || nextPost) && (
        <section class="mt-12">
          <hr class="rule" />
          <div class="grid gap-3 py-7 sm:grid-cols-2">
            {previousPost && (
              <a href={`/blog/${previousPost.slug}`} class="rounded-xl border p-4 transition-colors hover:border-[var(--border-strong)]" style="border-color: var(--border);">
                <div class="mono mb-2">이전 글</div>
                <strong class="text-base leading-[1.35]" style="color: var(--text);">{previousPost.title}</strong>
              </a>
            )}
            {nextPost && (
              <a href={`/blog/${nextPost.slug}`} class="rounded-xl border p-4 transition-colors hover:border-[var(--border-strong)]" style="border-color: var(--border);">
                <div class="mono mb-2">다음 글</div>
                <strong class="text-base leading-[1.35]" style="color: var(--text);">{nextPost.title}</strong>
              </a>
            )}
          </div>
        </section>
      )}

      {relatedPosts.length > 0 && (
        <section class="mt-4">
          <hr class="rule" />
          <div class="eyebrow my-7 mb-3">관련 글</div>
          <div class="flex flex-col">
            {relatedPosts.slice(0, 3).map((post, index) => (
              <>
                {index > 0 && <hr class="rule" />}
                <PostCard
                  title={post.title}
                  description={post.description}
                  slug={post.slug}
                  pubDate={post.pubDate || pubDate}
                  variant="compact"
                />
              </>
            ))}
          </div>
        </section>
      )}

      <div class="mt-10 border-t pt-5" style="border-color: var(--border);">
        <Comments client:load />
      </div>
    </div>
  </main>

  <Footer />
</BaseLayout>
