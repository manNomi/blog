---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter';
import Comments from '../components/Comments';
import ShareButtons from '../components/ShareButtons.astro';
import Footer from '../components/Footer.astro';

type NavPost = { title: string; slug: string } | null;
type RelatedPost = { title: string; slug: string; description?: string };
type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  readingTime: number;
  previousPost?: NavPost;
  nextPost?: NavPost;
  relatedPosts?: RelatedPost[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  slug,
  readingTime,
  previousPost = null,
  nextPost = null,
  relatedPosts = []
} = Astro.props as Props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
}).format(pubDate);

const formattedUpdatedDate = updatedDate
  ? new Intl.DateTimeFormat('ko-KR', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(updatedDate)
  : null;

const articleBodyClass = [
  'article-body min-w-0 text-[16px] leading-[1.72] text-zinc-800 md:text-[17px] md:leading-[1.78]',
  '[&_h1]:mt-10 [&_h1]:mb-3 [&_h1]:text-[32px] [&_h1]:font-semibold [&_h1]:leading-[1.16] [&_h1]:tracking-[-0.02em] md:[&_h1]:text-[44px]',
  '[&_h2]:mt-9 [&_h2]:mb-3 [&_h2]:text-[28px] [&_h2]:font-semibold [&_h2]:leading-[1.2] [&_h2]:tracking-[-0.01em] md:[&_h2]:text-[34px]',
  '[&_h3]:mt-8 [&_h3]:mb-2.5 [&_h3]:text-[24px] [&_h3]:font-semibold [&_h3]:leading-[1.24] md:[&_h3]:text-[28px]',
  '[&_h4]:mt-7 [&_h4]:mb-2 [&_h4]:text-[21px] [&_h4]:font-semibold [&_h4]:leading-[1.26]',
  '[&_h5]:mt-7 [&_h5]:mb-2 [&_h5]:text-[19px] [&_h5]:font-semibold [&_h5]:leading-[1.26]',
  '[&_h6]:mt-7 [&_h6]:mb-2 [&_h6]:text-[18px] [&_h6]:font-semibold [&_h6]:leading-[1.26]',
  '[&_p]:mb-3 [&_p:empty]:hidden',
  '[&_ul]:mb-3 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:mb-3 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:mb-1',
  '[&_a]:border-b [&_a]:border-zinc-400 [&_a]:text-zinc-900 hover:[&_a]:border-zinc-900',
  '[&_blockquote]:my-4 [&_blockquote]:border-l-[3px] [&_blockquote]:border-zinc-400 [&_blockquote]:pl-4 [&_blockquote]:text-zinc-600',
  '[&_code]:font-mono [&_code]:text-[0.9em] [&_:not(pre)>code]:rounded [&_:not(pre)>code]:border [&_:not(pre)>code]:border-zinc-300 [&_:not(pre)>code]:bg-zinc-100 [&_:not(pre)>code]:px-1.5 [&_:not(pre)>code]:py-0.5',
  '[&_pre]:my-5 [&_pre]:overflow-x-auto [&_pre]:rounded-md [&_pre]:border [&_pre]:border-zinc-700 [&_pre]:!bg-zinc-900 [&_pre]:p-4 [&_pre]:shadow-soft',
  '[&_pre.astro-code]:!bg-zinc-900 [&_pre.astro-code]:[--shiki-background-color:#18181b] [&_pre.astro-code]:[--shiki-color:#e5e7eb]',
  '[&_pre_code]:text-[13px] [&_pre_code]:leading-[1.55] [&_pre_code]:text-zinc-100',
  '[&_img]:mx-auto [&_img]:my-5 [&_img]:rounded-md',
  '[&_table]:my-5 [&_table]:min-w-full [&_table]:w-max [&_table]:border-collapse [&_table]:text-[15px] [&_table]:leading-[1.5]',
  '[&_thead]:bg-zinc-100 [&_th]:border [&_th]:border-zinc-300 [&_th]:px-3 [&_th]:py-2.5 [&_th]:text-left [&_th]:font-semibold [&_td]:border [&_td]:border-zinc-300 [&_td]:px-3 [&_td]:py-2.5 [&_td]:text-left [&_td]:align-top',
  '[&_hr]:my-6 [&_hr]:border-0 [&_hr]:border-t [&_hr]:border-zinc-300'
].join(' ');
---

<BaseLayout title={`${title} - 한만욱의 이모저모`} description={description || '글 상세 페이지'} canonicalURL={`/blog/${slug}`}>
  <Header />

  <main class="main-shell">
    <article id="detail-root" class="mx-auto grid w-full max-w-[1080px] animate-fade-up gap-10 font-sans">
      <section class="page-card grid gap-4 px-4 py-5 md:gap-5 md:px-8 md:py-7">
        <div class="flex flex-wrap items-center justify-between gap-2 text-[13px] text-zinc-600">
          <a href="/posts" class="underline-offset-2 hover:underline">← 글 목록으로</a>
          <p>공유 · 북마크</p>
        </div>

        <div class="h-px w-full bg-zinc-200"></div>

        <p class="kicker text-zinc-600">개발 문화</p>
        <h1 class="text-balance text-[40px] font-semibold leading-[1.06] tracking-[-0.03em] text-zinc-900 md:text-[60px] lg:text-[72px]">{title}</h1>

        {description && <p class="max-w-[760px] text-[16px] leading-[1.5] text-zinc-700 md:text-[18px]">{description}</p>}

        <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-[12px] text-zinc-600">
          <time datetime={pubDate.toISOString()}>발행 {formattedDate}</time>
          {formattedUpdatedDate && <span>수정 {formattedUpdatedDate}</span>}
          <span>읽는 시간 {readingTime}분</span>
          <ViewCounter client:load slug={slug} />
        </div>

        <div class="flex flex-wrap items-center gap-2">
          {tags && tags.length > 0 ? (
            tags.map((tag) => (
              <a href={`/tags?tag=${tag}`} class="chip">#{tag}</a>
            ))
          ) : (
            <span class="chip">#개발문화</span>
          )}
        </div>
      </section>

      <section class="grid items-start gap-6 xl:grid-cols-[220px_minmax(0,1fr)] xl:gap-12">
        <aside class="page-card sticky top-24 hidden p-4 xl:block" aria-label="이 페이지 목차">
          <h2 class="text-[24px] font-semibold leading-tight tracking-[-0.01em] text-zinc-900">이 페이지 목차</h2>
          <div class="my-3 h-px w-full bg-zinc-300"></div>
          <ol class="grid gap-2 text-[13px] leading-[1.4] text-zinc-700" data-toc-list>
            <li>목차를 준비하고 있습니다…</li>
          </ol>
        </aside>

        <div class="min-w-0 grid gap-6">
          <details class="page-card xl:hidden">
            <summary class="cursor-pointer list-none px-4 py-3 text-sm font-semibold text-zinc-800">이 페이지 목차</summary>
            <div class="border-t border-line px-4 py-3">
              <ol class="grid gap-2 text-sm text-zinc-700" data-toc-list>
                <li>목차를 준비하고 있습니다…</li>
              </ol>
            </div>
          </details>

          <div class={articleBodyClass}>
            <slot />
          </div>

          <div class="page-card flex flex-col gap-3 px-4 py-3 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-[13px] text-zinc-700">공유 · 댓글 · 구독</p>
            <ShareButtons title={title} url={`/blog/${slug}`} />
          </div>
        </div>
      </section>

      <section class="grid gap-5 md:gap-6">
        <div class="grid gap-3 md:grid-cols-2 md:gap-5">
          <a href={previousPost ? `/blog/${previousPost.slug}` : '/posts'} class="grid min-h-[76px] content-center gap-1.5 rounded-card border border-line bg-soft px-4 py-4 transition hover:border-zinc-400">
            <span class="text-[11px] text-zinc-500">이전 글</span>
            <strong class="text-[16px] leading-[1.3] text-zinc-900 md:text-[18px]">{previousPost?.title || '전체 글 보기'}</strong>
          </a>

          <a
            href={nextPost ? `/blog/${nextPost.slug}` : '/posts'}
            class="grid min-h-[76px] content-center gap-1.5 rounded-card border border-zinc-900 bg-zinc-900 px-4 py-4 transition hover:bg-zinc-800"
          >
            <span class="text-[11px] text-zinc-400">다음 글</span>
            <strong class="text-[16px] leading-[1.3] text-white md:text-[18px]">{nextPost?.title || '다음 글 보러가기'}</strong>
          </a>
        </div>

        <h2 class="text-[22px] font-semibold leading-tight tracking-[-0.01em] text-zinc-900 md:text-[26px]">관련 글</h2>

        <div class="grid gap-3 md:grid-cols-3 md:gap-4">
          {(relatedPosts.length > 0 ? relatedPosts : [{ title: '아직 관련 글이 없습니다', slug: 'posts' }]).slice(0, 3).map((post) => (
            <a href={post.slug === 'posts' ? '/posts' : `/blog/${post.slug}`} class="grid gap-2 rounded-card border border-line bg-surface p-3 transition hover:border-zinc-400">
              <div class="h-[100px] rounded-md border border-zinc-300 bg-zinc-200 md:h-[120px]"></div>
              <p class="text-[14px] font-semibold leading-[1.35] text-zinc-900">{post.title}</p>
            </a>
          ))}
        </div>

        <div class="page-card flex flex-col gap-2 px-4 py-3 text-xs text-zinc-700 md:flex-row md:items-center md:justify-between md:text-[13px]">
          <p>공유 · 댓글 · 구독</p>
          <p>댓글 보기</p>
        </div>

        <div class="border-t border-line pt-4">
          <Comments client:load />
        </div>
      </section>
    </article>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  const parseUrl = (value) => {
    try {
      return new URL(value);
    } catch {
      return null;
    }
  };

  const getVideoEmbedUrl = (href) => {
    const parsed = parseUrl(href);
    if (!parsed) return '';

    const host = parsed.hostname.replace(/^www\./, '');

    if (host === 'youtu.be') {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
    }

    if (host === 'youtube.com' || host.endsWith('.youtube.com')) {
      if (parsed.pathname === '/watch') {
        const videoId = parsed.searchParams.get('v');
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/shorts/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/embed/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
    }

    if (host === 'vimeo.com' || host.endsWith('.vimeo.com')) {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      if (videoId && /^\d+$/.test(videoId)) {
        return `https://player.vimeo.com/video/${videoId}`;
      }
    }

    return '';
  };

  const isStandaloneExternalLinkParagraph = (paragraph) => {
    if (!paragraph || paragraph.tagName !== 'P') return false;
    if (paragraph.closest('li, blockquote, td, th')) return false;
    if (paragraph.children.length !== 1 || paragraph.firstElementChild?.tagName !== 'A') return false;

    const inlineText = Array.from(paragraph.childNodes)
      .filter((node) => node.nodeType === Node.TEXT_NODE)
      .map((node) => node.textContent || '')
      .join('')
      .trim();

    if (inlineText) return false;

    const href = paragraph.firstElementChild.getAttribute('href') || '';
    return /^https?:\/\//.test(href);
  };

  const slugify = (text) =>
    text
      .toLowerCase()
      .trim()
      .replace(/[^\w\s가-힣-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');

  const articleBody = document.querySelector('.article-body');
  const tocLists = Array.from(document.querySelectorAll('[data-toc-list]'));
  const floatingTocToggle = document.querySelector('[data-floating-toc-toggle]');
  const floatingTocPanel = document.querySelector('[data-floating-toc-panel]');
  const floatingTocBackdrop = document.querySelector('[data-floating-toc-backdrop]');
  const floatingTocClose = document.querySelector('[data-floating-toc-close]');
  const floatingTocQuery = window.matchMedia('(max-width: 1360px) and (min-width: 1025px)');

  const setFloatingTocOpen = (open) => {
    if (!floatingTocPanel || !floatingTocBackdrop || !floatingTocToggle) return;
    floatingTocPanel.setAttribute('data-open', open ? 'true' : 'false');
    floatingTocBackdrop.setAttribute('data-open', open ? 'true' : 'false');
    floatingTocToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    floatingTocToggle.textContent = open ? '목차 닫기' : '목차 보기';
  };

  const syncFloatingTocVisibility = () => {
    if (!floatingTocToggle) return;
    if (floatingTocQuery.matches) {
      floatingTocToggle.style.display = '';
      return;
    }

    floatingTocToggle.style.display = 'none';
    setFloatingTocOpen(false);
  };

  floatingTocToggle?.addEventListener('click', () => {
    const nextOpen = floatingTocPanel?.getAttribute('data-open') !== 'true';
    setFloatingTocOpen(nextOpen);
  });

  floatingTocBackdrop?.addEventListener('click', () => setFloatingTocOpen(false));
  floatingTocClose?.addEventListener('click', () => setFloatingTocOpen(false));

  floatingTocPanel?.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof HTMLAnchorElement) {
      setFloatingTocOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setFloatingTocOpen(false);
    }
  });

  syncFloatingTocVisibility();
  if (typeof floatingTocQuery.addEventListener === 'function') {
    floatingTocQuery.addEventListener('change', syncFloatingTocVisibility);
  }

  if (articleBody) {
    for (const table of articleBody.querySelectorAll('table')) {
      if (table.parentElement?.classList.contains('table-scroll')) {
        continue;
      }
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll my-5 overflow-x-auto rounded-md border border-zinc-300 bg-white';
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    }

    for (const paragraph of articleBody.querySelectorAll('p')) {
      if (!isStandaloneExternalLinkParagraph(paragraph)) continue;

      const anchor = paragraph.firstElementChild;
      const href = anchor?.getAttribute('href')?.trim() || '';
      if (!href) continue;

      const embedUrl = getVideoEmbedUrl(href);
      if (embedUrl) {
        const frame = document.createElement('iframe');
        frame.src = embedUrl;
        frame.loading = 'lazy';
        frame.allowFullscreen = true;
        frame.referrerPolicy = 'strict-origin-when-cross-origin';
        frame.title = anchor?.textContent?.trim() || '삽입된 동영상';

        const wrapper = document.createElement('figure');
        wrapper.className = 'my-5 overflow-hidden rounded-md border border-zinc-300 bg-zinc-100';
        frame.className = 'block aspect-video w-full border-0';
        wrapper.appendChild(frame);
        paragraph.replaceWith(wrapper);
        continue;
      }

      const parsed = parseUrl(href);
      const domain = parsed?.hostname?.replace(/^www\./, '') || href;

      const card = document.createElement('a');
      card.className =
        'my-5 flex flex-col gap-1.5 rounded-md border border-zinc-300 bg-zinc-50 p-3.5 text-zinc-800 transition hover:border-zinc-400';
      card.href = href;
      card.target = '_blank';
      card.rel = 'noopener noreferrer';

      const title = document.createElement('span');
      title.className = 'text-[15px] font-semibold leading-[1.35] break-all';
      title.textContent = anchor?.textContent?.trim() || href;

      const meta = document.createElement('span');
      meta.className = 'text-[13px] text-zinc-500 break-all';
      meta.textContent = domain;

      card.appendChild(title);
      card.appendChild(meta);
      paragraph.replaceWith(card);
    }

    const headings = Array.from(articleBody.querySelectorAll('h2, h3'));
    tocLists.forEach((tocList) => {
      tocList.innerHTML = '';

      if (headings.length === 0) {
        const fallback = document.createElement('li');
        fallback.textContent = '목차가 없습니다';
        tocList.appendChild(fallback);
        return;
      }

      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = `${slugify(heading.textContent || `section-${index + 1}`)}-${index + 1}`;
        }

        const item = document.createElement('li');
        item.className = heading.tagName === 'H3' ? 'pl-3 text-zinc-500' : '';

        const anchor = document.createElement('a');
        anchor.href = `#${heading.id}`;
        anchor.textContent = `${index + 1}. ${heading.textContent || '제목 없는 섹션'}`;
        anchor.className = 'hover:underline underline-offset-2';

        item.appendChild(anchor);
        tocList.appendChild(item);
      });
    });

    const mermaidCodeBlocks = Array.from(articleBody.querySelectorAll('pre code.language-mermaid'));
    if (mermaidCodeBlocks.length > 0) {
      import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
        .then(({ default: mermaid }) => {
          const nodes = [];

          for (const code of mermaidCodeBlocks) {
            const pre = code.closest('pre');
            if (!pre) continue;

            const diagram = document.createElement('div');
            diagram.className = 'mermaid my-5 overflow-x-auto rounded-md border border-zinc-300 bg-white p-3';
            diagram.textContent = code.textContent || '';
            pre.replaceWith(diagram);
            nodes.push(diagram);
          }

          if (nodes.length === 0) return;

          mermaid.initialize({
            startOnLoad: false,
            securityLevel: 'loose',
            theme: 'neutral'
          });

          mermaid.run({ nodes });
        })
        .catch(() => {
          // keep original code block if mermaid fails
        });
    }
  }
</script>
