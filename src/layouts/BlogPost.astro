---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter';
import Comments from '../components/Comments';
import ShareButtons from '../components/ShareButtons.astro';
import Footer from '../components/Footer.astro';

type NavPost = { title: string; slug: string } | null;
type RelatedPost = { title: string; slug: string; description?: string };
type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  readingTime: number;
  previousPost?: NavPost;
  nextPost?: NavPost;
  relatedPosts?: RelatedPost[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags,
  slug,
  readingTime,
  previousPost = null,
  nextPost = null,
  relatedPosts = []
} = Astro.props as Props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
}).format(pubDate);

const formattedUpdatedDate = updatedDate
  ? new Intl.DateTimeFormat('ko-KR', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(updatedDate)
  : null;
---

<BaseLayout
  title={`${title} - Nomi Journal`}
  description={description || 'Editorial detail page'}
  image={heroImage}
  canonicalURL={`/blog/${slug}`}
>
  <Header />

  <main class="main-shell detail-main">
    <article class="detail-article font-basic">
      <section class="detail-top page-card">
        <div class="detail-top__nav">
          <a href="/posts">← Back to Articles</a>
          <p>Share · Bookmark</p>
        </div>

        <div class="detail-top__rule"></div>

        <p class="kicker detail-top__category">개발 문화</p>

        <h1 class="detail-top__title">{title}</h1>

        {description && <p class="detail-top__dek">{description}</p>}

        <div class="detail-top__meta">
          <time datetime={pubDate.toISOString()}>발행 {formattedDate}</time>
          {formattedUpdatedDate && <span>수정 {formattedUpdatedDate}</span>}
          <span>읽는 시간 {readingTime}분</span>
          <ViewCounter client:load slug={slug} />
        </div>

        <div class="detail-top__hero">
          {heroImage ? (
            <img src={heroImage} alt={title} loading="lazy" />
          ) : (
            <p>HERO IMAGE PLACEHOLDER</p>
          )}
        </div>

        <div class="detail-top__tag-row">
          {tags && tags.length > 0 ? (
            tags.map((tag) => (
              <a href={`/posts?tag=${tag}`} class="chip">#{tag}</a>
            ))
          ) : (
            <span class="chip">#editorial</span>
          )}
        </div>
      </section>

      <section class="detail-body">
        <aside class="detail-toc" aria-label="On this page">
          <h2>On this page</h2>
          <div class="detail-toc__rule"></div>
          <ol data-toc-list>
            <li>Preparing sections…</li>
          </ol>

          <div class="detail-font-toggle">
            <button type="button" data-font-toggle aria-pressed="true">Use Newspaper Font</button>
          </div>
        </aside>

        <div class="detail-content">
          <div class="detail-content__intro">{description || 'The detail body is designed as a calm reading field where each section breathes.'}</div>

          <div class="article-body">
            <slot />
          </div>

          <div class="detail-content__share-row page-card">
            <p>Share · Comment · Subscribe</p>
            <ShareButtons title={title} url={`/blog/${slug}`} />
          </div>
        </div>
      </section>

      <button
        type="button"
        class="detail-floating-toc-toggle"
        data-floating-toc-toggle
        aria-expanded="false"
        aria-controls="detail-floating-toc-panel"
      >
        목차 보기
      </button>

      <div class="detail-floating-toc-backdrop" data-floating-toc-backdrop data-open="false"></div>

      <aside
        id="detail-floating-toc-panel"
        class="detail-floating-toc-panel"
        data-floating-toc-panel
        data-open="false"
        aria-label="Floating table of contents"
      >
        <div class="detail-floating-toc-panel__header">
          <h2>On this page</h2>
          <button type="button" data-floating-toc-close>닫기</button>
        </div>
        <div class="detail-toc__rule"></div>
        <ol data-floating-toc-list>
          <li>Preparing sections…</li>
        </ol>
      </aside>

      <section class="detail-bottom">
        <div class="detail-bottom__nav-row">
          <a class="detail-nav-card" href={previousPost ? `/blog/${previousPost.slug}` : '/posts'}>
            <span>Previous</span>
            <strong>{previousPost?.title || 'View all posts'}</strong>
          </a>
          <a class="detail-nav-card detail-nav-card--dark" href={nextPost ? `/blog/${nextPost.slug}` : '/posts'}>
            <span>Next</span>
            <strong>{nextPost?.title || 'Explore next story'}</strong>
          </a>
        </div>

        <h2>Related Stories</h2>

        <div class="detail-related-grid">
          {(relatedPosts.length > 0 ? relatedPosts : [{ title: 'No related stories yet', slug: 'posts' }]).slice(0, 3).map((post) => (
            <a href={post.slug === 'posts' ? '/posts' : `/blog/${post.slug}`} class="detail-related-card">
              <div class="detail-related-card__thumb"></div>
              <p>{post.title}</p>
            </a>
          ))}
        </div>

        <div class="detail-bottom__cta page-card">
          <p>Share · Comment · Subscribe</p>
          <p>댓글 보기</p>
        </div>

        <div class="detail-comments">
          <Comments client:load />
        </div>
      </section>
    </article>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  const parseUrl = (value) => {
    try {
      return new URL(value);
    } catch {
      return null;
    }
  };

  const getVideoEmbedUrl = (href) => {
    const parsed = parseUrl(href);
    if (!parsed) {
      return '';
    }

    const host = parsed.hostname.replace(/^www\./, '');

    if (host === 'youtu.be') {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
    }

    if (host === 'youtube.com' || host.endsWith('.youtube.com')) {
      if (parsed.pathname === '/watch') {
        const videoId = parsed.searchParams.get('v');
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/shorts/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/embed/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
    }

    if (host === 'vimeo.com' || host.endsWith('.vimeo.com')) {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      if (videoId && /^\d+$/.test(videoId)) {
        return `https://player.vimeo.com/video/${videoId}`;
      }
    }

    return '';
  };

  const isStandaloneExternalLinkParagraph = (paragraph) => {
    if (!paragraph || paragraph.tagName !== 'P') {
      return false;
    }

    if (paragraph.closest('li, blockquote, td, th')) {
      return false;
    }

    if (paragraph.children.length !== 1 || paragraph.firstElementChild?.tagName !== 'A') {
      return false;
    }

    const inlineText = Array.from(paragraph.childNodes)
      .filter((node) => node.nodeType === Node.TEXT_NODE)
      .map((node) => node.textContent || '')
      .join('')
      .trim();

    if (inlineText) {
      return false;
    }

    const href = paragraph.firstElementChild.getAttribute('href') || '';
    return /^https?:\/\//.test(href);
  };

  const slugify = (text) =>
    text
      .toLowerCase()
      .trim()
      .replace(/[^\w\s가-힣-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');

  const articleBody = document.querySelector('.article-body');
  const articleRoot = document.querySelector('.detail-article');
  const tocList = document.querySelector('[data-toc-list]');
  const floatingTocList = document.querySelector('[data-floating-toc-list]');
  const fontToggleButton = document.querySelector('[data-font-toggle]');
  const floatingTocToggle = document.querySelector('[data-floating-toc-toggle]');
  const floatingTocPanel = document.querySelector('[data-floating-toc-panel]');
  const floatingTocBackdrop = document.querySelector('[data-floating-toc-backdrop]');
  const floatingTocClose = document.querySelector('[data-floating-toc-close]');
  const FONT_MODE_KEY = 'blog_detail_font_mode';
  const floatingTocQuery = window.matchMedia('(max-width: 1360px) and (min-width: 1025px)');

  const setFloatingTocOpen = (open) => {
    if (!floatingTocPanel || !floatingTocBackdrop || !floatingTocToggle) return;
    floatingTocPanel.setAttribute('data-open', open ? 'true' : 'false');
    floatingTocBackdrop.setAttribute('data-open', open ? 'true' : 'false');
    floatingTocToggle.setAttribute('aria-expanded', open ? 'true' : 'false');
    floatingTocToggle.textContent = open ? '목차 닫기' : '목차 보기';
  };

  const syncFloatingTocVisibility = () => {
    if (!floatingTocToggle) return;
    if (floatingTocQuery.matches) {
      floatingTocToggle.style.display = '';
      return;
    }

    floatingTocToggle.style.display = 'none';
    setFloatingTocOpen(false);
  };

  const applyFontMode = (mode) => {
    if (!articleRoot || !fontToggleButton) return;

    const useBasic = mode === 'basic';
    articleRoot.classList.toggle('font-basic', useBasic);
    fontToggleButton.setAttribute('aria-pressed', useBasic ? 'true' : 'false');
    fontToggleButton.textContent = useBasic ? 'Use Newspaper Font' : 'Use Basic Font';
  };

  const readSavedFontMode = () => {
    try {
      const saved = window.localStorage.getItem(FONT_MODE_KEY);
      return saved === 'newspaper' ? 'newspaper' : 'basic';
    } catch {
      return 'basic';
    }
  };

  const saveFontMode = (mode) => {
    try {
      window.localStorage.setItem(FONT_MODE_KEY, mode);
    } catch {
      // ignore storage failure
    }
  };

  applyFontMode(readSavedFontMode());

  fontToggleButton?.addEventListener('click', () => {
    const nextMode = articleRoot?.classList.contains('font-basic') ? 'newspaper' : 'basic';
    applyFontMode(nextMode);
    saveFontMode(nextMode);
  });

  floatingTocToggle?.addEventListener('click', () => {
    const nextOpen = floatingTocPanel?.getAttribute('data-open') !== 'true';
    setFloatingTocOpen(nextOpen);
  });

  floatingTocBackdrop?.addEventListener('click', () => setFloatingTocOpen(false));
  floatingTocClose?.addEventListener('click', () => setFloatingTocOpen(false));

  floatingTocPanel?.addEventListener('click', (event) => {
    const target = event.target;
    if (target instanceof HTMLAnchorElement) {
      setFloatingTocOpen(false);
    }
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') {
      setFloatingTocOpen(false);
    }
  });

  syncFloatingTocVisibility();
  if (typeof floatingTocQuery.addEventListener === 'function') {
    floatingTocQuery.addEventListener('change', syncFloatingTocVisibility);
  }

  if (articleBody) {
    for (const table of articleBody.querySelectorAll('table')) {
      if (table.parentElement?.classList.contains('table-scroll')) {
        continue;
      }
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll';
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    }

    for (const paragraph of articleBody.querySelectorAll('p')) {
      if (!isStandaloneExternalLinkParagraph(paragraph)) {
        continue;
      }

      const anchor = paragraph.firstElementChild;
      const href = anchor?.getAttribute('href')?.trim() || '';
      if (!href) {
        continue;
      }

      const embedUrl = getVideoEmbedUrl(href);
      if (embedUrl) {
        const frame = document.createElement('iframe');
        frame.src = embedUrl;
        frame.loading = 'lazy';
        frame.allowFullscreen = true;
        frame.referrerPolicy = 'strict-origin-when-cross-origin';
        frame.title = anchor?.textContent?.trim() || 'Embedded video';

        const wrapper = document.createElement('figure');
        wrapper.className = 'notion-video-embed';
        wrapper.appendChild(frame);
        paragraph.replaceWith(wrapper);
        continue;
      }

      const parsed = parseUrl(href);
      const domain = parsed?.hostname?.replace(/^www\./, '') || href;

      const card = document.createElement('a');
      card.className = 'notion-link-card';
      card.href = href;
      card.target = '_blank';
      card.rel = 'noopener noreferrer';

      const title = document.createElement('span');
      title.className = 'notion-link-card-title';
      title.textContent = anchor?.textContent?.trim() || href;

      const meta = document.createElement('span');
      meta.className = 'notion-link-card-meta';
      meta.textContent = domain;

      card.appendChild(title);
      card.appendChild(meta);
      paragraph.replaceWith(card);
    }

    const headings = Array.from(articleBody.querySelectorAll('h2, h3'));
    const tocLists = [tocList, floatingTocList].filter(Boolean);

    for (const list of tocLists) {
      list.innerHTML = '';

      if (headings.length === 0) {
        const fallback = document.createElement('li');
        fallback.textContent = 'No sections detected';
        list.appendChild(fallback);
        continue;
      }

      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = `${slugify(heading.textContent || `section-${index + 1}`)}-${index + 1}`;
        }

        const item = document.createElement('li');
        if (heading.tagName === 'H3') item.classList.add('is-sub');

        const anchor = document.createElement('a');
        anchor.href = `#${heading.id}`;
        anchor.textContent = `${index + 1}. ${heading.textContent || 'Untitled section'}`;

        item.appendChild(anchor);
        list.appendChild(item);
      });
    }

    const mermaidCodeBlocks = Array.from(articleBody.querySelectorAll('pre code.language-mermaid'));
    if (mermaidCodeBlocks.length > 0) {
      import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
        .then(({ default: mermaid }) => {
          const nodes = [];

          for (const code of mermaidCodeBlocks) {
            const pre = code.closest('pre');
            if (!pre) continue;

            const diagram = document.createElement('div');
            diagram.className = 'mermaid';
            diagram.textContent = code.textContent || '';
            pre.replaceWith(diagram);
            nodes.push(diagram);
          }

          if (nodes.length === 0) return;

          mermaid.initialize({
            startOnLoad: false,
            securityLevel: 'loose',
            theme: 'neutral'
          });

          mermaid.run({ nodes });
        })
        .catch(() => {
          // keep original code block if mermaid fails
        });
    }
  }
</script>

<style>
  .detail-article {
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
    --detail-font-serif: var(--font-serif);
    --detail-font-body: var(--font-sans);
  }

  .detail-article.font-basic {
    --detail-font-serif: var(--font-sans);
    --detail-font-body: var(--font-sans);
  }

  .detail-top {
    padding: 28px 40px;
    box-shadow: var(--shadow-card);
    display: grid;
    gap: 20px;
  }

  .detail-top__nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: 13px;
    color: #444;
  }

  .detail-top__nav a:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .detail-top__rule {
    width: 100%;
    height: 1px;
    background: #e8e8e8;
  }

  .detail-top__category {
    color: #4b4b4b;
  }

  .detail-top__title {
    font-family: var(--detail-font-serif);
    color: var(--text-strong);
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.05;
    letter-spacing: -0.03em;
  }

  .detail-top__dek {
    color: #3a3a3a;
    font-size: 18px;
    line-height: 1.45;
    max-width: 760px;
  }

  .detail-top__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 20px;
    font-size: 12px;
    color: #5f5f5f;
  }

  .detail-top__hero {
    width: 100%;
    min-height: 320px;
    border-radius: var(--radius-md);
    border: 1px solid #d9d9d9;
    background: linear-gradient(90deg, #ededed 0%, #dcdcdc 100%);
    box-shadow: var(--shadow-soft);
    overflow: hidden;
    display: grid;
    place-items: center;
  }

  .detail-top__hero img {
    width: 100%;
    height: 320px;
    object-fit: cover;
  }

  .detail-top__hero p {
    color: #7a7a7a;
    letter-spacing: 0.08em;
    font-size: 12px;
    font-weight: 600;
  }

  .detail-top__tag-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .detail-body {
    margin-top: 96px;
    display: grid;
    grid-template-columns: minmax(0, 220px) minmax(0, 1fr);
    gap: 48px;
    align-items: start;
    min-width: 0;
  }

  .detail-toc {
    position: sticky;
    top: calc(var(--header-height) + 20px);
    padding: 0;
    min-width: 0;
  }

  .detail-toc h2 {
    color: var(--text-strong);
    font-size: 18px;
    line-height: 1.2;
  }

  .detail-toc__rule {
    width: 100%;
    height: 1px;
    background: #d0d0d0;
    margin: 16px 0;
  }

  .detail-toc ol {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 12px;
  }

  .detail-toc li {
    color: #2a2a2a;
    font-size: 13px;
    line-height: 1.35;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .detail-toc li.is-sub {
    padding-left: 12px;
    color: #595959;
  }

  .detail-toc a {
    display: block;
    min-width: 0;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .detail-toc a:hover {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .detail-font-toggle {
    margin-top: 22px;
  }

  .detail-font-toggle button {
    width: 100%;
    height: 34px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--line-default);
    background: var(--bg-soft);
    font-size: 12px;
    color: #333;
  }

  .detail-font-toggle button[aria-pressed='false'] {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  .detail-content {
    min-width: 0;
    display: grid;
    gap: 30px;
  }

  .detail-content__intro {
    font-family: var(--detail-font-serif);
    color: #111;
    font-size: 28px;
    line-height: 1.25;
  }

  .article-body {
    font-family: var(--detail-font-body);
    color: #222;
    font-size: 17px;
    line-height: 1.7;
    word-break: keep-all;
  }

  .article-body :global(h1),
  .article-body :global(h2),
  .article-body :global(h3),
  .article-body :global(h4),
  .article-body :global(h5),
  .article-body :global(h6) {
    font-family: var(--detail-font-serif);
    color: #111;
    letter-spacing: -0.01em;
  }

  .article-body :global(h1) {
    margin-top: 46px;
    margin-bottom: 14px;
    font-size: 44px;
    line-height: 1.15;
  }

  .article-body :global(h2) {
    margin-top: 44px;
    margin-bottom: 14px;
    font-size: 34px;
    line-height: 1.2;
  }

  .article-body :global(h3) {
    margin-top: 36px;
    margin-bottom: 12px;
    font-size: 28px;
    line-height: 1.24;
  }

  .article-body :global(h4),
  .article-body :global(h5),
  .article-body :global(h6) {
    margin-top: 28px;
    margin-bottom: 10px;
    font-size: 22px;
    line-height: 1.28;
  }

  .article-body :global(p) {
    margin-bottom: 10px;
  }

  .article-body :global(p:empty) {
    display: none;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 12px;
    padding-left: 22px;
  }

  .article-body :global(li) {
    margin-bottom: 5px;
  }

  .article-body :global(a) {
    color: #1f1f1f;
    border-bottom: 1px solid #b8b8b8;
  }

  .article-body :global(a:hover) {
    border-bottom-color: #111;
  }

  .article-body :global(blockquote) {
    margin: 18px 0;
    padding-left: 14px;
    border-left: 3px solid #bdbdbd;
    color: #505050;
  }

  .article-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.86em;
    background: #efefef;
    border: 1px solid #d8d8d8;
    border-radius: 6px;
    padding: 0.1em 0.35em;
  }

  .article-body :global(pre),
  .article-body :global(pre.astro-code) {
    margin: 18px 0;
    padding: 20px;
    background: #0d1117 !important;
    border: 1px solid #30363d;
    border-radius: var(--radius-sm);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .article-body :global(pre code),
  .article-body :global(pre.astro-code code) {
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.5;
    color: #e6edf3;
    white-space: pre;
  }

  .article-body :global(pre.astro-code .line),
  .article-body :global(pre.astro-code .line span) {
    border: 0 !important;
    text-decoration: none !important;
  }

  .article-body :global(.table-scroll) {
    margin: 18px 0;
    overflow-x: auto;
    border: 1px solid #dcdcdc;
    border-radius: var(--radius-sm);
    background: #fff;
  }

  .article-body :global(.table-scroll table) {
    margin: 0;
    min-width: 100%;
    width: max-content;
    border-collapse: collapse;
    font-size: 15px;
    line-height: 1.5;
  }

  .article-body :global(.table-scroll th),
  .article-body :global(.table-scroll td) {
    border: 1px solid #d7d7d7;
    padding: 10px 12px;
    text-align: left;
    vertical-align: top;
  }

  .article-body :global(.table-scroll th) {
    background: #f3f3f3;
    font-weight: 700;
  }

  .article-body :global(a.notion-link-card) {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 18px 0;
    padding: 14px;
    border: 1px solid #dcdcdc;
    border-radius: var(--radius-sm);
    background: #fafafa;
    color: #222;
