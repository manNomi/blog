---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter';
import Comments from '../components/Comments';
import ShareButtons from '../components/ShareButtons.astro';
import Footer from '../components/Footer.astro';

type Props = CollectionEntry<'blog'>['data'] & { slug: string; readingTime: number };

const { title, description, pubDate, updatedDate, heroImage, tags, slug, readingTime } = Astro.props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
}).format(pubDate);
---

<BaseLayout
  title={`${title} - 한만욱`}
  description={description}
  image={heroImage}
  canonicalURL={`/blog/${slug}`}
>
  <Header />

  <main class="main">
    <article class="article">
      <div class="content">
        <header class="article-header">
          <h1 class="article-title">{title}</h1>

          <div class="article-meta">
            <time datetime={pubDate.toISOString()}>{formattedDate}</time>
            <span class="reading-time">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="10" />
                <polyline points="12 6 12 12 16 14" />
              </svg>
              <span>{readingTime}분 남짓</span>
            </span>
            <ViewCounter client:load slug={slug} />
            {updatedDate && (
              <span class="updated">
                고침 {new Intl.DateTimeFormat('ko-KR', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                }).format(updatedDate)}
              </span>
            )}
          </div>

          <div class="font-toggle-row">
            <button type="button" class="font-toggle-button" data-font-toggle aria-pressed="false">
              신문체 끄기
            </button>
          </div>

          {tags && tags.length > 0 && (
            <div class="tags">
              {tags.map(tag => (
                <a href={`/posts?tag=${tag}`} class="tag">{tag}</a>
              ))}
            </div>
          )}
        </header>

        <div class="article-body">
          <slot />
        </div>

        <div class="share-section">
          <ShareButtons title={title} url={`/blog/${slug}`} />
        </div>

        <div class="comments-section">
          <Comments client:load />
        </div>
      </div>
    </article>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  const parseUrl = (value) => {
    try {
      return new URL(value);
    } catch {
      return null;
    }
  };

  const getVideoEmbedUrl = (href) => {
    const parsed = parseUrl(href);
    if (!parsed) {
      return '';
    }

    const host = parsed.hostname.replace(/^www\./, '');

    if (host === 'youtu.be') {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
    }

    if (host === 'youtube.com' || host.endsWith('.youtube.com')) {
      if (parsed.pathname === '/watch') {
        const videoId = parsed.searchParams.get('v');
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/shorts/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/embed/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
    }

    if (host === 'vimeo.com' || host.endsWith('.vimeo.com')) {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      if (videoId && /^\d+$/.test(videoId)) {
        return `https://player.vimeo.com/video/${videoId}`;
      }
    }

    return '';
  };

  const isStandaloneExternalLinkParagraph = (paragraph) => {
    if (!paragraph || paragraph.tagName !== 'P') {
      return false;
    }

    if (paragraph.closest('li, blockquote, td, th')) {
      return false;
    }

    if (paragraph.children.length !== 1 || paragraph.firstElementChild?.tagName !== 'A') {
      return false;
    }

    const inlineText = Array.from(paragraph.childNodes)
      .filter((node) => node.nodeType === Node.TEXT_NODE)
      .map((node) => node.textContent || '')
      .join('')
      .trim();

    if (inlineText) {
      return false;
    }

    const href = paragraph.firstElementChild.getAttribute('href') || '';
    return /^https?:\/\//.test(href);
  };

  const articleBody = document.querySelector('.article-body');
  const articleRoot = document.querySelector('.article');
  const fontToggleButton = document.querySelector('[data-font-toggle]');
  const FONT_MODE_KEY = 'blog_detail_font_mode';

  const applyFontMode = (mode) => {
    if (!articleRoot || !fontToggleButton) {
      return;
    }

    const useBasicFont = mode === 'basic';
    articleRoot.classList.toggle('font-basic', useBasicFont);
    fontToggleButton.setAttribute('aria-pressed', useBasicFont ? 'true' : 'false');
    fontToggleButton.textContent = useBasicFont ? '신문체 켜기' : '신문체 끄기';
  };

  const readSavedFontMode = () => {
    try {
      const saved = window.localStorage.getItem(FONT_MODE_KEY);
      return saved === 'basic' ? 'basic' : 'newspaper';
    } catch {
      return 'newspaper';
    }
  };

  const saveFontMode = (mode) => {
    try {
      window.localStorage.setItem(FONT_MODE_KEY, mode);
    } catch {
      // 저장 실패 시 조용히 무시
    }
  };

  applyFontMode(readSavedFontMode());

  fontToggleButton?.addEventListener('click', () => {
    const nextMode = articleRoot?.classList.contains('font-basic') ? 'newspaper' : 'basic';
    applyFontMode(nextMode);
    saveFontMode(nextMode);
  });

  if (articleBody) {
    for (const table of articleBody.querySelectorAll('table')) {
      if (table.parentElement?.classList.contains('table-scroll')) {
        continue;
      }
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll';
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    }

    for (const paragraph of articleBody.querySelectorAll('p')) {
      if (!isStandaloneExternalLinkParagraph(paragraph)) {
        continue;
      }

      const anchor = paragraph.firstElementChild;
      const href = anchor?.getAttribute('href')?.trim() || '';
      if (!href) {
        continue;
      }

      const embedUrl = getVideoEmbedUrl(href);
      if (embedUrl) {
        const frame = document.createElement('iframe');
        frame.src = embedUrl;
        frame.loading = 'lazy';
        frame.allowFullscreen = true;
        frame.referrerPolicy = 'strict-origin-when-cross-origin';
        frame.title = anchor?.textContent?.trim() || '삽입된 영상';

        const wrapper = document.createElement('figure');
        wrapper.className = 'notion-video-embed';
        wrapper.appendChild(frame);
        paragraph.replaceWith(wrapper);
        continue;
      }

      const parsed = parseUrl(href);
      const domain = parsed?.hostname?.replace(/^www\./, '') || href;

      const card = document.createElement('a');
      card.className = 'notion-link-card';
      card.href = href;
      card.target = '_blank';
      card.rel = 'noopener noreferrer';

      const title = document.createElement('span');
      title.className = 'notion-link-card-title';
      title.textContent = anchor?.textContent?.trim() || href;

      const meta = document.createElement('span');
      meta.className = 'notion-link-card-meta';
      meta.textContent = domain;

      card.appendChild(title);
      card.appendChild(meta);
      paragraph.replaceWith(card);
    }

    const mermaidCodeBlocks = Array.from(articleBody.querySelectorAll('pre code.language-mermaid'));
    if (mermaidCodeBlocks.length > 0) {
      import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
        .then(({ default: mermaid }) => {
          const nodes = [];

          for (const code of mermaidCodeBlocks) {
            const pre = code.closest('pre');
            if (!pre) {
              continue;
            }

            const diagram = document.createElement('div');
            diagram.className = 'mermaid';
            diagram.textContent = code.textContent || '';
            pre.replaceWith(diagram);
            nodes.push(diagram);
          }

          if (nodes.length === 0) {
            return;
          }

          mermaid.initialize({
            startOnLoad: false,
            securityLevel: 'loose',
            theme: 'neutral'
          });

          mermaid.run({ nodes });
        })
        .catch(() => {
          // Mermaid 로딩 실패 시 기존 코드 블록 유지
        });
    }
  }
</script>

<style>
  .main {
    padding-top: calc(var(--header-height) + 1.5rem);
    padding-bottom: var(--space-3xl);
  }

  .article {
    max-width: 100%;
    --detail-font-serif: var(--font-serif);
    --detail-font-body: var(--font-sans);
  }

  .article.font-basic {
    --detail-font-serif: 'Noto Sans KR', 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
    --detail-font-body: 'Noto Sans KR', 'Apple SD Gothic Neo', 'Malgun Gothic', sans-serif;
  }

  .content {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 0 1rem;
  }

  .article-header {
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--divider);
  }

  .article-title {
    font-family: var(--detail-font-serif);
    font-size: clamp(2.05rem, 4vw, 2.9rem);
    line-height: 1.25;
    margin-bottom: 0.8rem;
    letter-spacing: -0.02em;
    color: var(--text-primary);
  }

  .font-toggle-row {
    margin-bottom: 0.75rem;
  }

  .font-toggle-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 32px;
    padding: 0 0.7rem;
    border: 1px solid var(--border-primary);
    border-radius: var(--radius-sm);
    background: var(--bg-secondary);
    color: var(--text-secondary);
    font-size: 0.76rem;
    font-weight: 700;
    line-height: 1;
    transition: border-color 0.15s ease, background-color 0.15s ease, color 0.15s ease;
  }

  .font-toggle-button:hover {
    border-color: var(--border-secondary);
    background: var(--bg-hover);
    color: var(--text-primary);
  }

  .font-toggle-button[aria-pressed='true'] {
    border-color: rgba(11, 110, 153, 0.28);
    background: #edf5f8;
    color: var(--accent-primary);
  }

  .article-meta {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin-bottom: 0.8rem;
    font-size: 0.82rem;
    color: var(--text-tertiary);
    flex-wrap: wrap;
  }

  .article-meta .reading-time {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .article-meta .reading-time::before {
    content: '•';
    margin-right: var(--space-sm);
  }

  .article-meta :global(.view-counter) {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
  }

  .article-meta :global(.view-counter)::before {
    content: '•';
    margin-right: var(--space-sm);
  }

  .updated::before {
    content: '•';
    margin-right: var(--space-md);
  }

  .tags {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
  }

  .tag {
    padding: 0.1rem 0.5rem;
    background-color: var(--bg-tag);
    border: 1px solid rgba(123, 118, 109, 0.44);
    border-radius: 999px;
    font-size: 0.78rem;
    color: var(--text-secondary);
    text-decoration: none;
    transition: background-color 0.15s ease, color 0.15s ease;
  }

  .tag:hover {
    background-color: #e6f3f8;
    color: var(--accent-primary);
  }

  .article-body {
    font-family: var(--detail-font-body);
    font-size: 1.08rem;
    line-height: 1.84;
    color: var(--text-primary);
    word-break: keep-all;
  }

  /* Markdown Styles */
  .article-body :global(h1) {
    font-family: var(--detail-font-serif);
    font-size: 2.2rem;
    margin-top: 2.8rem;
    margin-bottom: 1rem;
    line-height: 1.3;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .article-body :global(h2) {
    font-family: var(--detail-font-serif);
    font-size: 1.92rem;
    margin-top: 2.8rem;
    margin-bottom: 0.9rem;
    color: var(--text-primary);
    letter-spacing: -0.01em;
  }

  .article-body :global(h3) {
    font-family: var(--detail-font-serif);
    font-size: 1.46rem;
    margin-top: 1.8rem;
    margin-bottom: 0.6rem;
    color: var(--text-primary);
  }

  .article-body :global(h4) {
    font-family: var(--detail-font-serif);
    font-size: 1.2rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
  }

  .article-body :global(h5),
  .article-body :global(h6) {
    font-family: var(--detail-font-serif);
    font-size: 1.05rem;
    margin-top: 1.2rem;
    margin-bottom: 0.4rem;
    color: var(--text-primary);
  }

  .article-body :global(p) {
    margin-bottom: 0.95rem;
  }

  .article-body :global(a) {
    color: #7f3f17;
    text-decoration: none;
    border-bottom: 1px solid rgba(127, 63, 23, 0.42);
  }

  .article-body :global(a:hover) {
    color: #5e2d11;
    border-bottom-color: #5e2d11;
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.25rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .article-body :global(.contains-task-list) {
    list-style: none;
    padding-left: 0.2rem;
  }

  .article-body :global(.task-list-item) {
    list-style: none;
  }

  .article-body :global(.task-list-item input[type='checkbox']) {
    margin-right: 0.5rem;
    accent-color: #7f3f17;
    transform: translateY(1px);
  }

  .article-body :global(details) {
    margin: 1rem 0;
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    background: #f8f5ed;
    padding: 0.45rem 0.75rem;
  }

  .article-body :global(details > summary) {
    cursor: pointer;
    font-weight: 700;
    color: #5e2d11;
    list-style: none;
  }

  .article-body :global(details > summary::-webkit-details-marker) {
    display: none;
  }

  .article-body :global(details > summary::before) {
    content: '▸';
    display: inline-block;
    margin-right: 0.4rem;
    transition: transform 0.15s ease;
  }

  .article-body :global(details[open] > summary::before) {
    transform: rotate(90deg);
  }

  .article-body :global(details > *:not(summary)) {
    margin-top: 0.6rem;
  }

  .article-body :global(:not(pre) > code) {
    font-family: var(--font-mono);
    font-size: 0.84em;
    background-color: #c8c4ba;
    padding: 0.12em 0.35em;
    border-radius: var(--radius-sm);
    border: 1px solid #8f8a80;
  }

  .article-body :global(pre) {
    margin: 1rem 0;
    padding: 0.95rem;
    background-color: #151311;
    border-radius: var(--radius-sm);
    border: 1px solid #4f4942;
    overflow-x: auto;
  }

  .article-body :global(pre code) {
    background-color: transparent;
    padding: 0;
    border: 0;
    white-space: pre;
    word-break: normal;
  }

  .article-body :global(pre.astro-code) {
    background: #151311;
    border-color: #4f4942;
    -webkit-overflow-scrolling: touch;
  }

  .article-body :global(pre.astro-code code) {
    display: block;
    min-width: max-content;
    line-height: 1.6;
  }

  .article-body :global(pre.astro-code .line),
  .article-body :global(pre.astro-code .line span) {
    border: 0 !important;
    text-decoration: none !important;
  }

  .article-body :global(blockquote) {
    margin: 1rem 0;
    padding-left: 0.9rem;
    border-left: 3px solid #8f8a80;
    color: var(--text-secondary);
    font-style: normal;
  }

  .article-body :global(.table-scroll) {
    margin: 1.2rem 0;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    background: #fff;
  }

  .article-body :global(.table-scroll table) {
    margin: 0;
    min-width: 100%;
    width: max-content;
    border-collapse: collapse;
    line-height: 1.5;
    font-size: 0.92rem;
  }

  .article-body :global(.table-scroll th),
  .article-body :global(.table-scroll td) {
    border: 1px solid var(--divider);
    padding: 0.52rem 0.72rem;
    text-align: left;
    vertical-align: top;
    word-break: break-word;
    white-space: normal;
  }

  .article-body :global(.table-scroll th) {
    background-color: #efeadf;
    font-weight: 700;
  }

  .article-body :global(.table-scroll tbody tr:nth-child(even) td) {
    background-color: #faf7f0;
  }

  .article-body :global(a.notion-link-card) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 1rem 0;
    padding: 0.75rem 0.9rem;
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    background: #fbf8f1;
    color: var(--text-primary);
    text-decoration: none;
    border-bottom: 1px solid var(--divider);
    transition: border-color 0.15s ease, background-color 0.15s ease;
  }

  .article-body :global(a.notion-link-card:hover) {
    border-color: #c7bcab;
    background: #f5efe2;
    color: var(--text-primary);
  }

  .article-body :global(.notion-link-card-title) {
    font-weight: 700;
    line-height: 1.4;
    overflow-wrap: anywhere;
  }

  .article-body :global(.notion-link-card-meta) {
    font-size: 0.82rem;
    color: var(--text-tertiary);
    overflow-wrap: anywhere;
  }

  .article-body :global(.notion-video-embed) {
    margin: 1.2rem 0;
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: #111;
  }

  .article-body :global(.notion-video-embed iframe) {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: 0;
  }

  .article-body :global(.mermaid) {
    margin: 1rem 0;
    padding: 0.75rem;
    border: 1px solid var(--divider);
    border-radius: var(--radius-sm);
    background: #fff;
    overflow-x: auto;
  }

  .article-body :global(.mermaid svg) {
    max-width: 100%;
    height: auto;
  }

  .article-body :global(img) {
    max-width: 100%;
    height: auto;
    margin: 1.2rem auto;
    border-radius: var(--radius-sm);
    display: block;
  }

  .article-body :global(hr) {
    margin: 2rem 0;
    border: none;
    border-top: 1px solid var(--divider);
  }

  .share-section {
    margin-top: 1.6rem;
    padding-top: 1.3rem;
    border-top: 1px solid var(--divider);
    display: flex;
    justify-content: flex-end;
  }

  .comments-section {
    margin-top: 1.6rem;
    padding-top: 1.3rem;
  }

  @media (max-width: 768px) {
    .article-title {
      font-size: var(--text-3xl);
    }
  }
</style>
