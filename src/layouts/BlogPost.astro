---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import ViewCounter from '../components/ViewCounter';
import Comments from '../components/Comments';
import ShareButtons from '../components/ShareButtons.astro';
import Footer from '../components/Footer.astro';

type NavPost = { title: string; slug: string } | null;
type RelatedPost = { title: string; slug: string; description?: string };
type Props = CollectionEntry<'blog'>['data'] & {
  slug: string;
  readingTime: number;
  previousPost?: NavPost;
  nextPost?: NavPost;
  relatedPosts?: RelatedPost[];
};

const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  slug,
  readingTime,
  previousPost = null,
  nextPost = null,
  relatedPosts = []
} = Astro.props as Props;

const formattedDate = new Intl.DateTimeFormat('ko-KR', {
  year: 'numeric',
  month: '2-digit',
  day: '2-digit'
}).format(pubDate);

const formattedUpdatedDate = updatedDate
  ? new Intl.DateTimeFormat('ko-KR', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(updatedDate)
  : null;

const safeTags = (tags || []).filter((tag): tag is string => Boolean(tag?.trim()));

const articleBodyClass = [
  'article-body mx-auto w-full max-w-[760px] min-w-0 break-words text-[17px] leading-[1.88] text-zinc-800 md:text-[18px] md:leading-[1.9]',
  '[&_h1]:mt-12 [&_h1]:mb-5 [&_h1]:text-[32px] [&_h1]:font-bold [&_h1]:leading-[1.22] md:[&_h1]:text-[42px]',
  '[&_h2]:mt-14 [&_h2]:mb-5 [&_h2]:border-b [&_h2]:border-zinc-200 [&_h2]:pb-3 [&_h2]:text-[27px] [&_h2]:font-bold [&_h2]:leading-[1.28] [&_h2]:text-zinc-950 md:[&_h2]:text-[32px]',
  '[&_h3]:mt-11 [&_h3]:mb-4 [&_h3]:text-[23px] [&_h3]:font-bold [&_h3]:leading-[1.34] [&_h3]:text-zinc-950 md:[&_h3]:text-[26px]',
  '[&_h4]:mt-9 [&_h4]:mb-3 [&_h4]:text-[21px] [&_h4]:font-semibold [&_h4]:leading-[1.36] [&_h4]:text-zinc-950',
  '[&_h5]:mt-8 [&_h5]:mb-3 [&_h5]:text-[19px] [&_h5]:font-semibold [&_h5]:leading-[1.38] [&_h5]:text-zinc-950',
  '[&_h6]:mt-8 [&_h6]:mb-3 [&_h6]:text-[18px] [&_h6]:font-semibold [&_h6]:leading-[1.38] [&_h6]:text-zinc-950',
  '[&_p]:my-5 [&_p:empty]:hidden',
  '[&_ul]:my-5 [&_ul]:list-disc [&_ul]:pl-6 [&_ol]:my-5 [&_ol]:list-decimal [&_ol]:pl-6 [&_li]:my-2 [&_li]:pl-1',
  '[&_a]:border-b [&_a]:border-zinc-300 [&_a]:font-medium [&_a]:text-zinc-950 hover:[&_a]:border-zinc-900',
  '[&_blockquote]:my-7 [&_blockquote]:border-l-4 [&_blockquote]:border-zinc-300 [&_blockquote]:bg-zinc-50 [&_blockquote]:py-1 [&_blockquote]:pl-5 [&_blockquote]:text-zinc-600',
  '[&_code]:font-mono [&_code]:text-[0.9em] [&_:not(pre)>code]:rounded-md [&_:not(pre)>code]:border [&_:not(pre)>code]:border-zinc-200 [&_:not(pre)>code]:bg-zinc-100 [&_:not(pre)>code]:px-1.5 [&_:not(pre)>code]:py-0.5',
  '[&_pre]:my-7 [&_pre]:overflow-x-auto [&_pre]:rounded-lg [&_pre]:border [&_pre]:border-zinc-800 [&_pre]:!bg-zinc-950 [&_pre]:p-4 md:[&_pre]:p-5',
  '[&_pre.astro-code]:!bg-zinc-900 [&_pre.astro-code]:[--shiki-background-color:#18181b] [&_pre.astro-code]:[--shiki-color:#e5e7eb]',
  '[&_pre_code]:text-[13px] [&_pre_code]:leading-[1.65] [&_pre_code]:text-zinc-100',
  '[&_img]:mx-auto [&_img]:my-8 [&_img]:rounded-lg',
  '[&_table]:my-7 [&_table]:min-w-full [&_table]:w-max [&_table]:border-collapse [&_table]:text-[14px] [&_table]:leading-[1.55]',
  '[&_thead]:bg-zinc-100 [&_th]:border [&_th]:border-zinc-300 [&_th]:px-3 [&_th]:py-2.5 [&_th]:text-left [&_th]:font-semibold [&_td]:border [&_td]:border-zinc-300 [&_td]:px-3 [&_td]:py-2.5 [&_td]:text-left [&_td]:align-top',
  '[&_hr]:my-10 [&_hr]:border-0 [&_hr]:border-t [&_hr]:border-zinc-200'
].join(' ');
---

<BaseLayout
  title={`${title} - Nomi Journal`}
  description={description || '아티클 상세 페이지'}
  canonicalURL={`/blog/${slug}`}
  keywords={safeTags}
  ogType="article"
>
  <Header />

  <main class="main-shell bg-page px-5 md:px-8 xl:px-0">
    <article id="detail-root" class="mx-auto grid w-full max-w-[1120px] gap-9 font-sans md:gap-12">
      <header class="w-full pt-4 md:pt-8">
        <div class="grid items-start gap-8 lg:grid-cols-[minmax(0,760px)_200px] lg:justify-center lg:gap-16">
          <div class="min-w-0">
            <a href="/posts" class="inline-flex text-[14px] font-medium text-zinc-500 underline-offset-4 transition hover:text-zinc-900 hover:underline">
              ← 글 목록
            </a>

            <div class="mt-8 flex w-full flex-wrap items-center gap-x-5 gap-y-2 text-[13px] text-zinc-500 md:flex-nowrap">
              <time class="shrink-0 whitespace-nowrap" datetime={pubDate.toISOString()}>발행 {formattedDate}</time>
              {formattedUpdatedDate && <span class="shrink-0 whitespace-nowrap">수정 {formattedUpdatedDate}</span>}
              <span class="inline-flex min-w-[7.5rem] shrink-0 whitespace-nowrap">읽는 시간 {readingTime}분</span>
              <ViewCounter client:load slug={slug} />
            </div>

            <h1 class="mt-5 text-balance text-[34px] font-bold leading-[1.2] text-zinc-950 md:text-[48px] md:leading-[1.16] lg:text-[54px]">
              {title}
            </h1>

            {description && <p class="mt-5 text-[18px] leading-[1.72] text-zinc-600 md:text-[20px] md:leading-[1.72]">{description}</p>}

            {safeTags.length > 0 && (
              <nav class="mt-7 flex flex-wrap gap-2" aria-label="글 태그">
                {safeTags.map((tag) => (
                  <a href={`/tags?tag=${tag}`} class="inline-flex h-8 items-center rounded-full bg-zinc-100 px-3 text-[13px] font-medium text-zinc-600 transition hover:bg-zinc-200 hover:text-zinc-950">
                    #{tag}
                  </a>
                ))}
              </nav>
            )}
          </div>
          <div class="hidden lg:block" aria-hidden="true"></div>
        </div>
      </header>

      <section class="grid items-start gap-8 lg:grid-cols-[minmax(0,760px)_200px] lg:justify-center lg:gap-16">
        <div class="min-w-0">
          <details class="group mb-8 rounded-lg border border-zinc-200 bg-zinc-50 lg:hidden">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-3 px-4 py-3 text-sm font-semibold text-zinc-800">
              <span>이 페이지 목차</span>
              <span aria-hidden="true" class="text-zinc-400 transition group-open:rotate-180">⌄</span>
            </summary>
            <div class="border-t border-zinc-200 px-4 py-3">
              <ol class="grid gap-2 text-sm leading-[1.5] text-zinc-600" data-toc-list>
                <li>목차를 준비하고 있습니다…</li>
              </ol>
            </div>
          </details>

          <div class={articleBodyClass}>
            <slot />
          </div>

          <div class="mx-auto mt-12 flex w-full max-w-[760px] flex-col gap-3 border-t border-zinc-200 pt-5 sm:flex-row sm:items-center sm:justify-between">
            <p class="text-[13px] text-zinc-500">공유 · 댓글 · 구독</p>
            <ShareButtons title={title} url={`/blog/${slug}`} />
          </div>
        </div>

        <aside class="sticky top-24 hidden max-h-[calc(100vh-120px)] overflow-y-auto border-l border-zinc-200 pl-5 lg:block" aria-label="이 페이지 목차">
          <h2 class="text-[13px] font-bold text-zinc-950">목차</h2>
          <ol class="mt-3 grid gap-2 text-[13px] leading-[1.45] text-zinc-500" data-toc-list>
            <li>목차를 준비하고 있습니다…</li>
          </ol>
        </aside>
      </section>

      <section class="mx-auto grid w-full max-w-[900px] gap-6 border-t border-zinc-200 pt-8 md:gap-7">
        <div class="grid gap-3 md:grid-cols-2 md:gap-5">
          <a href={previousPost ? `/blog/${previousPost.slug}` : '/posts'} class="grid min-h-[82px] content-center gap-1.5 rounded-lg border border-zinc-200 bg-white px-4 py-4 transition hover:border-zinc-400">
            <span class="text-[11px] text-zinc-500">이전 글</span>
            <strong class="text-[16px] leading-[1.3] text-zinc-900 md:text-[18px]">{previousPost?.title || '전체 글 보기'}</strong>
          </a>

          <a
            href={nextPost ? `/blog/${nextPost.slug}` : '/posts'}
            class="theme-inverse grid min-h-[82px] content-center gap-1.5 rounded-lg border border-zinc-900 bg-zinc-900 px-4 py-4 transition hover:bg-zinc-800"
          >
            <span class="theme-inverse-muted text-[11px] text-zinc-400">다음 글</span>
            <strong class="theme-inverse-text text-[16px] leading-[1.3] text-white md:text-[18px]">{nextPost?.title || '다음 글 보러가기'}</strong>
          </a>
        </div>

        <h2 class="text-[22px] font-semibold leading-tight text-zinc-900 md:text-[26px]">관련 글</h2>

        <div class="grid gap-3 md:grid-cols-3 md:gap-4">
          {(relatedPosts.length > 0 ? relatedPosts : [{ title: '아직 관련 글이 없습니다', slug: 'posts' }]).slice(0, 3).map((post) => (
            <a href={post.slug === 'posts' ? '/posts' : `/blog/${post.slug}`} class="grid gap-2 rounded-lg border border-zinc-200 bg-white p-3 transition hover:border-zinc-400">
              <div class="h-[100px] rounded-md bg-zinc-100 md:h-[120px]"></div>
              <p class="text-[14px] font-semibold leading-[1.35] text-zinc-900">{post.title}</p>
            </a>
          ))}
        </div>

        <div class="flex flex-col gap-2 rounded-lg border border-zinc-200 bg-zinc-50 px-4 py-3 text-xs text-zinc-600 md:flex-row md:items-center md:justify-between md:text-[13px]">
          <p>공유 · 댓글 · 구독</p>
          <p>댓글 보기</p>
        </div>

        <div class="border-t border-line pt-4">
          <Comments client:load />
        </div>
      </section>
    </article>
  </main>

  <Footer />
</BaseLayout>

<script is:inline>
  const parseUrl = (value) => {
    try {
      return new URL(value);
    } catch {
      return null;
    }
  };

  const getVideoEmbedUrl = (href) => {
    const parsed = parseUrl(href);
    if (!parsed) return '';

    const host = parsed.hostname.replace(/^www\./, '');

    if (host === 'youtu.be') {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
    }

    if (host === 'youtube.com' || host.endsWith('.youtube.com')) {
      if (parsed.pathname === '/watch') {
        const videoId = parsed.searchParams.get('v');
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/shorts/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
      if (parsed.pathname.startsWith('/embed/')) {
        const videoId = parsed.pathname.split('/').filter(Boolean)[1];
        return videoId ? `https://www.youtube.com/embed/${videoId}` : '';
      }
    }

    if (host === 'vimeo.com' || host.endsWith('.vimeo.com')) {
      const videoId = parsed.pathname.split('/').filter(Boolean)[0];
      if (videoId && /^\d+$/.test(videoId)) {
        return `https://player.vimeo.com/video/${videoId}`;
      }
    }

    return '';
  };

  const isStandaloneExternalLinkParagraph = (paragraph) => {
    if (!paragraph || paragraph.tagName !== 'P') return false;
    if (paragraph.closest('li, blockquote, td, th')) return false;
    if (paragraph.children.length !== 1 || paragraph.firstElementChild?.tagName !== 'A') return false;

    const inlineText = Array.from(paragraph.childNodes)
      .filter((node) => node.nodeType === Node.TEXT_NODE)
      .map((node) => node.textContent || '')
      .join('')
      .trim();

    if (inlineText) return false;

    const href = paragraph.firstElementChild.getAttribute('href') || '';
    return /^https?:\/\//.test(href);
  };

  const slugify = (text) =>
    text
      .toLowerCase()
      .trim()
      .replace(/[^\w\s가-힣-]/g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');

  const articleBody = document.querySelector('.article-body');
  const tocLists = Array.from(document.querySelectorAll('[data-toc-list]'));

  if (articleBody) {
    for (const table of articleBody.querySelectorAll('table')) {
      if (table.parentElement?.classList.contains('table-scroll')) {
        continue;
      }
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll my-5 overflow-x-auto rounded-md border border-zinc-300 bg-white';
      table.parentNode?.insertBefore(wrapper, table);
      wrapper.appendChild(table);
    }

    for (const paragraph of articleBody.querySelectorAll('p')) {
      if (!isStandaloneExternalLinkParagraph(paragraph)) continue;

      const anchor = paragraph.firstElementChild;
      const href = anchor?.getAttribute('href')?.trim() || '';
      if (!href) continue;

      const embedUrl = getVideoEmbedUrl(href);
      if (embedUrl) {
        const frame = document.createElement('iframe');
        frame.src = embedUrl;
        frame.loading = 'lazy';
        frame.allowFullscreen = true;
        frame.referrerPolicy = 'strict-origin-when-cross-origin';
        frame.title = anchor?.textContent?.trim() || '삽입된 동영상';

        const wrapper = document.createElement('figure');
        wrapper.className = 'article-video my-5 overflow-hidden rounded-md border border-zinc-300 bg-zinc-100';
        frame.className = 'block aspect-video w-full border-0';
        wrapper.appendChild(frame);
        paragraph.replaceWith(wrapper);
        continue;
      }

      const parsed = parseUrl(href);
      const domain = parsed?.hostname?.replace(/^www\./, '') || href;

      const card = document.createElement('a');
      card.className =
        'article-link-card my-5 flex flex-col gap-1.5 rounded-md border border-zinc-300 bg-zinc-50 p-3.5 text-zinc-800 transition hover:border-zinc-400';
      card.href = href;
      card.target = '_blank';
      card.rel = 'noopener noreferrer';

      const title = document.createElement('span');
      title.className = 'text-[15px] font-semibold leading-[1.35] break-all';
      title.textContent = anchor?.textContent?.trim() || href;

      const meta = document.createElement('span');
      meta.className = 'text-[13px] text-zinc-500 break-all';
      meta.textContent = domain;

      card.appendChild(title);
      card.appendChild(meta);
      paragraph.replaceWith(card);
    }

    const headings = Array.from(articleBody.querySelectorAll('h2, h3'));
    tocLists.forEach((tocList) => {
      tocList.innerHTML = '';

      if (headings.length === 0) {
        const fallback = document.createElement('li');
        fallback.textContent = '목차가 없습니다';
        tocList.appendChild(fallback);
        return;
      }

      headings.forEach((heading, index) => {
        if (!heading.id) {
          heading.id = `${slugify(heading.textContent || `section-${index + 1}`)}-${index + 1}`;
        }

        const item = document.createElement('li');
        item.className = heading.tagName === 'H3' ? 'pl-3 text-zinc-500' : '';

        const anchor = document.createElement('a');
        anchor.href = `#${heading.id}`;
        anchor.textContent = `${index + 1}. ${heading.textContent || '제목 없는 섹션'}`;
        anchor.className = 'hover:underline underline-offset-2';

        item.appendChild(anchor);
        tocList.appendChild(item);
      });
    });

    const mermaidCodeBlocks = Array.from(articleBody.querySelectorAll('pre code.language-mermaid'));
    if (mermaidCodeBlocks.length > 0) {
      import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs')
        .then(({ default: mermaid }) => {
          const nodes = [];

          for (const code of mermaidCodeBlocks) {
            const pre = code.closest('pre');
            if (!pre) continue;

            const diagram = document.createElement('div');
            diagram.className = 'article-mermaid mermaid my-5 overflow-x-auto rounded-md border border-zinc-300 bg-white p-3';
            diagram.dataset.mermaidSource = code.textContent || '';
            diagram.textContent = diagram.dataset.mermaidSource;
            pre.replaceWith(diagram);
            nodes.push(diagram);
          }

          if (nodes.length === 0) return;

          const renderMermaid = () => {
            for (const node of nodes) {
              node.removeAttribute('data-processed');
              node.textContent = node.dataset.mermaidSource || '';
            }

            mermaid.initialize({
              startOnLoad: false,
              securityLevel: 'loose',
              theme: document.documentElement.classList.contains('dark') ? 'dark' : 'neutral'
            });

            mermaid.run({ nodes }).catch(() => {
              // keep the diagram source visible if mermaid fails
            });
          };

          renderMermaid();
          window.addEventListener('themechange', renderMermaid);
        })
        .catch(() => {
          // keep original code block if mermaid fails
        });
    }
  }
</script>
