{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["headline", "summary", "trends", "watchPoints", "signals"],
  "properties": {
    "headline": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "trends": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["name", "why", "count", "examples"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 80
          },
          "why": {
            "type": "string",
            "minLength": 1,
            "maxLength": 320
          },
          "count": {
            "type": "integer",
            "minimum": 1
          },
          "examples": {
            "type": "array",
            "minItems": 1,
            "maxItems": 3,
            "items": {
              "type": "string",
              "minLength": 1,
              "maxLength": 180
            }
          }
        },
        "additionalProperties": false
      }
    },
    "watchPoints": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 180
      }
    },
    "signals": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 180
      }
    }
  },
  "additionalProperties": false
}
